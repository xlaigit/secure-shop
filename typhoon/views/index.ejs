<!DOCTYPE html>
<html lang="zh-CN">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>台风模拟预测系统</title>
  <!-- Leaflet CDN（使用国内稳定镜像） -->
  <link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" />
  <script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"></script>
  <!-- leaflet-velocity CDN -->
  <script src="https://cdn.jsdelivr.net/npm/leaflet-velocity@2.1.1/dist/leaflet-velocity.min.js"></script>
  <style>
    * { margin: 0; padding: 0; box-sizing: border-box; }
    body {
      font-family: 'Segoe UI', 'PingFang SC', 'Microsoft YaHei', sans-serif;
      background: #0a1628;
      color: #e0e8f0;
      height: 100vh;
      overflow: hidden;
    }
    /* 顶部栏 */
    #top-bar {
      height: 48px;
      background: linear-gradient(135deg, #0d1b3e, #1a2f5a);
      display: flex;
      align-items: center;
      justify-content: space-between;
      padding: 0 16px;
      border-bottom: 1px solid #1e3a6a;
      flex-shrink: 0;
    }
    #top-bar .logo { font-size: 18px; font-weight: bold; color: #4fc3f7; }
    #top-bar .login-area { display: flex; align-items: center; gap: 10px; }
    #top-bar .login-area input {
      background: #1a2f5a;
      border: 1px solid #2a4a7a;
      color: #e0e8f0;
      padding: 6px 12px;
      border-radius: 4px;
      font-size: 13px;
      width: 160px;
      outline: none;
    }
    #top-bar .login-area input:focus { border-color: #4fc3f7; }
    #top-bar .login-area button {
      background: #1e88e5;
      color: #fff;
      border: none;
      padding: 6px 16px;
      border-radius: 4px;
      cursor: pointer;
      font-size: 13px;
      transition: background 0.2s;
    }
    #top-bar .login-area button:hover { background: #1565c0; }
    #top-bar .login-area .username-display { color: #4fc3f7; font-weight: bold; font-size: 14px; }
    #top-bar .nav-link {
      color: #90caf9;
      text-decoration: none;
      font-size: 13px;
      margin-left: 16px;
    }
    #top-bar .nav-link:hover { color: #4fc3f7; }
    /* 主体布局 */
    #main-container {
      display: flex;
      height: calc(100vh - 48px);
    }
    /* 左侧面板 */
    #left-panel {
      width: 280px;
      min-width: 280px;
      background: #0d1b3e;
      border-right: 1px solid #1e3a6a;
      overflow-y: auto;
      padding: 12px;
      flex-shrink: 0;
    }
    #left-panel::-webkit-scrollbar { width: 4px; }
    #left-panel::-webkit-scrollbar-thumb { background: #2a4a7a; border-radius: 2px; }
    #left-panel .section {
      background: #112244;
      border: 1px solid #1e3a6a;
      border-radius: 6px;
      padding: 12px;
      margin-bottom: 10px;
    }
    #left-panel .section h3 {
      font-size: 14px;
      color: #4fc3f7;
      margin-bottom: 8px;
      padding-bottom: 6px;
      border-bottom: 1px solid #1e3a6a;
    }
    #left-panel .section label {
      display: block;
      font-size: 12px;
      color: #90a4c0;
      margin-bottom: 3px;
      margin-top: 6px;
    }
    #left-panel .section input, #left-panel .section select {
      width: 100%;
      background: #1a2f5a;
      border: 1px solid #2a4a7a;
      color: #e0e8f0;
      padding: 5px 8px;
      border-radius: 3px;
      font-size: 12px;
      outline: none;
    }
    #left-panel .section input:focus { border-color: #4fc3f7; }
    #left-panel .section .btn {
      width: 100%;
      padding: 7px;
      border: none;
      border-radius: 4px;
      cursor: pointer;
      font-size: 13px;
      margin-top: 6px;
      transition: background 0.2s;
    }
    .btn-primary { background: #1e88e5; color: #fff; }
    .btn-primary:hover { background: #1565c0; }
    .btn-success { background: #2e7d32; color: #fff; }
    .btn-success:hover { background: #1b5e20; }
    .btn-warning { background: #e65100; color: #fff; }
    .btn-warning:hover { background: #bf360c; }
    .btn-info { background: #00838f; color: #fff; }
    .btn-info:hover { background: #006064; }
    .btn-danger { background: #c62828; color: #fff; }
    .btn-danger:hover { background: #b71c1c; }
    .btn:disabled { opacity: 0.5; cursor: not-allowed; }
    .param-row { display: flex; gap: 6px; }
    .param-row input { flex: 1; }
    .status-text { font-size: 11px; color: #90a4c0; margin-top: 4px; }
    .status-text.loading { color: #ffa726; }
    .status-text.success { color: #66bb6a; }
    .status-text.error { color: #ef5350; }
    /* 中央地图 */
    #map-container {
      flex: 1;
      position: relative;
    }
    #map { width: 100%; height: 100%; }
    /* 右侧面板 */
    #right-panel {
      width: 300px;
      min-width: 300px;
      background: #0d1b3e;
      border-left: 1px solid #1e3a6a;
      overflow-y: auto;
      padding: 12px;
      flex-shrink: 0;
    }
    #right-panel::-webkit-scrollbar { width: 4px; }
    #right-panel::-webkit-scrollbar-thumb { background: #2a4a7a; border-radius: 2px; }
    #right-panel .section {
      background: #112244;
      border: 1px solid #1e3a6a;
      border-radius: 6px;
      padding: 10px;
      margin-bottom: 8px;
    }
    #right-panel .section h3 {
      font-size: 13px;
      color: #4fc3f7;
      margin-bottom: 6px;
      padding-bottom: 4px;
      border-bottom: 1px solid #1e3a6a;
    }
    #right-panel .info-row {
      display: flex;
      justify-content: space-between;
      font-size: 12px;
      padding: 2px 0;
      border-bottom: 1px solid #0d1b3e;
    }
    #right-panel .info-row .label { color: #90a4c0; }
    #right-panel .info-row .value { color: #e0e8f0; font-weight: 500; }
    .weather-icon { font-size: 20px; }
    /* 天气代码转图标 */
    .forecast-item {
      display: flex;
      justify-content: space-between;
      font-size: 11px;
      padding: 3px 0;
      border-bottom: 1px solid #0d1b3e;
    }
    .forecast-item .date { color: #90a4c0; }
    .forecast-item .temp { color: #4fc3f7; }
    .typhoon-log {
      font-size: 11px;
      color: #b0bec5;
      padding: 2px 0;
      border-bottom: 1px solid #0d1b3e;
      line-height: 1.5;
    }
    .wind-circle-info {
      font-size: 11px;
      margin-top: 4px;
    }
    .wind-circle-info span { display: inline-block; margin-right: 8px; }
    .dot-7 { width: 8px; height: 8px; border-radius: 50%; display: inline-block; background: rgba(255,255,0,0.4); }
    .dot-10 { width: 8px; height: 8px; border-radius: 50%; display: inline-block; background: rgba(255,165,0,0.5); }
    .dot-12 { width: 8px; height: 8px; border-radius: 50%; display: inline-block; background: rgba(255,0,0,0.6); }
    .landfall-alert {
      background: rgba(198,40,40,0.2);
      border: 1px solid #c62828;
      border-radius: 4px;
      padding: 6px;
      margin-top: 4px;
      font-size: 12px;
      color: #ef9a9a;
    }
    .landfall-alert strong { color: #ff5252; }
    /* 响应式 */
    @media (max-width: 1200px) {
      #right-panel { width: 250px; min-width: 250px; }
    }
    @media (max-width: 900px) {
      #left-panel { width: 220px; min-width: 220px; }
      #right-panel { width: 220px; min-width: 220px; }
    }
    .loading-spinner {
      display: inline-block;
      width: 12px;
      height: 12px;
      border: 2px solid #4fc3f7;
      border-top-color: transparent;
      border-radius: 50%;
      animation: spin 0.8s linear infinite;
    }
    @keyframes spin { to { transform: rotate(360deg); } }
    .toast {
      position: fixed;
      top: 60px;
      right: 20px;
      padding: 10px 18px;
      border-radius: 6px;
      font-size: 13px;
      z-index: 9999;
      max-width: 350px;
      animation: fadeIn 0.3s;
    }
    .toast.success { background: #1b5e20; color: #c8e6c9; border: 1px solid #2e7d32; }
    .toast.error { background: #b71c1c; color: #ffcdd2; border: 1px solid #c62828; }
    .toast.info { background: #0d47a1; color: #bbdefb; border: 1px solid #1565c0; }
    @keyframes fadeIn { from { opacity: 0; transform: translateY(-10px); } to { opacity: 1; transform: translateY(0); } }
  </style>
</head>
<body>
  <!-- 顶部栏 -->
  <div id="top-bar">
    <div class="logo">🌀 台风模拟预测系统</div>
    <div style="display:flex;align-items:center;">
      <a href="/" class="nav-link">返回首页</a>
      <div class="login-area">
        <% if (user) { %>
          <span class="username-display">👤 <%= user.username %></span>
          <span style="color:#ffd54f;font-size:13px;">💰 <%= user.balance %></span>
          <% if (user.shopName) { %>
            <a href="/shop/manage" class="nav-link" target="_blank">🏪 <%= user.shopName %></a>
          <% } else { %>
            <a href="/shop/create" class="nav-link" target="_blank">🏪 开店</a>
          <% } %>
          <a href="/logout" class="nav-link">退出</a>
        <% } else { %>
          <a href="/login" class="nav-link">登录</a>
          <a href="/register" class="nav-link">注册</a>
        <% } %>
      </div>
    </div>
  </div>

  <!-- 主体 -->
  <div id="main-container">
    <!-- 左侧控制面板 -->
    <div id="left-panel">
      <!-- GPS定位 -->
      <div class="section">
        <h3>📍 GPS定位</h3>
        <button class="btn btn-primary" id="gps-btn">📡 一键定位</button>
        <div class="status-text" id="gps-status">点击获取位置</div>
      </div>

      <!-- 真实台风查询 -->
      <div class="section">
        <h3>🌪️ 真实台风查询</h3>
        <button class="btn btn-info" id="real-typhoon-btn">📥 获取实时台风数据</button>
        <div class="status-text" id="real-typhoon-status">点击查询中央气象台数据</div>
      </div>

      <!-- 自定义台风生成 -->
      <div class="section">
        <h3>⚙️ 自定义台风参数</h3>
        <label>初始纬度 (°N)</label>
        <input type="number" id="typhoon-lat" value="18.5" step="0.1" min="5" max="45" />
        <label>初始经度 (°E)</label>
        <input type="number" id="typhoon-lon" value="130.5" step="0.1" min="100" max="160" />
        <div class="param-row">
          <div style="flex:1;">
            <label>中心气压 (hPa)</label>
            <input type="number" id="typhoon-pressure" value="970" step="5" min="870" max="1010" />
          </div>
          <div style="flex:1;">
            <label>最大风速 (m/s)</label>
            <input type="number" id="typhoon-wind" value="30" step="1" min="10" max="85" />
          </div>
        </div>
        <label style="margin-top:8px;">模型版本</label>
        <select id="model-select">
          <option value="v7_opt" selected>v7_opt 优化版（含地形/物理约束，推荐）</option>
          <option value="v7">v7 真实海洋数据集成模型</option>
          <option value="v6">v6 海洋特征气候态模型</option>
          <option value="v5">v5 72h高精度模型</option>
          <option value="v2">v2 增强GRU模型（含副高）</option>
          <option value="v1">v1 原始GRU模型</option>
        </select>
        <div class="status-text" style="font-size:10px;color:#78909c;margin-top:2px;">已排除V4（存在重大bug漏洞）</div>
        <button class="btn btn-success" id="simulate-btn">🚀 生成并启动模拟</button>
        <button class="btn btn-warning" id="stop-animation-btn" style="display:none;">⏹️ 停止动画</button>
        <div class="status-text" id="simulate-status">设置参数后点击生成</div>
      </div>

      <!-- 预设场景 -->
      <div class="section">
        <h3>📋 预设场景</h3>
        <select id="preset-select">
          <option value="">-- 选择预设 --</option>
          <option value="typhoon1">强台风（南海生成）</option>
          <option value="typhoon2">超强台风（西北太平洋）</option>
          <option value="typhoon3">热带风暴（近海生成）</option>
        </select>
        <button class="btn btn-primary" id="preset-btn">应用预设</button>
      </div>
    </div>

    <!-- 中央地图 -->
    <div id="map-container">
      <div id="map"></div>
    </div>

    <!-- 右侧信息面板 -->
    <div id="right-panel">
      <!-- 本地天气预报 -->
      <div class="section">
        <h3>🌤️ 本地天气预报</h3>
        <div id="weather-content">
          <div class="info-row"><span class="label">温度</span><span class="value" id="w-temp">--</span></div>
          <div class="info-row"><span class="label">体感温度</span><span class="value" id="w-apparent">--</span></div>
          <div class="info-row"><span class="label">湿度</span><span class="value" id="w-humidity">--</span></div>
          <div class="info-row"><span class="label">风向</span><span class="value" id="w-wind-dir">--</span></div>
          <div class="info-row"><span class="label">风速</span><span class="value" id="w-wind-speed">--</span></div>
          <div class="info-row"><span class="label">气压</span><span class="value" id="w-pressure">--</span></div>
          <div class="info-row"><span class="label">降水</span><span class="value" id="w-precip">--</span></div>
          <div id="weather-alert" style="display:none;margin-top:4px;padding:4px 6px;background:rgba(255,152,0,0.15);border:1px solid #ff9800;border-radius:3px;font-size:11px;color:#ffcc80;"></div>
          <div style="margin-top:6px;"><strong style="font-size:12px;color:#90a4c0;">7天预报</strong></div>
          <div id="daily-forecast"></div>
        </div>
      </div>

      <!-- 海洋数据 -->
      <div class="section">
        <h3>🌊 海洋数据</h3>
        <div class="info-row"><span class="label">洋流流速</span><span class="value" id="o-current-vel">--</span></div>
        <div class="info-row"><span class="label">洋流流向</span><span class="value" id="o-current-dir">--</span></div>
        <div class="info-row"><span class="label">海表温度</span><span class="value" id="o-sst">--</span></div>
      </div>

      <!-- 高空风场 + 垂直风切变 + 海温 -->
      <div class="section">
        <h3>🌬️ 高空风场 & 环境</h3>
        <div class="info-row"><span class="label">海表温度 (SST)</span><span class="value" id="uw-sst">--</span></div>
        <div class="info-row"><span class="label">200hPa 风速/风向</span><span class="value" id="uw-wind200" style="font-size:11px;">--</span></div>
        <div class="info-row"><span class="label">200hPa 纬向风 (u)</span><span class="value" id="uw-u200">--</span></div>
        <div class="info-row"><span class="label">200hPa 经向风 (v)</span><span class="value" id="uw-v200">--</span></div>
        <div class="info-row"><span class="label">850hPa 风速/风向</span><span class="value" id="uw-wind850" style="font-size:11px;">--</span></div>
        <div class="info-row"><span class="label">850hPa 纬向风 (u)</span><span class="value" id="uw-u850">--</span></div>
        <div class="info-row"><span class="label">850hPa 经向风 (v)</span><span class="value" id="uw-v850">--</span></div>
        <div class="info-row"><span class="label">垂直风切变 (VWS)</span><span class="value" id="uw-vws" style="font-weight:bold;">--</span></div>
        <div class="status-text" id="uw-source" style="font-size:10px;color:#78909c;">--</div>
      </div>

      <!-- 副高参数 -->
      <div class="section">
        <h3>☀️ 副热带高压</h3>
        <div class="info-row"><span class="label">副高位置</span><span class="value" id="sh-position">--</span></div>
        <div class="info-row"><span class="label">副高强度</span><span class="value" id="sh-strength">--</span></div>
        <div class="info-row"><span class="label">覆盖范围</span><span class="value" id="sh-range">--</span></div>
      </div>

      <!-- 模拟台风详情 -->
      <div class="section">
        <h3>🌀 模拟台风详情</h3>
        <div id="typhoon-detail">
          <div class="info-row"><span class="label">当前风速</span><span class="value" id="td-wind">--</span></div>
          <div class="info-row"><span class="label">中心气压</span><span class="value" id="td-pressure">--</span></div>
          <div class="info-row"><span class="label">风力等级</span><span class="value" id="td-level">--</span></div>
          <div class="info-row"><span class="label">当前位置</span><span class="value" id="td-pos">--</span></div>
          <div class="info-row"><span class="label">风圈半径</span><span class="value" id="td-radius">--</span></div>
          <div class="info-row"><span class="label">轨迹点数</span><span class="value" id="td-points">--</span></div>
          <div class="info-row"><span class="label">模拟时长</span><span class="value" id="td-duration">--</span></div>
          <div class="info-row"><span class="label">数据源</span><span class="value" id="td-source" style="font-size:11px;color:#ffa726;">--</span></div>
          <div id="landfall-info" style="display:none;" class="landfall-alert"></div>
          <div style="margin-top:6px;"><strong style="font-size:12px;color:#90a4c0;">强度演变记录</strong></div>
          <div id="intensity-log" style="max-height:150px;overflow-y:auto;margin-top:4px;"></div>
        </div>
      </div>
    </div>
  </div>

  <script>
    // ============ 全局变量 ============
    var currentUser = '';  // 通过API异步获取
    // 异步获取用户会话状态
    (function() {
      fetch('/typhoon/api/user-session')
        .then(function(r) { return r.json(); })
        .then(function(data) {
          if (data && data.user && data.user.username) {
            currentUser = data.user.username;
            // 更新顶部栏显示
            var loginArea = document.querySelector('.login-area');
            if (loginArea) {
              loginArea.innerHTML = '<span class="username-display">👤 ' + data.user.username + '</span>' +
                '<span style="color:#ffd54f;font-size:13px;">💰 ' + data.user.balance + '</span>' +
                (data.user.shopName ? '<a href="/shop/manage" class="nav-link" target="_blank">🏪 ' + data.user.shopName + '</a>' : '<a href="/shop/create" class="nav-link" target="_blank">🏪 开店</a>') +
                '<a href="/logout" class="nav-link">退出</a>';
            }
          }
        })
        .catch(function(e) { console.warn('获取用户会话失败:', e); });
    })();
    var map = null;
    var userMarker = null;
    var realTyphoonMarkers = [];
    var simTyphoonMarker = null;
    var simTrajectoryLine = null;
    var simAnimTimer = null;
    var simAnimStep = 0;
    var simData = null;
    var velocityLayer = null;
    var contourLayer = null;
    var steeringLayer = null;
    var windCircleLayer = null;
    var coastalCitiesLayer = null;
    var isAnimating = false;

    // ============ 天气代码转图标 ============
    function getWeatherIcon(code) {
      if (code === undefined || code === null) return '❓';
      if (code === 0) return '☀️';
      if (code <= 3) return '⛅';
      if (code <= 48) return '🌫️';
      if (code <= 57) return '🌧️';
      if (code <= 67) return '🌧️';
      if (code <= 77) return '❄️';
      if (code <= 82) return '🌦️';
      if (code <= 86) return '🌨️';
      return '⛈️';
    }

    function getWindDirText(deg) {
      if (deg === undefined || deg === null) return '--';
      const dirs = ['北', '东北', '东', '东南', '南', '西南', '西', '西北'];
      return dirs[Math.round(deg / 45) % 8] + '风 ' + deg + '°';
    }

    function getWindLevelText(level) {
      if (level >= 17) return '17级以上 超强台风';
      if (level >= 16) return '16级 超强台风';
      if (level >= 14) return '14-15级 强台风';
      if (level >= 12) return '12-13级 台风';
      if (level >= 10) return '10-11级 强热带风暴';
      if (level >= 8) return '8-9级 热带风暴';
      if (level >= 6) return '6-7级 热带低压';
      return level + '级';
    }

    // ============ Toast 提示 ============
    function showToast(msg, type) {
      type = type || 'info';
      var t = document.createElement('div');
      t.className = 'toast ' + type;
      t.textContent = msg;
      document.body.appendChild(t);
      setTimeout(function() { t.style.opacity = '0'; setTimeout(function() { t.remove(); }, 300); }, 3000);
    }

    // ============ 初始化地图 ============
    function initMap() {
      map = L.map('map', {
        center: [25, 125],
        zoom: 5,
        minZoom: 3,
        maxZoom: 10,
        attributionControl: false
      });

      // 高清底图层（国内优先稳定访问）
      // 高德地图（国内最稳定）
      var amapLayer = L.tileLayer('https://webrd0{s}.is.autonavi.com/appmaptile?lang=zh_cn&size=1&scale=1&style=8&x={x}&y={y}&z={z}', {
        subdomains: ['1', '2', '3', '4'],
        maxZoom: 18,
        attribution: '&copy; 高德地图'
      });
      // 高德卫星影像
      var amapSatLayer = L.tileLayer('https://webst0{s}.is.autonavi.com/appmaptile?style=6&x={x}&y={y}&z={z}', {
        subdomains: ['1', '2', '3', '4'],
        maxZoom: 18,
        attribution: '&copy; 高德地图'
      });
      // OSM标准地图
      var osmLayer = L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', {
        maxZoom: 19,
        attribution: '&copy; <a href="https://www.openstreetmap.org/copyright">OSM</a>'
      });
      // CartoDB深色
      var darkLayer = L.tileLayer('https://{s}.basemaps.cartocdn.com/dark_all/{z}/{x}/{y}{r}.png', {
        maxZoom: 19,
        attribution: '&copy; OSM &copy; CartoDB'
      });

      // 默认使用高德地图（国内最稳定）
      amapLayer.addTo(map);

      // 底图切换控件
      var baseMaps = {
        '🗺️ 高德地图(推荐)': amapLayer,
        '🛰️ 高德卫星': amapSatLayer,
        '🌍 OSM标准': osmLayer,
        '🌙 深色地图': darkLayer
      };

      L.control.layers(baseMaps, null, { position: 'topright', collapsed: true }).addTo(map);

      // 添加比例尺
      L.control.scale({ position: 'bottomleft', metric: true, imperial: false }).addTo(map);

      // 加载沿海城市标注
      loadCoastalCities();

      // 添加鼠标经纬度显示
      var mouseCoord = L.control({ position: 'bottomright' });
      mouseCoord.onAdd = function() {
        var div = L.DomUtil.create('div', 'mouse-coord');
        div.style.cssText = 'background:rgba(0,0,0,0.7);color:#fff;padding:4px 10px;border-radius:4px;font-size:12px;margin:4px';
        div.id = 'mouse-coord-display';
        div.innerHTML = '经度: -- | 纬度: --';
        return div;
      };
      mouseCoord.addTo(map);

      map.on('mousemove', function(e) {
        var el = document.getElementById('mouse-coord-display');
        if (el) {
          el.innerHTML = '经度: ' + e.latlng.lng.toFixed(4) + '° | 纬度: ' + e.latlng.lat.toFixed(4) + '°';
        }
      });
    }

    // ============ 加载沿海城市 ============
    function loadCoastalCities() {
      var cities = <%- coastalCities %>;
      coastalCitiesLayer = L.layerGroup().addTo(map);
      cities.forEach(function(c) {
        var marker = L.circleMarker([c.lat, c.lon], {
          radius: 3,
          color: '#90caf9',
          fillColor: '#42a5f5',
          fillOpacity: 0.8,
          weight: 1
        }).addTo(coastalCitiesLayer);
        marker.bindTooltip(c.name, { direction: 'top', offset: [0, -5] });
      });
    }

    // ============ GPS定位 ============
    document.getElementById('gps-btn').addEventListener('click', function() {
      var statusEl = document.getElementById('gps-status');
      if (!navigator.geolocation) {
        statusEl.textContent = '❌ 浏览器不支持GPS定位';
        statusEl.className = 'status-text error';
        return;
      }
      statusEl.textContent = '⏳ 获取定位中...';
      statusEl.className = 'status-text loading';
      navigator.geolocation.getCurrentPosition(function(pos) {
        var lat = pos.coords.latitude;
        var lon = pos.coords.longitude;
        statusEl.textContent = '✅ 定位成功: ' + lat.toFixed(4) + ', ' + lon.toFixed(4);
        statusEl.className = 'status-text success';
        if (userMarker) map.removeLayer(userMarker);
        userMarker = L.circleMarker([lat, lon], {
          radius: 8,
          color: '#4fc3f7',
          fillColor: '#0288d1',
          fillOpacity: 0.9,
          weight: 2
        }).addTo(map);
        userMarker.bindPopup('📍 当前位置<br>纬度: ' + lat.toFixed(4) + '<br>经度: ' + lon.toFixed(4));
        map.setView([lat, lon], 6);
        // 查询本地天气
        fetchLocationWeather(lat, lon);
        // 查询高空风 + 海温
        fetchUpperWind(lat, lon);
      }, function(err) {
        statusEl.textContent = '❌ 定位失败: ' + err.message;
        statusEl.className = 'status-text error';
      }, { enableHighAccuracy: true, timeout: 10000 });
    });

    // ============ 查询定位点天气 ============
    function fetchLocationWeather(lat, lon) {
      fetch('/typhoon/api/location-weather?lat=' + lat + '&lon=' + lon)
        .then(function(r) { return r.json(); })
        .then(function(data) {
          if (data.success) {
            updateWeatherPanel(data);
            updateMarinePanel(data.marine);
          }
        })
        .catch(function(err) { console.error('天气查询失败:', err); });
    }

    // ============ 更新天气面板 ============
    function updateWeatherPanel(data) {
      var c = data.current || {};
      document.getElementById('w-temp').textContent = c.temperature !== undefined ? c.temperature + '°C' : '--';
      document.getElementById('w-apparent').textContent = c.apparentTemp !== undefined ? c.apparentTemp + '°C' : '--';
      document.getElementById('w-humidity').textContent = c.humidity !== undefined ? c.humidity + '%' : '--';
      document.getElementById('w-wind-dir').textContent = getWindDirText(c.windDirection);
      document.getElementById('w-wind-speed').textContent = c.windSpeed !== undefined ? c.windSpeed + ' km/h' : '--';
      document.getElementById('w-pressure').textContent = c.pressure !== undefined ? c.pressure + ' hPa' : '--';
      document.getElementById('w-precip').textContent = c.precipitation !== undefined ? c.precipitation + ' mm' : '--';

      // 7天预报
      var forecastEl = document.getElementById('daily-forecast');
      forecastEl.innerHTML = '';
      if (data.daily && data.daily.length > 0) {
        data.daily.forEach(function(d) {
          var dateStr = d.date ? d.date.substring(5) : '--';
          var icon = getWeatherIcon(d.weatherCode);
          var div = document.createElement('div');
          div.className = 'forecast-item';
          div.innerHTML = '<span class="date">' + icon + ' ' + dateStr + '</span><span class="temp">' +
            (d.tempMin !== undefined ? d.tempMin + '°' : '--') + '~' + (d.tempMax !== undefined ? d.tempMax + '°' : '--') + '</span>' +
            '<span style="color:#90a4c0;">' + (d.precipProb !== undefined ? d.precipProb + '%' : '') + '</span>';
          forecastEl.appendChild(div);
        });
      } else {
        forecastEl.innerHTML = '<div class="forecast-item" style="color:#90a4c0;">暂无预报数据</div>';
      }
    }

    // ============ 更新海洋面板 ============
    function updateMarinePanel(marine) {
      if (!marine) return;
      document.getElementById('o-current-vel').textContent = marine.currentVelocity !== undefined ? marine.currentVelocity + ' m/s' : '--';
      document.getElementById('o-current-dir').textContent = getWindDirText(marine.currentDirection);
      document.getElementById('o-sst').textContent = marine.seaSurfaceTemp !== undefined ? marine.seaSurfaceTemp + '°C' : '--';
    }

    // ============ 获取并更新高空风场 + 垂直风切变 ============
    function fetchUpperWind(lat, lon) {
      const qLat = lat || 25;
      const qLon = lon || 125;
      // 同时获取高空风 + 海温
      Promise.all([
        fetch('/typhoon/api/upper-wind?lat=' + qLat + '&lon=' + qLon).then(function(r) { return r.json(); }),
        fetch('/typhoon/api/marine-weather?lat=' + qLat + '&lon=' + qLon).then(function(r) { return r.json(); })
      ]).then(function(results) {
        var windData = results[0];
        var marineData = results[1];
        if (windData.success) {
          // 200hPa风速风向
          if (windData.windSpeed200 !== undefined && windData.windDir200 !== undefined) {
            document.getElementById('uw-wind200').textContent = windData.windSpeed200.toFixed(1) + ' m/s @ ' + getWindDirText(windData.windDir200);
          }
          // 200hPa u/v
          document.getElementById('uw-u200').textContent = windData.u200 !== null ? windData.u200.toFixed(1) + ' m/s' : '--';
          document.getElementById('uw-v200').textContent = windData.v200 !== null ? windData.v200.toFixed(1) + ' m/s' : '--';
          // 850hPa风速风向
          if (windData.windSpeed850 !== undefined && windData.windDir850 !== undefined) {
            document.getElementById('uw-wind850').textContent = windData.windSpeed850.toFixed(1) + ' m/s @ ' + getWindDirText(windData.windDir850);
          }
          // 850hPa u/v
          document.getElementById('uw-u850').textContent = windData.u850 !== null ? windData.u850.toFixed(1) + ' m/s' : '--';
          document.getElementById('uw-v850').textContent = windData.v850 !== null ? windData.v850.toFixed(1) + ' m/s' : '--';
          // 垂直风切变 - 带颜色显示
          var vws = windData.verticalWindShear;
          if (vws !== null) {
            var vwsEl = document.getElementById('uw-vws');
            vwsEl.textContent = vws.toFixed(2) + ' m/s';
            // 颜色：<10 绿色(有利), 10-20 黄色(一般), >20 红色(不利)
            if (vws < 10) vwsEl.style.color = '#66bb6a';
            else if (vws < 20) vwsEl.style.color = '#ffa726';
            else vwsEl.style.color = '#ef5350';
          } else {
            document.getElementById('uw-vws').textContent = '--';
          }
          document.getElementById('uw-source').textContent = '数据源: ' + (windData.dataSource || '--');
        }
        // 海温
        if (marineData.success && marineData.marine && marineData.marine.current) {
          var sst = marineData.marine.current.seaSurfaceTemp;
          document.getElementById('uw-sst').textContent = sst !== undefined ? sst + '°C' : '--';
        } else if (windData.success) {
          // 尝试从高空风数据中获取SST（没有这个字段，保留为--）
        }
      }).catch(function(err) {
        console.error('高空风/海温获取失败:', err);
      });
    }

    // ============ 查询真实台风 ============
    document.getElementById('real-typhoon-btn').addEventListener('click', function() {
      if (!currentUser) { showToast('请先登录', 'error'); return; }
      var statusEl = document.getElementById('real-typhoon-status');
      statusEl.textContent = '⏳ 查询中...';
      statusEl.className = 'status-text loading';
      fetch('/typhoon/api/real-typhoon')
        .then(function(r) { return r.json(); })
        .then(function(data) {
          if (data.success) {
            // 清除旧标记
            realTyphoonMarkers.forEach(function(m) { map.removeLayer(m); });
            realTyphoonMarkers = [];
            if (data.typhoonList && data.typhoonList.length > 0) {
              data.typhoonList.forEach(function(t) {
                if (t.lat && t.lon) {
                  var marker = L.circleMarker([t.lat, t.lon], {
                    radius: 12,
                    color: '#ff5252',
                    fillColor: '#d32f2f',
                    fillOpacity: 0.7,
                    weight: 2
                  }).addTo(map);
                  marker.bindTooltip(
                    '<b>' + t.name + '</b><br>' +
                    '位置: ' + t.lat + '°N, ' + t.lon + '°E<br>' +
                    '风速: ' + (t.windSpeed || '--') + ' m/s<br>' +
                    '等级: ' + (t.windLevel || '--') + '<br>' +
                    '气压: ' + (t.pressure || '--') + ' hPa<br>' +
                    '移动: ' + (t.moveSpeed || '--') + ' km/h ' + (t.moveDir || '') + '°<br>' +
                    (t.radius7 ? '7级风圈: ' + t.radius7 + 'km' : ''),
                    { direction: 'top' }
                  );
                  realTyphoonMarkers.push(marker);
                }
              });
              // 绘制预报路径（含路径点标记）
              if (data.forecast && data.forecast.length > 0) {
                var forecastCoords = data.forecast.filter(function(f) { return f.lat && f.lon; })
                  .map(function(f) { return [f.lat, f.lon]; });
                if (forecastCoords.length > 1) {
                  var forecastLine = L.polyline(forecastCoords, {
                    color: '#ff7043',
                    weight: 2,
                    dashArray: '8,8',
                    opacity: 0.7
                  }).addTo(map);
                  realTyphoonMarkers.push(forecastLine);
                }
                // 在每个预报路径点上添加标记
                data.forecast.forEach(function(f) {
                  if (!f.lat || !f.lon) return;
                  var fMarker = L.circleMarker([f.lat, f.lon], {
                    radius: 5,
                    color: '#ff7043',
                    fillColor: '#ff8a65',
                    fillOpacity: 0.6,
                    weight: 1.5,
                    dashArray: '3,3'
                  }).addTo(map);
                  var fWindLevel = getWindLevelText(f.windLevel || '');
                  fMarker.bindTooltip(
                    '🔮 预报 ' + (f.time ? new Date(f.time).toLocaleString('zh-CN', {month:'short',day:'numeric',hour:'2-digit'}) : '') + '<br>' +
                    '📍 ' + f.lat + '°N, ' + f.lon + '°E<br>' +
                    '💨 风速: ' + (f.windSpeed || '--') + ' m/s<br>' +
                    '📊 等级: ' + (f.windLevel || '--') + '<br>' +
                    '🔽 气压: ' + (f.pressure || '--') + ' hPa'
                  );
                  realTyphoonMarkers.push(fMarker);
                });
              }
              // 显示数据源
              var sourceText = data.dataSource || '模拟数据';
              statusEl.textContent = '✅ 已加载 ' + data.typhoonList.length + ' 个台风（' + sourceText + '）';
              statusEl.className = 'status-text success';
              // 更新数据源显示
              document.getElementById('td-source').textContent = sourceText;
              if (data.note) {
                document.getElementById('td-source').title = data.note;
              }
              if (data.typhoonList[0]) {
                map.setView([data.typhoonList[0].lat, data.typhoonList[0].lon], 5);
              }
            } else {
              statusEl.textContent = '⚠️ 当前无活跃台风';
              statusEl.className = 'status-text';
            }
          } else {
            statusEl.textContent = '❌ ' + (data.message || '查询失败');
            statusEl.className = 'status-text error';
          }
        })
        .catch(function(err) {
          statusEl.textContent = '❌ 网络错误: ' + err.message;
          statusEl.className = 'status-text error';
        });
    });

    // ============ 预设场景 ============
    document.getElementById('preset-btn').addEventListener('click', function() {
      var val = document.getElementById('preset-select').value;
      if (!val) { showToast('请选择预设场景', 'error'); return; }
