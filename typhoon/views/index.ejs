    // ============ 清理所有模拟状态 ============
    function clearSimulation() {
      // 停止动画
      isAnimating = false;
      if (simAnimTimer) { clearTimeout(simAnimTimer); simAnimTimer = null; }
      simAnimStep = 0;
      document.getElementById('stop-animation-btn').style.display = 'none';
      // 清除轨迹线
      if (simTrajectoryLine) { map.removeLayer(simTrajectoryLine); simTrajectoryLine = null; }
      // 清除台风标记
      if (simTyphoonMarker) { map.removeLayer(simTyphoonMarker); simTyphoonMarker = null; }
      // 清除风圈
      if (windCircleLayer) { map.removeLayer(windCircleLayer); windCircleLayer = null; }
      // 清除标签
      if (simLabelMarker) { map.removeLayer(simLabelMarker); simLabelMarker = null; }
      // 清除图例
      if (window._legendControl) { map.removeControl(window._legendControl); window._legendControl = null; }
      simData = null;
    }

    // ============ 台风推演模拟 ============
    document.getElementById('simulate-btn').addEventListener('click', function() {
      if (!currentUser) { showToast('请先登录', 'error'); return; }
      // 先清理旧模拟的全部数据
      clearSimulation();
      var lat = parseFloat(document.getElementById('typhoon-lat').value);
      var lon = parseFloat(document.getElementById('typhoon-lon').value);
      var pressure = parseFloat(document.getElementById('typhoon-pressure').value);
      var windSpeed = parseFloat(document.getElementById('typhoon-wind').value);
      if (!lat || !lon || !pressure || !windSpeed) {
        showToast('请填写完整的台风参数', 'error');
        return;
      }
      var statusEl = document.getElementById('simulate-status');
      statusEl.textContent = '⏳ 正在推演计算...';
      statusEl.className = 'status-text loading';
      this.disabled = true;
      this.textContent = '⏳ 计算中...';

      var selectedModel = document.getElementById('model-select').value;
      fetch('/typhoon/api/simulate-typhoon', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ lat: lat, lon: lon, pressure: pressure, windSpeed: windSpeed, model: selectedModel })
      })
      .then(function(r) { return r.json(); })
      .then(function(data) {
        document.getElementById('simulate-btn').disabled = false;
        document.getElementById('simulate-btn').textContent = '🚀 生成并启动模拟';
        if (data.success) {
          simData = data;
          statusEl.textContent = '✅ 推演完成，共 ' + data.trajectory.length + ' 个轨迹点';
          statusEl.className = 'status-text success';
          // 绘制轨迹
          drawTrajectory(data.trajectory);
          // 更新详情面板
          updateTyphoonDetail(data);
          // 启动动画
          startAnimation(data.trajectory);
          // 刷新GFS和海洋数据
          refreshEnvironmentData();
          showToast('模拟完成，点击播放动画', 'success');
        } else {
          statusEl.textContent = '❌ 推演失败';
          statusEl.className = 'status-text error';
          showToast('推演失败', 'error');
        }
      })
      .catch(function(err) {
        document.getElementById('simulate-btn').disabled = false;
        document.getElementById('simulate-btn').textContent = '🚀 生成并启动模拟';
        statusEl.textContent = '❌ 错误: ' + err.message;
        statusEl.className = 'status-text error';
        showToast('推演错误: ' + err.message, 'error');
      });
    });

    // ============ 绘制轨迹（含可点击标注点） ============
    function drawTrajectory(trajectory) {
      // 清除旧轨迹（clearSimulation已处理，双重保险）
      if (simTrajectoryLine) map.removeLayer(simTrajectoryLine);
      if (simTyphoonMarker) map.removeLayer(simTyphoonMarker);
      if (windCircleLayer) { map.removeLayer(windCircleLayer); windCircleLayer = null; }

      if (!trajectory || trajectory.length < 2) return;

      // 用连续折线绘制完整轨迹，确保不断开
      // 每段单独着色：intensifying=绿, mature=黄, weakening=橙, landfall=红
      var allCoords = trajectory.map(function(t) { return [t.lat, t.lon]; });
      var lineSegments = [];
      var currentColor = null;
      var currentPoints = [];

      function flushSegment() {
        if (currentPoints.length > 1 && currentColor) {
          lineSegments.push(L.polyline(currentPoints, {
            color: currentColor, weight: 3, opacity: 0.8
          }));
        }
      }

      trajectory.forEach(function(t) {
        var color;
        if (t.stage === 'intensifying' || t.stage === 'initial') color = '#4caf50';
        else if (t.stage === 'mature') color = '#ffeb3b';
        else if (t.stage === 'weakening' || t.stage === 'ocean') color = '#ff9800';
        else if (t.stage === 'landfall') color = '#f44336';
        else color = '#9e9e9e';

        if (color !== currentColor) {
          flushSegment();
          currentColor = color;
          // 新段包含上一个点的坐标，确保连续
          if (currentPoints.length > 0) {
            currentPoints = [currentPoints[currentPoints.length - 1]];
          } else {
            currentPoints = [];
          }
        }
        currentPoints.push([t.lat, t.lon]);
      });
      flushSegment();

      simTrajectoryLine = L.layerGroup(lineSegments).addTo(map);

      // 在每个路径点上添加可点击标注（显示完整强度数据）
      trajectory.forEach(function(t) {
        var windDesc = getWindLevelText(t.windLevel);
        var marker = L.circleMarker([t.lat, t.lon], {
          radius: 5,
          color: '#fff',
          fillColor: t.stage === 'landfall' ? '#f44336' : t.stage === 'intensifying' ? '#4caf50' : t.stage === 'mature' ? '#ffeb3b' : '#ff9800',
          fillOpacity: 0.8,
          weight: 1.5
        }).addTo(simTrajectoryLine);
        marker.bindTooltip(
          '🌀 第' + (t.step * 6) + '小时<br>' +
          '📍 ' + t.lat + '°N, ' + t.lon + '°E<br>' +
          '💨 风速: ' + t.windSpeed + ' m/s<br>' +
          '📊 等级: ' + windDesc + '<br>' +
          '🔽 气压: ' + t.pressure + ' hPa<br>' +
          (t.radius ? '🌀 7级风圈: ' + t.radius.r7 + 'km<br>' +
          '🌀 10级风圈: ' + t.radius.r10 + 'km<br>' : '') +
          (t.sst ? '🌡️ 海温: ' + t.sst + '°C' : '')
        );
        marker.on('click', function() {
          map.setView([t.lat, t.lon], 6);
        });
      });

      // 添加起始点标记（大一些）
      var first = trajectory[0];
      L.circleMarker([first.lat, first.lon], {
        radius: 8,
        color: '#4caf50',
        fillColor: '#2e7d32',
        fillOpacity: 1,
        weight: 2
      }).addTo(simTrajectoryLine).bindTooltip('🟢 起点<br>' + first.windSpeed + 'm/s ' + first.pressure + 'hPa');

      // 添加终点标记
      var last = trajectory[trajectory.length - 1];
      L.circleMarker([last.lat, last.lon], {
        radius: 8,
        color: '#f44336',
        fillColor: '#c62828',
        fillOpacity: 1,
        weight: 2
      }).addTo(simTrajectoryLine).bindTooltip('🔴 终点<br>' + last.windSpeed + 'm/s ' + last.pressure + 'hPa');

      // 添加图例
      addMapLegend();

      // 调整地图视野
      map.fitBounds(allCoords, { padding: [50, 50] });
    }

    // ============ 添加地图图例 ============
    function addMapLegend() {
      var legend = L.control({ position: 'bottomleft' });
      legend.onAdd = function() {
        var div = L.DomUtil.create('div', 'map-legend');
        div.style.cssText = 'background:rgba(0,0,0,0.8);color:#fff;padding:8px 12px;border-radius:6px;font-size:12px;line-height:1.8;min-width:140px';
        div.innerHTML =
          '<div style="font-weight:bold;margin-bottom:4px;color:#4fc3f7;">🌀 轨迹图例</div>' +
          '<div><span style="display:inline-block;width:20px;height:3px;background:#4caf50;vertical-align:middle;margin-right:6px;"></span>增强阶段</div>' +
          '<div><span style="display:inline-block;width:20px;height:3px;background:#ffeb3b;vertical-align:middle;margin-right:6px;"></span>成熟阶段</div>' +
          '<div><span style="display:inline-block;width:20px;height:3px;background:#ff9800;vertical-align:middle;margin-right:6px;"></span>减弱阶段</div>' +
          '<div><span style="display:inline-block;width:20px;height:3px;background:#f44336;vertical-align:middle;margin-right:6px;"></span>登陆阶段</div>' +
          '<hr style="border-color:#333;margin:4px 0;">' +
          '<div><span style="display:inline-block;width:10px;height:10px;border-radius:50%;background:rgba(255,235,59,0.3);border:1px solid #ffeb3b;vertical-align:middle;margin-right:6px;"></span>7级风圈</div>' +
          '<div><span style="display:inline-block;width:10px;height:10px;border-radius:50%;background:rgba(255,152,0,0.3);border:1px solid #ff9800;vertical-align:middle;margin-right:6px;"></span>10级风圈</div>' +
          '<div><span style="display:inline-block;width:10px;height:10px;border-radius:50%;background:rgba(244,67,54,0.3);border:1px solid #f44336;vertical-align:middle;margin-right:6px;"></span>12级风圈</div>';
        return div;
      };
      legend.addTo(map);
      // 保存引用以便后续移除
      if (window._legendControl) map.removeControl(window._legendControl);
      window._legendControl = legend;
    }

    // ============ 更新台风详情面板 ============
    function updateTyphoonDetail(data) {
      var t = data.trajectory;
      var last = t[t.length - 1];
      document.getElementById('td-wind').textContent = last.windSpeed + ' m/s';
      document.getElementById('td-pressure').textContent = last.pressure + ' hPa';
      document.getElementById('td-level').textContent = getWindLevelText(last.windLevel);
      document.getElementById('td-pos').textContent = last.lat + '°N, ' + last.lon + '°E';
      document.getElementById('td-radius').textContent = '7级:' + (last.radius ? last.radius.r7 + 'km' : '--') +
        ' 10级:' + (last.radius ? last.radius.r10 + 'km' : '--') +
        ' 12级:' + (last.radius ? last.radius.r12 + 'km' : '--');
      document.getElementById('td-points').textContent = t.length + ' 个';
      document.getElementById('td-duration').textContent = (data.durationHours || (t.length * 6)) + ' 小时';
      document.getElementById('td-source').textContent = data.dataSource || '模拟数据';
      if (data.note) {
        document.getElementById('td-source').title = data.note;
      }

      // 登陆信息（只存数据，动画播放到登陆点时再显示）
      var landfallEl = document.getElementById('landfall-info');
      if (data.landfallPrediction && data.landfallPrediction.location) {
        landfallEl.style.display = 'block';
        landfallEl.innerHTML = '<strong>⏳ 登陆预判</strong><br>' +
          '待动画播放至登陆点后显示...<br>' +
          '<span style="font-size:11px;color:#78909c;">预计: ' + data.landfallPrediction.location + ' | ' +
          data.landfallPrediction.description + '</span>';
        // 保存landfall数据供动画使用
        window._landfallData = data.landfallPrediction;
        window._landfallShown = false;
      } else {
        landfallEl.style.display = 'block';
        landfallEl.innerHTML = '<strong>ℹ️ 路径预判</strong><br>' + data.landfallPrediction.description;
      }

      // 强度演变记录
      var logEl = document.getElementById('intensity-log');
      logEl.innerHTML = '';
      if (data.intensityLog && data.intensityLog.length > 0) {
        data.intensityLog.forEach(function(line) {
          var div = document.createElement('div');
          div.className = 'typhoon-log';
          div.textContent = line;
          logEl.appendChild(div);
        });
      } else {
        logEl.innerHTML = '<div class="typhoon-log" style="color:#90a4c0;">暂无记录</div>';
      }

      // 事件记录（含岛屿/大陆登陆事件）
      if (data.events && data.events.length > 0) {
        var eventDiv = document.getElementById('landfall-info');
        data.events.forEach(function(evt) {
          if (evt.type === 'island_landfall') {
            var eventHtml = '<div style="background:#ff9800;color:#fff;padding:6px 10px;border-radius:4px;margin-top:6px;font-size:12px;">' +
              '🏝️ ' + evt.description + '</div>';
            eventDiv.innerHTML += eventHtml;
          }
        });
      }
    }

    // ============ 启动动画（含强度标签和风圈） ============
    var simLabelMarker = null; // 强度文字标签
    function startAnimation(trajectory) {
      if (isAnimating) return;
      isAnimating = true;
      simAnimStep = 0;
      document.getElementById('stop-animation-btn').style.display = 'block';

      // 清除旧标记
      if (simTyphoonMarker) map.removeLayer(simTyphoonMarker);
      if (windCircleLayer) { map.removeLayer(windCircleLayer); windCircleLayer = null; }
      if (simLabelMarker) map.removeLayer(simLabelMarker);

      function step() {
        if (!isAnimating || simAnimStep >= trajectory.length) {
          isAnimating = false;
          document.getElementById('stop-animation-btn').style.display = 'none';
          // 动画结束后保留最后一个状态
          return;
        }
        var t = trajectory[simAnimStep];
        // 更新红色圆点（更大更醒目）
        if (simTyphoonMarker) map.removeLayer(simTyphoonMarker);
        simTyphoonMarker = L.circleMarker([t.lat, t.lon], {
          radius: 16,
          color: '#ff1744',
          fillColor: '#d50000',
          fillOpacity: 0.9,
          weight: 3,
          pane: 'markerPane'
        }).addTo(map);
        simTyphoonMarker.bindTooltip(
          '🌀 模拟台风<br>' +
          '📍 ' + t.lat + '°N, ' + t.lon + '°E<br>' +
          '💨 风速: ' + t.windSpeed + ' m/s<br>' +
          '🔽 气压: ' + t.pressure + ' hPa<br>' +
          '📊 风力等级: ' + t.windLevel + '级 (' + getWindLevelText(t.windLevel) + ')<br>' +
          (t.sst ? '🌡️ 海温: ' + t.sst + '°C' : ''),
          { direction: 'top', offset: [0, -10] }
        );

        // 添加强度文字标签（在地图上的台风旁边）
        if (simLabelMarker) map.removeLayer(simLabelMarker);
        var windDesc = getWindLevelText(t.windLevel).split(' ')[0];
        simLabelMarker = L.marker([t.lat + 0.5, t.lon + 0.5], {
          icon: L.divIcon({
            className: 'typhoon-label',
            html: '<div style="background:rgba(0,0,0,0.75);color:#fff;padding:3px 8px;border-radius:4px;font-size:13px;font-weight:bold;border:1px solid #ff1744;white-space:nowrap;">💨' + t.windSpeed + 'm/s | 🔽' + t.pressure + 'hPa | ' + windDesc + '</div>',
            iconSize: [0, 0],
            iconAnchor: [0, 0]
          })
        }).addTo(map);

        // 更新风圈（加大透明度）
        drawWindCircles(t);

        // 更新详情面板的当前值
        document.getElementById('td-wind').textContent = t.windSpeed + ' m/s';
        document.getElementById('td-pressure').textContent = t.pressure + ' hPa';
        document.getElementById('td-level').textContent = getWindLevelText(t.windLevel);
        document.getElementById('td-pos').textContent = t.lat + '°N, ' + t.lon + '°E';
        document.getElementById('td-radius').textContent = '7级:' + (t.radius ? t.radius.r7 + 'km' : '--') +
          ' 10级:' + (t.radius ? t.radius.r10 + 'km' : '--') +
          ' 12级:' + (t.radius ? t.radius.r12 + 'km' : '--');

        // 动画播放到登陆点时，更新登陆信息
        if (t.stage === 'landfall' && window._landfallData && !window._landfallShown) {
          window._landfallShown = true;
          var lf = window._landfallData;
          document.getElementById('landfall-info').innerHTML = '<strong>⚠️ 登陆警报</strong><br>' +
            '📍 地点: ' + lf.location + '<br>' +
            '⏰ 时间: ' + (lf.time ? new Date(lf.time).toLocaleString() : '--') + '<br>' +
            '💨 风速: ' + lf.windSpeed + ' m/s<br>' +
            '🔽 气压: ' + lf.pressure + ' hPa<br>' +
            '📊 等级: ' + lf.description;
        }

        simAnimStep++;
        // 每300ms推进一步（模拟6小时）
        simAnimTimer = setTimeout(step, 300);
      }
      step();
    }

    // ============ 停止动画 ============
    document.getElementById('stop-animation-btn').addEventListener('click', function() {
      isAnimating = false;
      if (simAnimTimer) clearTimeout(simAnimTimer);
      this.style.display = 'none';
    });

    // ============ 绘制风圈（加大透明度，更醒目） ============
    function drawWindCircles(t) {
      if (windCircleLayer) { map.removeLayer(windCircleLayer); windCircleLayer = null; }
      if (!t.radius) return;
      var lat = t.lat, lon = t.lon;
      var r7 = t.radius.r7 || 0;
      var r10 = t.radius.r10 || 0;
      var r12 = t.radius.r12 || 0;
      var group = L.layerGroup();
      // 7级风圈（黄色半透明，加大描边）
      if (r7 > 0) {
        L.circle([lat, lon], {
          radius: r7 * 1000,
          color: '#ffeb3b',
          fillColor: '#ffeb3b',
          fillOpacity: 0.15,
          weight: 2,
          opacity: 0.6
        }).addTo(group).bindTooltip('🟡 7级风圈 ' + r7 + 'km');
      }
      // 10级风圈（橙色）
      if (r10 > 0) {
        L.circle([lat, lon], {
          radius: r10 * 1000,
          color: '#ff9800',
          fillColor: '#ff9800',
          fillOpacity: 0.18,
          weight: 2,
          opacity: 0.7
        }).addTo(group).bindTooltip('🟠 10级风圈 ' + r10 + 'km');
      }
      // 12级风圈（红色）
      if (r12 > 0) {
        L.circle([lat, lon], {
          radius: r12 * 1000,
          color: '#f44336',
          fillColor: '#f44336',
          fillOpacity: 0.2,
          weight: 2,
          opacity: 0.8
        }).addTo(group).bindTooltip('🔴 12级风圈 ' + r12 + 'km');
      }
      windCircleLayer = group.addTo(map);
    }

    // ============ 刷新环境数据（GFS + 海洋） ============
    function refreshEnvironmentData() {
      // 获取GFS副高数据
      fetch('/typhoon/api/gfs')
        .then(function(r) { return r.json(); })
        .then(function(data) {
          if (data.success) {
            updateSHPanel(data);
            drawContour5880(data.contour5880);
            drawSteeringFlow(data.gridData);
          }
        })
        .catch(function(err) { console.error('GFS查询失败:', err); });

      // 获取海洋数据（使用台风初始位置）
      var lat = document.getElementById('typhoon-lat').value;
      var lon = document.getElementById('typhoon-lon').value;
      fetch('/typhoon/api/marine-weather?lat=' + lat + '&lon=' + lon)
        .then(function(r) { return r.json(); })
        .then(function(data) {
          if (data.success) {
            drawOceanCurrent(data);
            if (data.marine && data.marine.current) {
              updateMarinePanel(data.marine.current);
            }
            if (data.weather && data.weather.current) {
              updateWeatherPanel(data.weather);
            }
          }
        })
        .catch(function(err) { console.error('海洋数据查询失败:', err); });
      // 获取高空风 + 海温
      fetchUpperWind(lat, lon);
    }

    // ============ 更新副高面板 ============
    function updateSHPanel(data) {
      document.getElementById('sh-position').textContent = data.description || '--';
      if (data.avgHeight !== undefined) {
        document.getElementById('sh-strength').textContent = '平均 ' + data.avgHeight + ' gpm (范围 ' + (data.minHeight || '--') + '~' + (data.maxHeight || '--') + ' gpm)';
      } else if (data.gridData && data.gridData.length > 0) {
        var heights = data.gridData.map(function(p) { return p.height; });
        var avg = heights.reduce(function(a, b) { return a + b; }, 0) / heights.length;
        var max = Math.max.apply(null, heights);
        var min = Math.min.apply(null, heights);
        document.getElementById('sh-strength').textContent = '平均 ' + Math.round(avg) + ' gpm (范围 ' + min + '~' + max + ' gpm)';
      } else {
        document.getElementById('sh-strength').textContent = '--';
      }
      if (data.count588 !== undefined) {
        document.getElementById('sh-range').textContent = data.count588 + ' 个网格点 ≥ 5880gpm' + (data.dataSource ? '（' + data.dataSource + '）' : '');
      } else if (data.gridData && data.gridData.length > 0) {
        document.getElementById('sh-range').textContent = data.gridData.filter(function(p) { return p.height >= 5880; }).length + ' 个网格点 ≥ 5880gpm';
      } else {
        document.getElementById('sh-range').textContent = '--';
      }
    }

    // ============ 绘制5880等高线 ============
    function drawContour5880(contour) {
      if (contourLayer) { map.removeLayer(contourLayer); contourLayer = null; }
      if (!contour || contour.length < 3) return;
      var coords = contour.map(function(p) { return [p.lat, p.lon]; });
      contourLayer = L.polygon(coords, {
        color: '#ff9800',
        fillColor: '#ff9800',
        fillOpacity: 0.12,
        weight: 2,
        opacity: 0.5,
        interactive: false
      }).addTo(map);
      contourLayer.bindTooltip('副热带高压 5880gpm 等高线', { direction: 'top' });
    }

    // ============ 绘制引导气流箭头 + 网格点 ============
    function drawSteeringFlow(gridData) {
      if (steeringLayer) { map.removeLayer(steeringLayer); steeringLayer = null; }
      if (!gridData || gridData.length === 0) return;

      var group = L.layerGroup();

      // 1. 画网格点（小圆点），显示数据覆盖范围，包括南海
      var gridDots = [];
      // 按经纬度分组，确保每个网格点只画一个
      var seen = {};
      for (var k = 0; k < gridData.length; k++) {
        var pt = gridData[k];
        var key = pt.lat + ',' + pt.lon;
        if (seen[key]) continue;
        seen[key] = true;
        gridDots.push(pt);
      }
      for (var d = 0; d < gridDots.length; d++) {
        var p = gridDots[d];
        L.circleMarker([p.lat, p.lon], {
          radius: 2,
          color: '#888',
          fillColor: '#aaa',
          fillOpacity: 0.4,
          weight: 1,
          opacity: 0.3,
          interactive: false
        }).addTo(group);
      }

      // 2. 画引导气流箭头（2D网格遍历，每隔1个纬度取一个）
      // 按经度分组，找到所有唯一的纬度
      var latMap = {};
      for (var i = 0; i < gridData.length; i++) {
        var pt = gridData[i];
        if (pt.u === undefined || pt.v === undefined) continue;
        if (!latMap[pt.lat]) latMap[pt.lat] = [];
        latMap[pt.lat].push(pt);
      }

      var lats = Object.keys(latMap).sort(function(a, b) { return b - a; }); // 降序

      for (var li = 0; li < lats.length; li += 2) { // 每隔1个纬度
        var row = latMap[lats[li]];
        row.sort(function(a, b) { return a.lon - b.lon; });
        for (var j = 0; j < row.length; j += 2) { // 每隔1个经度
          var pt = row[j];
          var u = pt.u || 0;
          var v = pt.v || 0;
          var speed = Math.sqrt(u * u + v * v);
          if (speed < 1) continue; // 风速太小时不画

          // 箭头长度和方向
          var scale = 0.12; // 每m/s风速对应0.12度地图距离
          var len = Math.min(speed * scale, 1.8); // 最大长度1.8度
          var angle = Math.atan2(u, -v); // 气象学风向：u向东为正，v向北为正

          var endLat = pt.lat + len * Math.cos(angle);
          var endLon = pt.lon + len * Math.sin(angle);

          // 箭头颜色：风速越大越红
          var r = Math.min(255, Math.round(100 + speed * 10));
          var color = 'rgb(' + r + ', 120, 60)';

          // 箭头线
          L.polyline([[pt.lat, pt.lon], [endLat, endLon]], {
            color: color,
            weight: 2,
            opacity: 0.55,
            interactive: false
          }).addTo(group);

          // 箭头头部
          var headAngle1 = angle + 2.5;
          var headAngle2 = angle - 2.5;
          var headLen = len * 0.3;
          var head1 = [endLat + headLen * Math.cos(headAngle1), endLon + headLen * Math.sin(headAngle1)];
          var head2 = [endLat + headLen * Math.cos(headAngle2), endLon + headLen * Math.sin(headAngle2)];
          L.polyline([[endLat, endLon], head1], { color: color, weight: 1.5, opacity: 0.55, interactive: false }).addTo(group);
          L.polyline([[endLat, endLon], head2], { color: color, weight: 1.5, opacity: 0.55, interactive: false }).addTo(group);
        }
      }

      steeringLayer = group.addTo(map);
    }

    // ============ 绘制洋流箭头（leaflet-velocity） ============
    function drawOceanCurrent(data) {
      if (velocityLayer) { map.removeLayer(velocityLayer); velocityLayer = null; }
      // 构建洋流数据网格
      // 使用简化的模拟数据（基于返回的海洋数据）
      if (!data || !data.marine || !data.marine.current) return;
      var curr = data.marine.current;
      // leaflet-velocity需要特定的数据格式
      // 构建一个简单的洋流网格
      var gridData = {
        header: {
          dx: 2.5, dy: 2.5,
          la1: 5, lo1: 100,
          la2: 45, lo2: 160,
          nx: 25, ny: 17
        },
        u: [],
        v: []
      };
      var dirRad = (curr.currentDirection || 270) * Math.PI / 180;
      var vel = curr.currentVelocity || 0.3;
      // 填充网格
      var nx = gridData.header.nx, ny = gridData.header.ny;
      for (var i = 0; i < nx * ny; i++) {
        gridData.u.push(-Math.sin(dirRad) * vel * 2); // 转换为m/s
        gridData.v.push(-Math.cos(dirRad) * vel * 2);
      }
      try {
        velocityLayer = L.velocityLayer({
          displayValues: true,
          displayOptions: {
            velocityType: '洋流',
            position: 'bottomleft',
            emptyString: '无数据',
            angleConvention: 'bearingCW',
            showCardinal: true,
            directionString: '流向',
            speedString: '流速',
            palette: ['#2b83ba', '#abdda4', '#fdae61', '#d7191c']
          },
          data: gridData,
          maxVelocity: 2,
          minVelocity: 0.1,
          velocityScale: 0.02,
          opacity: 0.8,
          backgroundColor: 'transparent'
        });
        velocityLayer.addTo(map);
      } catch (e) {
        console.warn('leaflet-velocity加载失败:', e.message);
      }
    }

    // ============ 页面加载完成后初始化 ============
    window.addEventListener('load', function() {
      initMap();
      // 自动获取一次海洋气象数据
      fetch('/typhoon/api/marine-weather?lat=25&lon=125')
        .then(function(r) { return r.json(); })
        .then(function(data) {
          if (data.success) {
            if (data.marine && data.marine.current) updateMarinePanel(data.marine.current);
            if (data.weather && data.weather.current) {
              updateWeatherPanel(data.weather);
            }
          }
        })
        .catch(function(err) { console.error('初始数据加载失败:', err); });
      // 加载高空风 + 海温（默认位置）
      fetchUpperWind(25, 125);
      // 加载GFS数据
      fetch('/typhoon/api/gfs')
        .then(function(r) { return r.json(); })
        .then(function(data) {
          if (data.success) {
            updateSHPanel(data);
            drawContour5880(data.contour5880);
            drawSteeringFlow(data.gridData);
          }
        })
        .catch(function(err) { console.error('GFS初始加载失败:', err); });
    });
  </script>
</body>
</html>