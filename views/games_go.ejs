<!DOCTYPE html>
<html lang="zh-CN">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <meta name="csrf-token" content="<%= csrfToken %>">
  <title>围棋 - 游戏中心</title>
  <script src="https://cdn.socket.io/4.7.5/socket.io.min.js"></script>
  <style>
    * { margin: 0; padding: 0; box-sizing: border-box; }
    body {
      background: #0b0e17;
      color: #e0e0e0;
      font-family: 'Segoe UI', 'PingFang SC', 'Microsoft YaHei', sans-serif;
      min-height: 100vh;
      overflow-x: hidden;
    }
    ::-webkit-scrollbar { width: 6px; }
    ::-webkit-scrollbar-track { background: #121926; }
    ::-webkit-scrollbar-thumb { background: #2a3a5c; border-radius: 3px; }
    ::-webkit-scrollbar-thumb:hover { background: #3a4a6c; }

    /* ========== NAVBAR ========== */
    .navbar {
      display: flex;
      align-items: center;
      justify-content: space-between;
      padding: 0 32px;
      height: 64px;
      background: rgba(11, 14, 23, 0.92);
      backdrop-filter: blur(12px);
      border-bottom: 1px solid rgba(255, 215, 0, 0.15);
      position: sticky;
      top: 0;
      z-index: 100;
    }
    .navbar .nav-left { display: flex; align-items: center; gap: 8px; }
    .navbar .nav-logo {
      font-size: 22px;
      font-weight: 700;
      background: linear-gradient(135deg, #ffd700, #f0a500);
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
      margin-right: 24px;
    }
    .navbar .nav-links { display: flex; gap: 4px; }
    .navbar .nav-links a {
      color: #8899bb;
      text-decoration: none;
      padding: 8px 16px;
      border-radius: 8px;
      font-size: 14px;
      transition: all 0.25s;
    }
    .navbar .nav-links a:hover,
    .navbar .nav-links a.active { background: rgba(255, 215, 0, 0.1); color: #ffd700; }
    .navbar .nav-user {
      display: flex;
      align-items: center;
      gap: 16px;
      font-size: 14px;
    }
    .navbar .nav-user .balance {
      background: rgba(255, 215, 0, 0.12);
      border: 1px solid rgba(255, 215, 0, 0.25);
      padding: 6px 16px;
      border-radius: 20px;
      color: #ffd700;
      font-weight: 600;
    }
    .navbar .nav-user .avatar-small {
      width: 36px;
      height: 36px;
      border-radius: 50%;
      border: 2px solid rgba(255, 215, 0, 0.3);
      object-fit: cover;
    }

    /* ========== MAIN LAYOUT ========== */
    .app-container {
      display: flex;
      max-width: 1440px;
      margin: 0 auto;
      padding: 20px 24px;
      gap: 24px;
      min-height: calc(100vh - 64px);
    }
    .game-main {
      flex: 1;
      display: flex;
      flex-direction: column;
      align-items: center;
    }
    .game-sidebar {
      width: 280px;
      flex-shrink: 0;
      display: flex;
      flex-direction: column;
      gap: 16px;
    }

    /* ========== GLASS CARD ========== */
    .glass-card {
      background: rgba(18, 25, 38, 0.85);
      backdrop-filter: blur(16px);
      border: 1px solid rgba(255, 255, 255, 0.06);
      border-radius: 16px;
      padding: 20px;
    }

    /* ========== BOARD ========== */
    .board-container {
      position: relative;
      background: rgba(18, 25, 38, 0.85);
      backdrop-filter: blur(16px);
      border: 1px solid rgba(255, 255, 255, 0.06);
      border-radius: 16px;
      padding: 24px;
      box-shadow: 0 8px 40px rgba(0, 0, 0, 0.4);
    }
    .board-wrapper {
      position: relative;
      display: inline-block;
    }
    #gameCanvas {
      display: block;
      cursor: pointer;
      border-radius: 8px;
      background: #d4a45a;
      box-shadow: inset 0 0 30px rgba(0, 0, 0, 0.3);
    }
    .board-info {
      display: flex;
      justify-content: space-between;
      align-items: center;
      margin-top: 12px;
      font-size: 13px;
      color: #8899bb;
    }
    .board-info .last-move-label { color: #ffd700; }

    /* ========== PLAYER INFO PANELS ========== */
    .player-panel {
      display: flex;
      align-items: center;
      gap: 14px;
      padding: 14px 18px;
      background: rgba(18, 25, 38, 0.85);
      backdrop-filter: blur(16px);
      border: 1px solid rgba(255, 255, 255, 0.06);
      border-radius: 14px;
      transition: all 0.3s;
    }
    .player-panel.active-turn {
      border-color: rgba(255, 215, 0, 0.4);
      box-shadow: 0 0 20px rgba(255, 215, 0, 0.08);
    }
    .player-panel .avatar {
      width: 48px;
      height: 48px;
      border-radius: 50%;
      border: 2px solid rgba(255, 255, 255, 0.1);
      object-fit: cover;
      flex-shrink: 0;
    }
    .player-panel .avatar.black-side { border-color: #333; }
    .player-panel .avatar.white-side { border-color: #ccc; }
    .player-panel .player-info { flex: 1; min-width: 0; }
    .player-panel .player-info .name {
      font-size: 15px;
      font-weight: 600;
      white-space: nowrap;
      overflow: hidden;
      text-overflow: ellipsis;
    }
    .player-panel .player-info .captures {
      font-size: 12px;
      color: #8899bb;
      margin-top: 2px;
    }
    .player-panel .player-info .captures strong { color: #ffd700; }
    .player-panel .stone-indicator {
      width: 20px;
      height: 20px;
      border-radius: 50%;
      flex-shrink: 0;
    }
    .stone-indicator.black { background: radial-gradient(circle at 35% 35%, #555, #111); box-shadow: 1px 1px 3px rgba(0,0,0,0.4); }
    .stone-indicator.white { background: radial-gradient(circle at 35% 35%, #fff, #ccc); box-shadow: 1px 1px 3px rgba(0,0,0,0.2); }

    /* ========== SIDEBAR ========== */
    .sidebar-section h3 {
      font-size: 14px;
      font-weight: 600;
      color: #8899bb;
      margin-bottom: 12px;
      display: flex;
      align-items: center;
      gap: 8px;
    }
    .sidebar-section h3 .badge {
      font-size: 11px;
      padding: 2px 8px;
      border-radius: 8px;
      background: rgba(255,215,0,0.1);
      color: #ffd700;
    }

    .status-display {
      text-align: center;
    }
    .status-display .turn-label {
      font-size: 18px;
      font-weight: 700;
      margin-bottom: 4px;
    }
    .status-display .turn-label.black-turn { color: #e0e0e0; }
    .status-display .turn-label.white-turn { color: #ffd700; }
    .status-display .move-count {
      font-size: 13px;
      color: #556688;
    }

    /* Difficulty selector in sidebar */
    .diff-selector {
      display: flex;
      flex-direction: column;
      gap: 8px;
    }
    .diff-selector .diff-label {
      font-size: 12px;
      color: #556688;
      text-transform: uppercase;
      letter-spacing: 1px;
    }
    .diff-selector .diff-options {
      display: flex;
      gap: 6px;
    }
    .diff-selector .diff-options .diff-btn {
      flex: 1;
      padding: 8px 6px;
      border: 1px solid rgba(255,255,255,0.08);
      border-radius: 8px;
      background: rgba(255,255,255,0.03);
      color: #8899bb;
      cursor: pointer;
      text-align: center;
      font-size: 12px;
      transition: all 0.25s;
    }
    .diff-selector .diff-options .diff-btn:hover { border-color: rgba(255,215,0,0.3); color: #c8d6e5; }
    .diff-selector .diff-options .diff-btn.active {
      background: rgba(255,215,0,0.1);
      border-color: #ffd700;
      color: #ffd700;
    }

    /* Game Actions */
    .game-actions {
      display: flex;
      flex-wrap: wrap;
      gap: 8px;
    }
    .game-actions .btn {
      flex: 1;
      min-width: 60px;
      padding: 10px 12px;
      border: 1px solid rgba(255,255,255,0.08);
      border-radius: 8px;
      background: rgba(255,255,255,0.03);
      color: #c8d6e5;
      cursor: pointer;
      font-size: 13px;
      transition: all 0.25s;
      text-align: center;
    }
    .game-actions .btn:hover { background: rgba(255,255,255,0.08); border-color: rgba(255,255,255,0.15); }
    .game-actions .btn.primary-action {
      background: rgba(255,215,0,0.1);
      border-color: rgba(255,215,0,0.2);
      color: #ffd700;
    }
    .game-actions .btn.primary-action:hover { background: rgba(255,215,0,0.2); }
    .game-actions .btn:disabled { opacity: 0.4; cursor: not-allowed; transform: none !important; }

    /* Move History */
    .move-history {
      max-height: 200px;
      overflow-y: auto;
    }
    .move-history .move-row {
      display: flex;
      padding: 3px 6px;
      border-radius: 4px;
      font-size: 12px;
      font-family: 'Courier New', monospace;
      transition: background 0.15s;
    }
    .move-history .move-row:hover { background: rgba(255,255,255,0.04); }
    .move-history .move-row .move-num {
      width: 28px;
      color: #556688;
    }
    .move-history .move-row .move-pos {
      width: 40px;
      color: #c8d6e5;
    }
    .move-history .move-row .move-info {
      flex: 1;
      text-align: right;
      color: #556688;
      font-size: 11px;
    }
    .move-history .move-row:nth-child(odd) { background: rgba(255,255,255,0.02); }

    /* ========== AI THINKING ========== */
    .ai-thinking {
      position: fixed;
      top: 50%;
      left: 50%;
      transform: translate(-50%, -50%);
      z-index: 150;
      background: rgba(11,14,23,0.92);
      backdrop-filter: blur(8px);
      border: 1px solid rgba(255,215,0,0.3);
      border-radius: 16px;
      padding: 24px 36px;
      text-align: center;
      display: none;
    }
    .ai-thinking.show { display: block; }
    .ai-thinking .ai-spinner {
      width: 36px;
      height: 36px;
      margin: 0 auto 12px;
      border: 3px solid rgba(255,215,0,0.1);
      border-top: 3px solid #ffd700;
      border-radius: 50%;
      animation: spin 0.8s linear infinite;
    }
    @keyframes spin { to { transform: rotate(360deg); } }
    .ai-thinking .ai-text {
      font-size: 16px;
      color: #ffd700;
      letter-spacing: 2px;
    }

    /* ========== GAME OVER MODAL ========== */
    .gameover-modal {
      display: none;
      position: fixed;
      top: 0; left: 0; right: 0; bottom: 0;
      background: rgba(0,0,0,0.75);
      backdrop-filter: blur(12px);
      z-index: 300;
      justify-content: center;
      align-items: center;
    }
    .gameover-modal.show { display: flex; }
    .gameover-modal .modal-card {
      background: rgba(18,25,38,0.95);
      border: 1px solid rgba(255,215,0,0.2);
      border-radius: 20px;
      padding: 36px 40px;
      max-width: 440px;
      width: 90%;
      text-align: center;
      animation: modalIn 0.4s ease-out;
    }
    @keyframes modalIn {
      from { opacity: 0; transform: scale(0.9) translateY(20px); }
      to { opacity: 1; transform: scale(1) translateY(0); }
    }
    .gameover-modal .result-icon { font-size: 56px; margin-bottom: 8px; }
    .gameover-modal .result-title {
      font-size: 26px;
      font-weight: 700;
      margin-bottom: 4px;
    }
    .gameover-modal .result-sub {
      font-size: 14px;
      color: #8899bb;
      margin-bottom: 20px;
    }
    .gameover-modal .stats-grid {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 12px;
      margin-bottom: 24px;
    }
    .gameover-modal .stat-item {
      background: rgba(255,255,255,0.03);
      border-radius: 10px;
      padding: 12px;
    }
    .gameover-modal .stat-item .label {
      font-size: 11px;
      color: #556688;
      text-transform: uppercase;
    }
    .gameover-modal .stat-item .value {
      font-size: 18px;
      font-weight: 700;
      margin-top: 4px;
    }
    .gameover-modal .stat-item .value.positive { color: #4ecdc4; }
    .gameover-modal .modal-actions {
      display: flex;
      gap: 10px;
      flex-wrap: wrap;
    }
    .gameover-modal .modal-actions .btn {
      flex: 1;
      min-width: 100px;
      padding: 12px 20px;
      border: none;
      border-radius: 10px;
      font-size: 14px;
      font-weight: 600;
      cursor: pointer;
      transition: all 0.25s;
    }

    /* ========== TOAST ========== */
    .toast {
      position: fixed;
      bottom: 30px;
      left: 50%;
      transform: translateX(-50%);
      padding: 12px 24px;
      border-radius: 10px;
      background: rgba(11,14,23,0.92);
      border: 1px solid rgba(255,215,0,0.2);
      color: #e0e0e0;
      font-size: 14px;
      z-index: 500;
      opacity: 0;
      transition: opacity 0.3s, transform 0.3s;
      pointer-events: none;
    }
    .toast.show { opacity: 1; transform: translateX(-50%) translateY(0); }

    /* ========== RESPONSIVE ========== */
    @media (max-width: 1100px) {
      .app-container { flex-direction: column; align-items: center; }
      .game-sidebar { width: 100%; max-width: 600px; flex-direction: row; flex-wrap: wrap; }
      .game-sidebar .glass-card { flex: 1; min-width: 200px; }
    }
    @media (max-width: 600px) {
      .navbar { padding: 0 16px; }
      .navbar .nav-links a { padding: 6px 10px; font-size: 12px; }
      .board-container { padding: 12px; }
      .player-panel { padding: 10px 12px; }
    }

    /* ========== MATCH LOBBY ========== */
    .match-lobby-bar {
      display: flex;
      align-items: center;
      gap: 10px;
      width: 100%;
      max-width: 660px;
      margin-bottom: 16px;
      flex-wrap: wrap;
    }
    .match-lobby-bar .mode-btn {
      padding: 8px 18px;
      border: 1px solid rgba(255,255,255,0.08);
      border-radius: 10px;
      background: rgba(255,255,255,0.03);
      color: #8899bb;
      cursor: pointer;
      font-size: 13px;
      transition: all 0.25s;
      white-space: nowrap;
    }
    .match-lobby-bar .mode-btn:hover {
      border-color: rgba(255,215,0,0.3);
      color: #c8d6e5;
    }
    .match-lobby-bar .mode-btn.active {
      background: rgba(255,215,0,0.1);
      border-color: #ffd700;
      color: #ffd700;
    }
    .match-lobby-bar .mode-btn.online-indicator {
      display: flex;
      align-items: center;
      gap: 6px;
    }
    .match-lobby-bar .mode-btn .dot {
      width: 8px;
      height: 8px;
      border-radius: 50%;
      display: inline-block;
    }
    .match-lobby-bar .mode-btn .dot.online { background: #4ecdc4; }
    .match-lobby-bar .mode-btn .dot.offline { background: #556688; }
    .match-lobby-bar .lobby-status {
      font-size: 12px;
      color: #556688;
      margin-left: auto;
    }

    /* ========== MATCH MODAL ========== */
    .match-modal {
      display: none;
      position: fixed;
      top: 0; left: 0; right: 0; bottom: 0;
      background: rgba(0,0,0,0.7);
      backdrop-filter: blur(12px);
      z-index: 400;
      justify-content: center;
      align-items: center;
    }
    .match-modal.show { display: flex; }
    .match-modal .modal-card {
      background: rgba(18,25,38,0.95);
      border: 1px solid rgba(255,215,0,0.2);
      border-radius: 20px;
      padding: 32px 36px;
      max-width: 480px;
      width: 90%;
      animation: modalIn 0.4s ease-out;
    }
    .match-modal .modal-title {
      font-size: 20px;
      font-weight: 700;
      text-align: center;
      margin-bottom: 20px;
      color: #e0e0e0;
    }
    .match-modal .match-options {
      display: flex;
      flex-direction: column;
      gap: 12px;
      margin-bottom: 20px;
    }
    .match-modal .match-options .option-row {
      display: flex;
      align-items: center;
      gap: 12px;
    }
    .match-modal .match-options .option-row label {
      font-size: 14px;
      color: #8899bb;
      min-width: 80px;
    }
    .match-modal .match-options .option-row select,
    .match-modal .match-options .option-row input {
      flex: 1;
      padding: 10px 14px;
      border: 1px solid rgba(255,255,255,0.1);
      border-radius: 8px;
      background: rgba(255,255,255,0.05);
      color: #e0e0e0;
      font-size: 14px;
      outline: none;
    }
    .match-modal .match-options .option-row select option {
      background: #1a2332;
      color: #e0e0e0;
    }
    .match-modal .match-options .option-row input::placeholder {
      color: #556688;
    }
    .match-modal .modal-actions {
      display: flex;
      gap: 10px;
    }
    .match-modal .modal-actions .btn {
      flex: 1;
      padding: 12px 20px;
      border: none;
      border-radius: 10px;
      font-size: 14px;
      font-weight: 600;
      cursor: pointer;
      transition: all 0.25s;
      text-align: center;
    }
    .match-modal .modal-actions .btn.btn-primary {
      background: linear-gradient(135deg, #ffd700, #f0a500);
      color: #1a1a2e;
    }
    .match-modal .modal-actions .btn.btn-primary:hover { transform: translateY(-1px); box-shadow: 0 4px 15px rgba(255,215,0,0.3); }
    .match-modal .modal-actions .btn.btn-secondary {
      background: rgba(255,255,255,0.06);
      color: #c8d6e5;
      border: 1px solid rgba(255,255,255,0.1);
    }
    .match-modal .modal-actions .btn.btn-secondary:hover { background: rgba(255,255,255,0.1); }
    .match-modal .modal-actions .btn.btn-danger {
      background: rgba(255,50,50,0.15);
      color: #ff6b6b;
      border: 1px solid rgba(255,50,50,0.2);
    }
    .match-modal .modal-actions .btn.btn-danger:hover { background: rgba(255,50,50,0.25); }
    .match-modal .modal-actions .btn:disabled { opacity: 0.4; cursor: not-allowed; transform: none !important; }

    /* ========== MATCH WAITING ========== */
    .match-waiting {
      text-align: center;
      padding: 20px 0;
    }
    .match-waiting .waiting-spinner {
      display: flex;
      justify-content: center;
      gap: 8px;
      margin-bottom: 16px;
    }
    .match-waiting .waiting-spinner .dot-pulse {
      width: 12px;
      height: 12px;
      border-radius: 50%;
      background: #ffd700;
      animation: pulse 1.4s ease-in-out infinite;
    }
    .match-waiting .waiting-spinner .dot-pulse:nth-child(2) { animation-delay: 0.2s; }
    .match-waiting .waiting-spinner .dot-pulse:nth-child(3) { animation-delay: 0.4s; }
    @keyframes pulse {
      0%, 80%, 100% { transform: scale(0.5); opacity: 0.3; }
      40% { transform: scale(1); opacity: 1; }
    }
    .match-waiting .waiting-text {
      font-size: 16px;
      color: #ffd700;
      margin-bottom: 8px;
    }
    .match-waiting .waiting-sub {
      font-size: 13px;
      color: #556688;
    }

    /* ========== TIER BADGE ========== */
    .tier-badge {
      display: inline-flex;
      align-items: center;
      gap: 6px;
      padding: 4px 12px;
      border-radius: 20px;
      font-size: 12px;
      font-weight: 600;
      letter-spacing: 0.5px;
    }
    .tier-badge .tier-dot {
      width: 8px;
      height: 8px;
      border-radius: 50%;
      flex-shrink: 0;
    }

    /* ========== RATING INFO ========== */
    .rating-info {
      display: flex;
      flex-direction: column;
      gap: 8px;
    }
    .rating-info .rating-row {
      display: flex;
      justify-content: space-between;
      align-items: center;
      font-size: 13px;
    }
    .rating-info .rating-row .label {
      color: #556688;
    }
    .rating-info .rating-row .value {
      color: #c8d6e5;
      font-weight: 600;
    }
    .rating-info .rating-row .value.positive { color: #4ecdc4; }
    .rating-info .rating-row .value.negative { color: #ff6b6b; }
    .rating-info .rating-divider {
      height: 1px;
      background: rgba(255,255,255,0.06);
      margin: 4px 0;
    }

    /* ========== ONLINE PLAYER INFO ========== */
    .opponent-info {
      display: none;
      align-items: center;
      gap: 10px;
      padding: 8px 12px;
      background: rgba(255,215,0,0.05);
      border: 1px solid rgba(255,215,0,0.15);
      border-radius: 10px;
      margin-top: 8px;
      font-size: 13px;
    }
    .opponent-info.show { display: flex; }
    .opponent-info .opponent-avatar {
      width: 32px;
      height: 32px;
      border-radius: 50%;
      border: 2px solid rgba(255,215,0,0.3);
      object-fit: cover;
    }
    .opponent-info .opponent-details {
      flex: 1;
      min-width: 0;
    }
    .opponent-info .opponent-details .opponent-name {
      font-weight: 600;
      color: #e0e0e0;
      white-space: nowrap;
      overflow: hidden;
      text-overflow: ellipsis;
    }
    .opponent-info .opponent-details .opponent-tier {
      font-size: 11px;
      color: #8899bb;
    }

    /* ========== ROOM INFO BAR ========== */
    .room-info-bar {
      display: none;
      align-items: center;
      gap: 10px;
      width: 100%;
      max-width: 660px;
      margin-bottom: 16px;
      padding: 10px 16px;
      background: rgba(78, 205, 196, 0.08);
      border: 1px solid rgba(78, 205, 196, 0.2);
      border-radius: 10px;
      font-size: 13px;
    }
    .room-info-bar.show { display: flex; }
    .room-info-bar .room-id-label {
      color: #4ecdc4;
      font-weight: 600;
    }
    .room-info-bar .room-id-value {
      color: #e0e0e0;
      font-family: 'Courier New', monospace;
    }
    .room-info-bar .room-status {
      margin-left: auto;
      color: #8899bb;
    }
  </style>
</head>
