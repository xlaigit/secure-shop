  <!-- ========== JOIN ROOM MODAL ========== -->
  <div class="match-modal" id="joinRoomModal">
    <div class="modal-card">
      <div class="modal-title">🚪 加入房间</div>
      <div class="match-options">
        <div class="option-row">
          <label>房间号</label>
          <input type="text" id="joinRoomIdInput" placeholder="输入房间号" maxlength="50">
        </div>
        <div class="option-row">
          <label>密码</label>
          <input type="text" id="joinRoomPasswordInput" placeholder="留空如果无密码" maxlength="10">
        </div>
      </div>
      <div class="modal-actions">
        <button class="btn btn-primary" onclick="joinRoom()">加入房间</button>
        <button class="btn btn-secondary" onclick="closeModal('joinRoomModal')">取消</button>
      </div>
    </div>
  </div>

  <!-- ========== TOAST ========== -->
  <div class="toast" id="toast"></div>

  <script>
    // ========================================================================
    //  围棋 (Go) — 完整游戏引擎 + AI + Canvas 渲染
    // ========================================================================
    'use strict';

    // ---- Constants ----
    const BOARD_SIZE = 19;
    const CELL_SIZE = 34;
    const PADDING = 28;
    const BOARD_PX = CELL_SIZE * (BOARD_SIZE - 1);
    const TOTAL_SIZE = BOARD_PX + PADDING * 2;
    const STONE_RADIUS = CELL_SIZE * 0.43;
    const KOMI = 6.5;

    // ---- DOM refs ----
    const canvas = document.getElementById('gameCanvas');
    const ctx = canvas.getContext('2d');
    canvas.width = TOTAL_SIZE;
    canvas.height = TOTAL_SIZE;

    // ---- Game State ----
    const go = {
      board: [],        // 0=empty, 1=black, 2=white
      currentPlayer: 1, // 1=black, 2=white
      moveCount: 0,
      lastMove: null,   // { row, col }
      captures: { 1: 0, 2: 0 }, // black captures, white captures
      koPoint: null,    // { row, col } or null
      passCount: 0,     // consecutive passes
      gameOver: false,
      isAIThinking: false,
      moveHistory: [],  // array of { row, col, player, captures }
      boardHistory: [], // array of board snapshots for undo
      difficulty: 'easy',
      locked: false,    // lock board during AI turn
      mode: 'ai',       // 'ai' or 'online'
    };

    // ---- Helper functions ----
    const COL_LABELS = 'ABCDEFGHJKLMNOPQRSTUVWXYZ';

    function coordToLabel(row, col) {
      return COL_LABELS[col] + (BOARD_SIZE - row);
    }

    function showToast(msg, duration) {
      var t = document.getElementById('toast');
      t.textContent = msg;
      t.classList.add('show');
      clearTimeout(t._hide);
      t._hide = setTimeout(function() { t.classList.remove('show'); }, duration || 2000);
    }

    // ========================================================================
    //  BOARD INIT
    // ========================================================================
    function createEmptyBoard() {
      var b = [];
      for (var r = 0; r < BOARD_SIZE; r++) {
        b[r] = [];
        for (var c = 0; c < BOARD_SIZE; c++) {
          b[r][c] = 0;
        }
      }
      return b;
    }

    function cloneBoard(b) {
      return b.map(function(row) { return row.slice(); });
    }

    // ========================================================================
    //  GO RULES ENGINE
    // ========================================================================

    // Get neighbors of a position
    function getNeighbors(row, col) {
      var n = [];
      if (row > 0) n.push({ row: row - 1, col: col });
      if (row < BOARD_SIZE - 1) n.push({ row: row + 1, col: col });
      if (col > 0) n.push({ row: row, col: col - 1 });
      if (col < BOARD_SIZE - 1) n.push({ row: row, col: col + 1 });
      return n;
    }

    // Get the group (connected stones of same color) at a position
    function getGroup(board, row, col) {
      var color = board[row][col];
      if (color === 0) return null;
      var visited = {};
      var group = [];
      var queue = [{ row: row, col: col }];
      visited[row + ',' + col] = true;
      while (queue.length > 0) {
        var p = queue.shift();
        group.push(p);
        var neighbors = getNeighbors(p.row, p.col);
        for (var i = 0; i < neighbors.length; i++) {
          var n = neighbors[i];
          var key = n.row + ',' + n.col;
          if (!visited[key] && board[n.row][n.col] === color) {
            visited[key] = true;
            queue.push(n);
          }
        }
      }
      return group;
    }

    // Get liberties (empty adjacent intersections) of a group
    function getLiberties(board, group) {
      var liberties = {};
      for (var i = 0; i < group.length; i++) {
        var p = group[i];
        var neighbors = getNeighbors(p.row, p.col);
        for (var j = 0; j < neighbors.length; j++) {
          var n = neighbors[j];
          if (board[n.row][n.col] === 0) {
            liberties[n.row + ',' + n.col] = true;
          }
        }
      }
      return Object.keys(liberties).length;
    }

    // Check if a move is legal (without actually making it)
    function isLegalMove(board, row, col, player, koPoint) {
      // Check bounds
      if (row < 0 || row >= BOARD_SIZE || col < 0 || col >= BOARD_SIZE) return false;
      // Check empty
      if (board[row][col] !== 0) return false;
      // Check ko
      if (koPoint && koPoint.row === row && koPoint.col === col) return false;

      // Simulate the move
      var simBoard = cloneBoard(board);
      simBoard[row][col] = player;

      var opponent = player === 1 ? 2 : 1;
      var captured = false;

      // Check captures of opponent groups
      var neighbors = getNeighbors(row, col);
      for (var i = 0; i < neighbors.length; i++) {
        var n = neighbors[i];
        if (simBoard[n.row][n.col] === opponent) {
          var group = getGroup(simBoard, n.row, n.col);
          if (group && getLiberties(simBoard, group) === 0) {
            captured = true;
            // Remove captured stones
            for (var j = 0; j < group.length; j++) {
              simBoard[group[j].row][group[j].col] = 0;
            }
          }
        }
      }

      // Check suicide: if no captures were made, check if own group has liberties
      if (!captured) {
        var ownGroup = getGroup(simBoard, row, col);
        if (ownGroup && getLiberties(simBoard, ownGroup) === 0) {
          return false; // suicide
        }
      }

      return true;
    }

    // Make a move on the board. Returns { success, captures, koPoint }
    function makeMove(board, row, col, player) {
      if (board[row][col] !== 0) return { success: false };

      board[row][col] = player;
      var opponent = player === 1 ? 2 : 1;
      var totalCaptured = 0;
      var newKo = null;

      // Check captures
      var neighbors = getNeighbors(row, col);
      for (var i = 0; i < neighbors.length; i++) {
        var n = neighbors[i];
        if (board[n.row][n.col] === opponent) {
          var group = getGroup(board, n.row, n.col);
          if (group && getLiberties(board, group) === 0) {
            // Capture
            for (var j = 0; j < group.length; j++) {
              board[group[j].row][group[j].col] = 0;
            }
            totalCaptured += group.length;
          }
        }
      }

      // Check for ko: if exactly one stone was captured and the move was a single stone
      if (totalCaptured === 1) {
        // Check if the placed stone has exactly one liberty (the captured point)
        var ownGroup = getGroup(board, row, col);
        if (ownGroup && ownGroup.length === 1) {
          var libs = {};
          var ownNeighbors = getNeighbors(row, col);
          for (var k = 0; k < ownNeighbors.length; k++) {
            if (board[ownNeighbors[k].row][ownNeighbors[k].col] === 0) {
              libs[ownNeighbors[k].row + ',' + ownNeighbors[k].col] = true;
            }
          }
          var libKeys = Object.keys(libs);
          if (libKeys.length === 1) {
            var parts = libKeys[0].split(',');
            newKo = { row: parseInt(parts[0]), col: parseInt(parts[1]) };
          }
        }
      }

      return { success: true, captured: totalCaptured, koPoint: newKo };
    }

    // ========================================================================
    //  TERRITORY COUNTING (Chinese counting)
    // ========================================================================
    function countTerritory(board) {
      var visited = {};
      var blackTerritory = 0;
      var whiteTerritory = 0;
      var blackStones = 0;
      var whiteStones = 0;

      // Count stones
      for (var r = 0; r < BOARD_SIZE; r++) {
        for (var c = 0; c < BOARD_SIZE; c++) {
          if (board[r][c] === 1) blackStones++;
          else if (board[r][c] === 2) whiteStones++;
        }
      }

      // Flood fill empty regions
      for (var r = 0; r < BOARD_SIZE; r++) {
        for (var c = 0; c < BOARD_SIZE; c++) {
          if (board[r][c] === 0 && !visited[r + ',' + c]) {
            // BFS to find the empty region
            var region = [];
            var borders = { 1: false, 2: false };
            var queue = [{ row: r, col: c }];
            visited[r + ',' + c] = true;

            while (queue.length > 0) {
              var p = queue.shift();
              region.push(p);
              var neighbors = getNeighbors(p.row, p.col);
              for (var i = 0; i < neighbors.length; i++) {
                var n = neighbors[i];
                var key = n.row + ',' + n.col;
                if (board[n.row][n.col] === 0 && !visited[key]) {
                  visited[key] = true;
                  queue.push(n);
                } else if (board[n.row][n.col] === 1) {
                  borders[1] = true;
                } else if (board[n.row][n.col] === 2) {
                  borders[2] = true;
                }
              }
            }

            // If only one color borders the region, it's territory
            if (borders[1] && !borders[2]) {
              blackTerritory += region.length;
            } else if (borders[2] && !borders[1]) {
              whiteTerritory += region.length;
            }
          }
        }
      }

      var blackScore = blackStones + blackTerritory;
      var whiteScore = whiteStones + whiteTerritory + KOMI;

      return {
        blackStones: blackStones,
        whiteStones: whiteStones,
        blackTerritory: blackTerritory,
        whiteTerritory: whiteTerritory,
        blackScore: blackScore,
        whiteScore: whiteScore,
        winner: blackScore > whiteScore ? 1 : (whiteScore > blackScore ? 2 : 0),
        diff: Math.abs(blackScore - whiteScore)
      };
    }

    // ========================================================================
    //  CANVAS RENDERING
    // ========================================================================

    function boardToPixel(row, col) {
      return {
        x: PADDING + col * CELL_SIZE,
        y: PADDING + row * CELL_SIZE
      };
    }

    function pixelToBoard(px, py) {
      var col = Math.round((px - PADDING) / CELL_SIZE);
      var row = Math.round((py - PADDING) / CELL_SIZE);
      if (row < 0 || row >= BOARD_SIZE || col < 0 || col >= BOARD_SIZE) return null;
      // Check if click is close enough to an intersection
      var p = boardToPixel(row, col);
      var dist = Math.sqrt((px - p.x) * (px - p.x) + (py - p.y) * (py - p.y));
      if (dist > CELL_SIZE * 0.5) return null;
      return { row: row, col: col };
    }

    // Animation state
    var animStones = []; // { row, col, player, alpha, scale, type: 'place'|'remove' }

    function addPlaceAnimation(row, col, player) {
      animStones.push({ row: row, col: col, player: player, alpha: 0, scale: 0.3, type: 'place' });
    }

    function addRemoveAnimation(row, col, player) {
      animStones.push({ row: row, col: col, player: player, alpha: 1, scale: 1, type: 'remove' });
    }

    var hoverPos = null; // { row, col }

    function drawBoard() {
      ctx.clearRect(0, 0, TOTAL_SIZE, TOTAL_SIZE);

      // Board background
      var grad = ctx.createRadialGradient(TOTAL_SIZE/2, TOTAL_SIZE/2, 0, TOTAL_SIZE/2, TOTAL_SIZE/2, TOTAL_SIZE/1.5);
      grad.addColorStop(0, '#d4a45a');
      grad.addColorStop(0.7, '#c8944a');
      grad.addColorStop(1, '#b8843a');
      ctx.fillStyle = grad;
      ctx.fillRect(0, 0, TOTAL_SIZE, TOTAL_SIZE);

      // Grid lines
      ctx.strokeStyle = 'rgba(0,0,0,0.5)';
      ctx.lineWidth = 1;
      for (var i = 0; i < BOARD_SIZE; i++) {
        // Horizontal
        ctx.beginPath();
        ctx.moveTo(PADDING, PADDING + i * CELL_SIZE);
        ctx.lineTo(PADDING + BOARD_PX, PADDING + i * CELL_SIZE);
        ctx.stroke();
        // Vertical
        ctx.beginPath();
        ctx.moveTo(PADDING + i * CELL_SIZE, PADDING);
        ctx.lineTo(PADDING + i * CELL_SIZE, PADDING + BOARD_PX);
        ctx.stroke();
      }

      // Star points (hoshi)
      var starPoints = [3, 9, 15];
      ctx.fillStyle = '#000';
      for (var si = 0; si < starPoints.length; si++) {
        for (var sj = 0; sj < starPoints.length; sj++) {
          var sp = boardToPixel(starPoints[si], starPoints[sj]);
          ctx.beginPath();
          ctx.arc(sp.x, sp.y, 4, 0, Math.PI * 2);
          ctx.fill();
        }
      }

      // Coordinate labels
      ctx.fillStyle = 'rgba(0,0,0,0.4)';
      ctx.font = '11px sans-serif';
      ctx.textAlign = 'center';
      ctx.textBaseline = 'top';
      for (var c = 0; c < BOARD_SIZE; c++) {
        var p = boardToPixel(0, c);
        ctx.fillText(COL_LABELS[c], p.x, PADDING - 18);
      }
      ctx.textAlign = 'right';
      ctx.textBaseline = 'middle';
      for (var r = 0; r < BOARD_SIZE; r++) {
        var p = boardToPixel(r, 0);
        ctx.fillText(BOARD_SIZE - r, PADDING - 10, p.y);
      }

      // Draw stones
      for (var r = 0; r < BOARD_SIZE; r++) {
        for (var c = 0; c < BOARD_SIZE; c++) {
          if (go.board[r][c] !== 0) {
            drawStone(r, c, go.board[r][c], 1, 1);
          }
        }
      }

      // Draw animated stones
      for (var ai = 0; ai < animStones.length; ai++) {
        var a = animStones[ai];
        if (a.type === 'place') {
          drawStone(a.row, a.col, a.player, a.alpha, a.scale);
        } else {
          // Remove animation: fade out
          drawStone(a.row, a.col, a.player, a.alpha, a.scale);
        }
      }

      // Hover preview
      if (hoverPos && !go.locked && !go.gameOver && go.board[hoverPos.row][hoverPos.col] === 0) {
        var isLegal = isLegalMove(go.board, hoverPos.row, hoverPos.col, go.currentPlayer, go.koPoint);
        if (isLegal) {
          drawStone(hoverPos.row, hoverPos.col, go.currentPlayer, 0.4, 0.85);
        }
      }

      // Last move marker
      if (go.lastMove) {
        var lp = boardToPixel(go.lastMove.row, go.lastMove.col);
        var lc = go.board[go.lastMove.row][go.lastMove.col];
        ctx.fillStyle = lc === 1 ? '#fff' : '#000';
        ctx.beginPath();
        ctx.arc(lp.x, lp.y, 4, 0, Math.PI * 2);
        ctx.fill();
      }
    }

    function drawStone(row, col, player, alpha, scale) {
      var p = boardToPixel(row, col);
      var r = STONE_RADIUS * scale;

      ctx.save();
      ctx.globalAlpha = Math.min(1, Math.max(0, alpha));

      // Shadow
      ctx.beginPath();
      ctx.arc(p.x + 1.5, p.y + 1.5, r, 0, Math.PI * 2);
      ctx.fillStyle = 'rgba(0,0,0,0.15)';
      ctx.fill();

      // Stone
      var grad = ctx.createRadialGradient(p.x - r * 0.3, p.y - r * 0.3, r * 0.1, p.x, p.y, r);
      if (player === 1) {
        grad.addColorStop(0, '#444');
        grad.addColorStop(0.5, '#222');
        grad.addColorStop(1, '#000');
      } else {
        grad.addColorStop(0, '#ffffff');
        grad.addColorStop(0.5, '#f0f0f0');
        grad.addColorStop(1, '#cccccc');
      }
      ctx.beginPath();
      ctx.arc(p.x, p.y, r, 0, Math.PI * 2);
      ctx.fillStyle = grad;
      ctx.fill();

      // Border
      ctx.strokeStyle = player === 1 ? 'rgba(0,0,0,0.3)' : 'rgba(0,0,0,0.1)';
      ctx.lineWidth = 0.5;
      ctx.stroke();

      // Highlight
      ctx.beginPath();
      ctx.arc(p.x - r * 0.25, p.y - r * 0.25, r * 0.3, 0, Math.PI * 2);
      ctx.fillStyle = player === 1 ? 'rgba(255,255,255,0.1)' : 'rgba(255,255,255,0.3)';
      ctx.fill();

      ctx.restore();
    }

    // ========================================================================
    //  ANIMATION LOOP
    // ========================================================================
    var animRunning = false;

    function updateAnimations() {
      var alive = [];
      var changed = false;
      for (var i = 0; i < animStones.length; i++) {
        var a = animStones[i];
        if (a.type === 'place') {
          a.alpha = Math.min(1, a.alpha + 0.08);
          a.scale = Math.min(1, a.scale + 0.07);
          if (a.alpha >= 1 && a.scale >= 1) {
            // Done
          } else {
            alive.push(a);
            changed = true;
          }
        } else {
          // remove
          a.alpha -= 0.06;
          a.scale -= 0.03;
          if (a.alpha <= 0 || a.scale <= 0.1) {
            // Done fading
          } else {
            alive.push(a);
            changed = true;
          }
        }
      }
      animStones = alive;
      if (changed) {
        drawBoard();
        return true;
      }
      return false;
    }

    function animLoop() {
      if (updateAnimations()) {
        requestAnimationFrame(animLoop);
      } else {
        animRunning = false;
        // If there are captured stones to actually remove from board, do it now
        // (captures are already removed from board data in makeMove, animation is visual only)
      }
    }

    function startAnimLoop() {
      if (!animRunning) {
        animRunning = true;
        requestAnimationFrame(animLoop);
      }
    }

    // ========================================================================
    //  UI UPDATE
    // ========================================================================
    function updateUI() {
      var turnStr = go.currentPlayer === 1 ? '⚫ 黑棋落子' : '⚪ 白棋落子';
      document.getElementById('turnIndicator').textContent = go.gameOver ? '🏁 对局结束' : turnStr;
      document.getElementById('statusTurnLabel').textContent = go.gameOver ? '🏁 对局结束' : turnStr;
      document.getElementById('moveCount').textContent = go.moveCount;
      document.getElementById('blackCaptures').textContent = go.captures[1];
      document.getElementById('whiteCaptures').textContent = go.captures[2];

      // Active turn highlighting
      document.getElementById('playerBlackPanel').classList.toggle('active-turn', go.currentPlayer === 1 && !go.gameOver);
      document.getElementById('playerWhitePanel').classList.toggle('active-turn', go.currentPlayer === 2 && !go.gameOver);

      // Last move label
      if (go.lastMove) {
        document.getElementById('lastMoveLabel').textContent = '最后落子: ' + coordToLabel(go.lastMove.row, go.lastMove.col);
      } else {
        document.getElementById('lastMoveLabel').textContent = '';
      }

      // Undo button
      document.getElementById('btnUndo').disabled = go.moveCount === 0 || go.gameOver || go.locked || go.isAIThinking;

      // History count
      document.getElementById('historyCount').textContent = go.moveCount;
    }

    function updateMoveHistory() {
      var el = document.getElementById('moveHistory');
      el.innerHTML = '';
      for (var i = 0; i < go.moveHistory.length; i++) {
        var m = go.moveHistory[i];
        var div = document.createElement('div');
        div.className = 'move-row';
        var isBlack = m.player === 1;
        var label = m.pass ? 'Pass' : coordToLabel(m.row, m.col);
        div.innerHTML = '<span class="move-num">' + (i + 1) + '.</span>' +
          '<span class="move-pos">' + (isBlack ? '⚫' : '⚪') + ' ' + label + '</span>' +
          (m.captured > 0 ? '<span class="move-info">提' + m.captured + '子</span>' : '');
        el.appendChild(div);
      }
      el.scrollTop = el.scrollHeight;
    }

    // ========================================================================
    //  GAME LOGIC
    // ========================================================================

    function placeStone(row, col) {
      if (go.gameOver || go.locked || go.isAIThinking) return false;
      if (go.board[row][col] !== 0) return false;

      // Check legal move
      if (!isLegalMove(go.board, row, col, go.currentPlayer, go.koPoint)) {
        showToast('⚠️ 非法落子！');
        return false;
      }

      // Save board state for undo
      go.boardHistory.push(cloneBoard(go.board));

      // Make the move
      var result = makeMove(go.board, row, col, go.currentPlayer);
      if (!result.success) return false;

      // Add place animation
      addPlaceAnimation(row, col, go.currentPlayer);

      // Update captures
      if (result.captured > 0) {
        go.captures[go.currentPlayer] += result.captured;
      }

      // Record move
      go.moveHistory.push({
        row: row,
        col: col,
        player: go.currentPlayer,
        captured: result.captured || 0,
        pass: false
      });

      go.lastMove = { row: row, col: col };
      go.koPoint = result.koPoint || null;
      go.passCount = 0;
      go.moveCount++;

      // Switch player
      go.currentPlayer = go.currentPlayer === 1 ? 2 : 1;

      // Redraw
      drawBoard();
      startAnimLoop();
      updateUI();
      updateMoveHistory();

      return true;
    }

    function passMove() {
      if (go.gameOver || go.locked || go.isAIThinking) return;

      go.passCount++;
      go.boardHistory.push(cloneBoard(go.board));

      go.moveHistory.push({
        row: -1,
        col: -1,
        player: go.currentPlayer,
        captured: 0,
        pass: true
      });
      go.moveCount++;
      go.koPoint = null;

      // Check double pass = game over
      if (go.passCount >= 2) {
        endGame();
        return;
      }

      // Switch player
      go.currentPlayer = go.currentPlayer === 1 ? 2 : 1;

      drawBoard();
      updateUI();
      updateMoveHistory();

      showToast('⏭️ ' + (go.currentPlayer === 1 ? '黑棋' : '白棋') + ' pass，当前回合');

      // If it's AI's turn, trigger AI move
      if (go.currentPlayer === 2 && !go.gameOver) {
        scheduleAIMove();
      }
    }

    function undoMove() {
      if (go.gameOver || go.locked || go.isAIThinking) return;
      if (go.moveHistory.length < 2) return; // Need at least 2 moves to undo (player + AI)

      // Undo player's move and AI's response
      var steps = 0;
      while (steps < 2 && go.boardHistory.length > 0) {
        go.board = go.boardHistory.pop();
        go.moveHistory.pop();
        steps++;
        go.moveCount--;
        // Restore captures - we can't perfectly restore, so recount
        // Recalculate captures from board state
        go.captures = { 1: 0, 2: 0 };
        // Simple recount: just recount stones on board
        var blackCount = 0, whiteCount = 0;
        for (var r = 0; r < BOARD_SIZE; r++) {
          for (var c = 0; c < BOARD_SIZE; c++) {
            if (go.board[r][c] === 1) blackCount++;
            else if (go.board[r][c] === 2) whiteCount++;
          }
        }
        // Estimate captures from initial total (361)
        // This is a rough estimate
        var totalBlack = Math.floor((go.moveHistory.filter(function(m) { return m.player === 1 && !m.pass; }).length));
        var totalWhite = Math.floor((go.moveHistory.filter(function(m) { return m.player === 2 && !m.pass; }).length));
        go.captures[2] = totalBlack - blackCount;
        go.captures[1] = totalWhite - whiteCount;
        if (go.captures[1] < 0) go.captures[1] = 0;
        if (go.captures[2] < 0) go.captures[2] = 0;
      }

      // Restore last move
      if (go.moveHistory.length > 0) {
        var last = go.moveHistory[go.moveHistory.length - 1];
        if (last.pass) {
          go.lastMove = null;
        } else {
          go.lastMove = { row: last.row, col: last.col };
        }
      } else {
        go.lastMove = null;
      }

      go.currentPlayer = 1; // Always player's turn after undo
      go.passCount = 0;
      go.koPoint = null;

      drawBoard();
      updateUI();
      updateMoveHistory();
      showToast('↩️ 已悔棋');
    }

    function endGame() {
      go.gameOver = true;
      go.locked = true;

      var result = countTerritory(go.board);

      // Update UI
      drawBoard();
      updateUI();

      // Show result modal
      setTimeout(function() {
        var icon, title, sub;
        if (result.winner === 1) {
          icon = '🏆';
          title = '黑棋胜';
          sub = '黑棋 ' + result.blackScore.toFixed(1) + ' 目 vs 白棋 ' + result.whiteScore.toFixed(1) + ' 目';
        } else if (result.winner === 2) {
          icon = '🥈';
          title = '白棋胜';
          sub = '白棋 ' + result.whiteScore.toFixed(1) + ' 目 vs 黑棋 ' + result.blackScore.toFixed(1) + ' 目';
        } else {
          icon = '🤝';
          title = '平局';
          sub = '双方各 ' + result.blackScore.toFixed(1) + ' 目';
        }

        document.getElementById('goResultIcon').textContent = icon;
        document.getElementById('goResultTitle').textContent = title;
        document.getElementById('goResultSub').textContent = sub;
        document.getElementById('goBlackScore').textContent = result.blackScore.toFixed(1) + ' 目';
        document.getElementById('goWhiteScore').textContent = result.whiteScore.toFixed(1) + ' 目';
        document.getElementById('goTotalMoves').textContent = go.moveCount;

        var detail = '黑棋 ' + result.blackStones + '子 + ' + result.blackTerritory + '目 = ' + result.blackScore.toFixed(1) + '<br>白棋 ' + result.whiteStones + '子 + ' + result.whiteTerritory + '目 + ' + KOMI + '贴目 = ' + result.whiteScore.toFixed(1);
        document.getElementById('goResultDetail').innerHTML = detail;

        document.getElementById('gameoverModal').classList.add('show');
      }, 500);
    }

    // ========================================================================
    //  AI ENGINE
    // ========================================================================

    // ---- Position value table (standard Go opening theory) ----
    var POSITION_VALUE = (function() {
      var table = [];
      for (var r = 0; r < BOARD_SIZE; r++) {
        table[r] = [];
        for (var c = 0; c < BOARD_SIZE; c++) {
          var distEdge = Math.min(r, c, BOARD_SIZE - 1 - r, BOARD_SIZE - 1 - c);
          var val = 0;
          if (distEdge === 0) val = 2;   // edge
          else if (distEdge === 1) val = 8;  // 3rd line
          else if (distEdge === 2) val = 10; // 4th line (ideal for opening)
          else if (distEdge === 3) val = 7;  // 5th line
          else if (distEdge === 4) val = 5;
          else val = 4;

          // Corner bias
          var cornerDist = Math.min(r, c, BOARD_SIZE - 1 - r, BOARD_SIZE - 1 - c);
          if (cornerDist <= 1) val += 3; // corner area bonus
          if (cornerDist === 2) val += 1; // near corner

          table[r][c] = val;
        }
      }
      return table;
    })();

    // ---- Evaluate a position for AI (higher = better for AI which is white=2) ----
    function evaluatePosition(board, row, col, player) {
      var opponent = player === 1 ? 2 : 1;
      var score = 0;

      // 1. Position value
      score += POSITION_VALUE[row][col] * 1.0;

      // 2. Check captures: if placing here captures opponent stones
      var simBoard = cloneBoard(board);
      simBoard[row][col] = player;
      var neighbors = getNeighbors(row, col);
      var captureScore = 0;
      for (var i = 0; i < neighbors.length; i++) {
        var n = neighbors[i];
        if (simBoard[n.row][n.col] === opponent) {
          var group = getGroup(simBoard, n.row, n.col);
          if (group && getLiberties(simBoard, group) === 0) {
            captureScore += group.length * 50;
            // Remove stones for further evaluation
            for (var j = 0; j < group.length; j++) {
              simBoard[group[j].row][group[j].col] = 0;
            }
          }
        }
      }
      score += captureScore;

      // 3. Check if the move saves own stones from being captured
      var ownGroup = getGroup(simBoard, row, col);
      if (ownGroup) {
        var libs = getLiberties(simBoard, ownGroup);
        if (libs === 1) score -= 30; // atari
        else if (libs === 2) score -= 5; // needs to run
        else if (libs >= 3) score += 5; // safe
      }

      // 4. Influence: count nearby friendly stones
      var friendlyNear = 0;
      var enemyNear = 0;
      for (var dr = -3; dr <= 3; dr++) {
        for (var dc = -3; dc <= 3; dc++) {
          if (dr === 0 && dc === 0) continue;
          var nr = row + dr, nc = col + dc;
          if (nr >= 0 && nr < BOARD_SIZE && nc >= 0 && nc < BOARD_SIZE) {
            var dist = Math.sqrt(dr * dr + dc * dc);
            var weight = 4 / (dist + 1);
            if (board[nr][nc] === player) friendlyNear += weight;
            else if (board[nr][nc] === opponent) enemyNear += weight;
          }
        }
      }
      score += (friendlyNear - enemyNear) * 2;

      // 5. Territory influence: prefer areas near own territory
      // (simplified: check if the move expands toward open areas)
      var openSpaces = 0;
      for (var dr = -2; dr <= 2; dr++) {
        for (var dc = -2; dc <= 2; dc++) {
          if (dr === 0 && dc === 0) continue;
          var nr = row + dr, nc = col + dc;
          if (nr >= 0 && nr < BOARD_SIZE && nc >= 0 && nc < BOARD_SIZE && board[nr][nc] === 0) {
            openSpaces++;
          }
        }
      }
      score += openSpaces * 1.5;

      // 6. Edge proximity penalty (too close to edge is bad except for specific patterns)
      if (row === 0 || row === BOARD_SIZE - 1 || col === 0 || col === BOARD_SIZE - 1) {
        score -= 3;
      }

      return score;
    }

    // ---- Get all legal moves for a player ----
    function getLegalMoves(board, player, koPoint) {
      var moves = [];
      for (var r = 0; r < BOARD_SIZE; r++) {
        for (var c = 0; c < BOARD_SIZE; c++) {
          if (board[r][c] === 0 && isLegalMove(board, r, c, player, koPoint)) {
            moves.push({ row: r, col: c });
          }
        }
      }
      return moves;
    }

    // ---- AI Move Selection ----
    function aiSelectMove() {
      var player = 2; // AI is always white (player 2)
      var opponent = 1;
      var legalMoves = getLegalMoves(go.board, player, go.koPoint);

      if (legalMoves.length === 0) return null;

      // Difficulty-based evaluation
      var difficulty = go.difficulty;

      if (difficulty === 'easy') {
        // Easy: mostly random with basic heuristics
        // Filter out low-value moves sometimes
        var scored = legalMoves.map(function(m) {
          var score = evaluatePosition(go.board, m.row, m.col, player);
          // Add randomness
          score += Math.random() * 30;
          // Captures get extra weight
          if (go.board[m.row][m.col] === 0) {
            var simBoard = cloneBoard(go.board);
            simBoard[m.row][m.col] = player;
            var neighbors = getNeighbors(m.row, m.col);
            for (var i = 0; i < neighbors.length; i++) {
              var n = neighbors[i];
              if (simBoard[n.row][n.col] === opponent) {
                var group = getGroup(simBoard, n.row, n.col);
                if (group && getLiberties(simBoard, group) === 0) {
                  score += 80;
                }
              }
            }
          }
          return { move: m, score: score };
        });
        scored.sort(function(a, b) { return b.score - a.score; });
        // Pick from top 5 with some randomness
        var topN = Math.min(5, scored.length);
        var idx = Math.floor(Math.random() * topN);
        return scored[idx].move;
      }

      else if (difficulty === 'medium') {
        // Medium: consider multiple factors
        var scored = legalMoves.map(function(m) {
          var score = evaluatePosition(go.board, m.row, m.col, player);
          score += Math.random() * 15;

          // Prioritize capturing
          var simBoard = cloneBoard(go.board);
          simBoard[m.row][m.col] = player;
          var neighbors = getNeighbors(m.row, m.col);
          for (var i = 0; i < neighbors.length; i++) {
            var n = neighbors[i];
            if (simBoard[n.row][n.col] === opponent) {
              var group = getGroup(simBoard, n.row, n.col);
              if (group && getLiberties(simBoard, group) === 0) {
                score += 120;
              }
            }
          }

          // Defend own stones in atari
          var ownGroup = getGroup(simBoard, m.row, m.col);
          if (ownGroup) {
            var libs = getLiberties(simBoard, ownGroup);
            if (libs === 1) score += 60; // saving own group
          }

          return { move: m, score: score };
        });
        scored.sort(function(a, b) { return b.score - a.score; });
        return scored[0].move;
      }

      else {
        // Hard: full evaluation with multiple passes
        var scored = legalMoves.map(function(m) {
          var score = evaluatePosition(go.board, m.row, m.col, player);
          score += Math.random() * 8;

          var simBoard = cloneBoard(go.board);
          simBoard[m.row][m.col] = player;

          // Capture priority
          var neighbors = getNeighbors(m.row, m.col);
          var captureCount = 0;
          for (var i = 0; i < neighbors.length; i++) {
            var n = neighbors[i];
            if (simBoard[n.row][n.col] === opponent) {
              var group = getGroup(simBoard, n.row, n.col);
              if (group && getLiberties(simBoard, group) === 0) {
                captureCount += group.length;
                for (var j = 0; j < group.length; j++) {
                  simBoard[group[j].row][group[j].col] = 0;
                }
              }
            }
          }
          score += captureCount * 60;

          // Defensive: save own group
          var ownGroup = getGroup(simBoard, m.row, m.col);
          if (ownGroup) {
            var libs = getLiberties(simBoard, ownGroup);
            if (libs === 1) score += 100; // critical rescue
            else if (libs === 2) score += 30;
          }

          // Attack: put opponent in atari
          for (var dr = -1; dr <= 1; dr++) {
            for (var dc = -1; dc <= 1; dc++) {
              if (dr === 0 && dc === 0) continue;
              var nr = m.row + dr, nc = m.col + dc;
              if (nr >= 0 && nr < BOARD_SIZE && nc >= 0 && nc < BOARD_SIZE) {
                if (simBoard[nr][nc] === opponent) {
                  var oppGroup = getGroup(simBoard, nr, nc);
                  if (oppGroup && getLiberties(simBoard, oppGroup) === 1) {
                    score += 80; // put opponent in atari
                  }
                }
              }
            }
          }

          // Ko consideration: if AI can win a ko, try
          if (go.koPoint && m.row === go.koPoint.row && m.col === go.koPoint.col) {
            score += 150; // retake ko
          }

          // Territory building: prefer moves that surround territory
          // Check if the move is on a "sente" point
          var isSente = false;
          for (var dr = -2; dr <= 2; dr++) {
            for (var dc = -2; dc <= 2; dc++) {
              var nr = m.row + dr, nc = m.col + dc;
              if (nr >= 0 && nr < BOARD_SIZE && nc >= 0 && nc < BOARD_SIZE) {
                if (simBoard[nr][nc] === opponent) {
                  var oppGroup = getGroup(simBoard, nr, nc);
                  if (oppGroup && getLiberties(simBoard, oppGroup) <= 2) {
                    isSente = true;
                  }
                }
              }
            }
          }
          if (isSente) score += 40;

          return { move: m, score: score };
        });

        scored.sort(function(a, b) { return b.score - a.score; });
        return scored[0].move;
      }
    }

    function scheduleAIMove() {
      if (go.gameOver) return;
      if (go.currentPlayer !== 2) return; // AI is white (2)
      if (go.isAIThinking) return;

      go.isAIThinking = true;
      go.locked = true;
      document.getElementById('aiThinking').classList.add('show');

      setTimeout(function() {
        var move = aiSelectMove();

        if (move === null) {
          // No legal moves, pass
          go.passCount++;
          go.moveHistory.push({
            row: -1, col: -1,
            player: 2,
            captured: 0,
            pass: true
          });
          go.moveCount++;
          go.koPoint = null;

          if (go.passCount >= 2) {
            go.isAIThinking = false;
            go.locked = true;
            document.getElementById('aiThinking').classList.remove('show');
            endGame();
            return;
          }

          go.currentPlayer = 1;
          showToast('🤖 AI 选择 Pass');
        } else {
          // Make AI move
          go.boardHistory.push(cloneBoard(go.board));
          var result = makeMove(go.board, move.row, move.col, 2);
          if (result.success) {
            addPlaceAnimation(move.row, move.col, 2);
            if (result.captured > 0) {
              go.captures[2] += result.captured;
            }
            go.moveHistory.push({
              row: move.row, col: move.col,
              player: 2,
              captured: result.captured || 0,
              pass: false
            });
            go.lastMove = { row: move.row, col: move.col };
            go.koPoint = result.koPoint || null;
            go.passCount = 0;
            go.moveCount++;
            go.currentPlayer = 1;
          }
        }

        go.isAIThinking = false;
        go.locked = false;
        document.getElementById('aiThinking').classList.remove('show');

        drawBoard();
        startAnimLoop();
        updateUI();
        updateMoveHistory();
      }, 800);
    }

    // ========================================================================
    //  CANVAS EVENT HANDLERS
    // ========================================================================

    canvas.addEventListener('mousemove', function(e) {
      var rect = canvas.getBoundingClientRect();
      var scaleX = canvas.width / rect.width;
      var scaleY = canvas.height / rect.height;
      var px = (e.clientX - rect.left) * scaleX;
      var py = (e.clientY - rect.top) * scaleY;
      var pos = pixelToBoard(px, py);

      if (pos && go.board[pos.row][pos.col] === 0 && !go.gameOver && !go.locked) {
        if (!hoverPos || hoverPos.row !== pos.row || hoverPos.col !== pos.col) {
          hoverPos = pos;
          drawBoard();
        }
      } else {
        if (hoverPos) {
          hoverPos = null;
          drawBoard();
        }
      }
    });

    canvas.addEventListener('mouseleave', function() {
      if (hoverPos) {
        hoverPos = null;
        drawBoard();
      }
    });

    // ========================================================================
    //  GAME CONTROL FUNCTIONS
    // ========================================================================

    function newGame() {
      go.board = createEmptyBoard();
      go.currentPlayer = 1;
      go.moveCount = 0;
      go.lastMove = null;
      go.captures = { 1: 0, 2: 0 };
      go.koPoint = null;
      go.passCount = 0;
      go.gameOver = false;
      go.isAIThinking = false;
      go.locked = false;
      go.moveHistory = [];
      go.boardHistory = [];
      animStones = [];
      hoverPos = null;

      document.getElementById('gameoverModal').classList.remove('show');
      document.getElementById('aiThinking').classList.remove('show');

      drawBoard();
      updateUI();
      updateMoveHistory();
      showToast('🔄 新对局开始！');
    }

    function setDifficulty(level, el) {
      go.difficulty = level;
      var btns = document.querySelectorAll('.diff-btn');
      for (var i = 0; i < btns.length; i++) {
        btns[i].classList.remove('active');
      }
      if (el) el.classList.add('active');
      showToast('🤖 AI 难度已切换为: ' + (level === 'easy' ? '简单' : level === 'medium' ? '普通' : '困难'));
    }

    // ========================================================================
    //  ONLINE MODE & SOCKET.IO
    // ========================================================================

    // ---- Tier definitions (client-side) ----
    var TIERS = [
      { min: 0, max: 999, name: '初学', color: '#8B7355' },
      { min: 1000, max: 1299, name: '业余初级', color: '#2E8B57' },
      { min: 1300, max: 1499, name: '业余中级', color: '#1E90FF' },
      { min: 1500, max: 1699, name: '业余高级', color: '#9370DB' },
      { min: 1700, max: 1899, name: '专业初级', color: '#FF4500' },
      { min: 1900, max: 2099, name: '专业中级', color: '#FF6347' },
      { min: 2100, max: 2299, name: '专业高级', color: '#FF1493' },
      { min: 2300, max: 2499, name: '大师', color: '#FFD700' },
      { min: 2500, max: Infinity, name: '宗师', color: '#FF0000' },
    ];

    function getTierName(rating) {
      for (var i = 0; i < TIERS.length; i++) {
        if (rating >= TIERS[i].min && rating <= TIERS[i].max) {
          return TIERS[i].name;
        }
      }
      return '宗师';
    }

    function getTierColor(tierName) {
      for (var i = 0; i < TIERS.length; i++) {
        if (TIERS[i].name === tierName) {
          return TIERS[i].color;
        }
      }
      return '#8B7355';
    }

    function updateTierBadge(tierName, rating) {
      var color = getTierColor(tierName);
      var badge = document.getElementById('tierBadge');
      badge.innerHTML = '<span class="tier-dot" style="background:' + color + '"></span>' + tierName;
      badge.style.background = 'rgba(' + hexToRgb(color) + ',0.15)';
      badge.style.color = color;
      badge.style.borderColor = 'rgba(' + hexToRgb(color) + ',0.3)';
      document.getElementById('ratingValue').textContent = Math.round(rating);
    }

    function hexToRgb(hex) {
      var result = /^#?([a-f\d]{2})([a-f\d]{2})([a-f\d]{2})$/i.exec(hex);
      return result ? parseInt(result[1], 16) + ',' + parseInt(result[2], 16) + ',' + parseInt(result[3], 16) : '139,115,85';
    }

    // ---- Socket.IO ----
    var socket = null;
    var connected = false;
    var currentRoomId = null;
    var inQueue = false;
    var isMyTurn = false;
    var onlinePlayerColor = 1; // 1=black, 2=white
    var opponentInfo = null;

    function initSocket() {
      socket = io(window.location.origin, {
        transports: ['websocket', 'polling']
      });

      socket.on('connect', function() {
        connected = true;
        document.getElementById('connectionDot').className = 'dot online';
        document.getElementById('lobbyStatus').textContent = '🟢 已连接';
        showToast('✅ 已连接到服务器');
        fetchRating();
      });

      socket.on('disconnect', function() {
        connected = false;
        document.getElementById('connectionDot').className = 'dot offline';
        document.getElementById('lobbyStatus').textContent = '🔴 未连接';
        if (inQueue) {
          inQueue = false;
          showToast('⚠️ 连接断开，已退出匹配队列');
        }
      });

      // ---- Match events ----
      socket.on('go_match_found', function(data) {
        inQueue = false;
        closeMatchModal();
        currentRoomId = data.roomId;
        opponentInfo = data.opponent;
        showToast('🎯 匹配成功！对阵 ' + (data.opponent.username || '对手'));
        document.getElementById('roomInfoBar').classList.add('show');
        document.getElementById('roomIdDisplay').textContent = data.roomId;
        document.getElementById('roomStatusText').textContent = '🔄 等待游戏开始...';
        // Show opponent info
        document.getElementById('opponentInfo').classList.add('show');
        document.getElementById('opponentName').textContent = data.opponent.username || '对手';
        if (data.opponent.rating) {
          var oppTier = getTierName(data.opponent.rating.rating || 1500);
          var oppColor = getTierColor(oppTier);
          document.getElementById('opponentTier').innerHTML = '<span class="tier-badge" style="background:rgba(' + hexToRgb(oppColor) + ',0.15);color:' + oppColor + ';border:1px solid rgba(' + hexToRgb(oppColor) + ',0.3);padding:2px 8px;font-size:11px;"><span class="tier-dot" style="background:' + oppColor + '"></span>' + oppTier + '</span> 积分:' + Math.round(data.opponent.rating.rating || 1500);
        }
        // Self rating display
        if (data.selfRating) {
          updateTierBadge(getTierName(data.selfRating.rating || 1500), data.selfRating.rating || 1500);
        }
      });

      socket.on('go_queue_status', function(data) {
        if (data.inQueue) {
          inQueue = true;
          var pos = data.position || '?';
          document.getElementById('matchWaitingSub').textContent = '队列位置: #' + pos;
        } else {
          inQueue = false;
        }
      });

      socket.on('go_room_created', function(data) {
        currentRoomId = data.roomId;
        document.getElementById('roomInfoBar').classList.add('show');
        document.getElementById('roomIdDisplay').textContent = data.roomId;
        document.getElementById('roomStatusText').textContent = '⏳ 等待对手加入...';
        showToast('🏠 房间创建成功！房间号: ' + data.roomId);
      });

      socket.on('go_game_start', function(data) {
        // Switch to online mode
        go.mode = 'online';
        document.getElementById('roomInfoBar').classList.add('show');
        document.getElementById('roomIdDisplay').textContent = data.roomId || currentRoomId;
        document.getElementById('roomStatusText').textContent = '🎮 对局中';

        // Determine player color
        var players = data.players || [];
        var myId = currentUser ? currentUser.id : null;
        if (players.length >= 2) {
          if (players[0].id === myId) {
            onlinePlayerColor = 1; // Black
          } else {
            onlinePlayerColor = 2; // White
          }
        }

        // Update UI
        if (onlinePlayerColor === 1) {
          document.getElementById('blackName').textContent = '黑棋 (' + (currentUser ? currentUser.username : '你') + ')';
          document.getElementById('whiteName').textContent = '白棋 (' + (opponentInfo ? opponentInfo.username : '对手') + ')';
        } else {
          document.getElementById('blackName').textContent = '黑棋 (' + (opponentInfo ? opponentInfo.username : '对手') + ')';
          document.getElementById('whiteName').textContent = '白棋 (' + (currentUser ? currentUser.username : '你') + ')';
        }

        // Update avatar based on color
        if (onlinePlayerColor === 1) {
          document.getElementById('blackAvatar').src = currentUser && currentUser.avatar ? currentUser.avatar : '/images/default-avatar.png';
          document.getElementById('whiteAvatar').src = '/images/default-avatar.png';
        } else {
          document.getElementById('blackAvatar').src = '/images/default-avatar.png';
          document.getElementById('whiteAvatar').src = currentUser && currentUser.avatar ? currentUser.avatar : '/images/default-avatar.png';
        }

        // Start game
        newGame();
        go.mode = 'online';

        // Set turn
        isMyTurn = (data.currentTurn === myId);
        go.currentPlayer = data.currentTurn === myId ? onlinePlayerColor : (onlinePlayerColor === 1 ? 2 : 1);
        go.locked = !isMyTurn;

        updateUI();
        showToast('🎮 对局开始！' + (isMyTurn ? '轮到你了' : '等待对手落子'));
      });

      socket.on('go_moved', function(data) {
        if (!data.move || go.mode !== 'online') return;
        var move = data.move;
        var row = move.row, col = move.col;

        // Handle pass
        if (move.pass || row === -1 || col === -1) {
          go.passCount++;
          go.boardHistory.push(cloneBoard(go.board));
          var movingPlayer = onlinePlayerColor === 1 ? 2 : 1;
          go.moveHistory.push({
            row: -1, col: -1,
            player: movingPlayer,
            captured: 0,
            pass: true
          });
          go.moveCount++;
          go.koPoint = null;

          if (go.passCount >= 2) {
            endGame();
            return;
          }

          go.currentPlayer = onlinePlayerColor;
          isMyTurn = true;
          go.locked = false;

          drawBoard();
          updateUI();
          updateMoveHistory();
          showToast('⏭️ 对手选择了 Pass');
          return;
        }

        // Normal move
        if (row === undefined || col === undefined) return;

        // Set the current player to the one who moved
        var movingPlayer = onlinePlayerColor === 1 ? 2 : 1;

        // Save board state for undo
        go.boardHistory.push(cloneBoard(go.board));

        // Make the move
        var result = makeMove(go.board, row, col, movingPlayer);
        if (!result.success) return;

        addPlaceAnimation(row, col, movingPlayer);

        // Update captures
        if (result.captured > 0) {
          go.captures[movingPlayer] += result.captured;
        }

        // Record move
        go.moveHistory.push({
          row: row,
          col: col,
          player: movingPlayer,
          captured: result.captured || 0,
          pass: false
        });

        go.lastMove = { row: row, col: col };
        go.koPoint = result.koPoint || null;
        go.passCount = 0;
        go.moveCount++;

        // Switch to current player
        go.currentPlayer = onlinePlayerColor;
        isMyTurn = true;
        go.locked = false;

        drawBoard();
        startAnimLoop();
        updateUI();
        updateMoveHistory();
      });

      socket.on('go_game_over', function(data) {
        go.gameOver = true;
        go.locked = true;
        drawBoard();
        updateUI();

        var winnerId = data.winnerId;
        var reason = data.reason || '';
        var myId = currentUser ? currentUser.id : null;
        var isWin = winnerId === myId;
        var isDraw = !winnerId;

        setTimeout(function() {
          var icon, title, sub;
          if (isDraw) {
            icon = '🤝';
            title = '平局';
            sub = reason === 'draw' ? '双方同意和棋' : '对局结束';
          } else if (isWin) {
            icon = '🏆';
            title = '你赢了！';
            sub = reason === 'resign' ? '对手认输' : '获胜';
          } else {
            icon = '😅';
            title = '你输了';
            sub = reason === 'resign' ? '你认输了' : reason === 'timeout' ? '超时负' : '对局结束';
          }

          document.getElementById('goResultIcon').textContent = icon;
          document.getElementById('goResultTitle').textContent = title;
          document.getElementById('goResultSub').textContent = sub;
          document.getElementById('goBlackScore').textContent = go.captures[1] + ' 提子';
          document.getElementById('goWhiteScore').textContent = go.captures[2] + ' 提子';
          document.getElementById('goTotalMoves').textContent = go.moveCount;
          document.getElementById('goResultDetail').textContent = reason || '—';

          document.getElementById('gameoverModal').classList.add('show');
        }, 500);

        // Clean up room
        document.getElementById('roomInfoBar').classList.remove('show');
        document.getElementById('opponentInfo').classList.remove('show');
        currentRoomId = null;
      });

      socket.on('go_rating_update', function(data) {
        var myId = currentUser ? currentUser.id : null;
        if (myId && data[myId]) {
          var r = data[myId];
          updateTierBadge(r.tier || getTierName(r.rating), r.rating);
          var changeStr = r.change > 0 ? '+' + r.change : r.change;
          showToast('📊 积分变化: ' + changeStr + ' (' + (r.tier || getTierName(r.rating)) + ')', 3000);

          // Update rating display
          document.getElementById('ratingValue').textContent = Math.round(r.rating);
          var tierName = r.tier || getTierName(r.rating);
          var color = getTierColor(tierName);
          var badge = document.getElementById('tierBadge');
          badge.innerHTML = '<span class="tier-dot" style="background:' + color + '"></span>' + tierName;
          badge.style.background = 'rgba(' + hexToRgb(color) + ',0.15)';
          badge.style.color = color;
          badge.style.borderColor = 'rgba(' + hexToRgb(color) + ',0.3)';
        }
      });

      socket.on('go_error', function(msg) {
        showToast('⚠️ ' + (typeof msg === 'string' ? msg : '操作失败'));
      });

      socket.on('go_draw_offer', function() {
        if (confirm('🤝 对手请求和棋，是否同意？')) {
          socket.emit('go_accept_draw', { roomId: currentRoomId });
        }
      });

      socket.on('go_chat', function(data) {
        if (data.from && data.message) {
          showToast('💬 ' + data.from + ': ' + data.message, 3000);
        }
      });
    }

    // ---- Match/Room Functions ----
    function switchMode(mode, btn) {
      if (mode === 'online' && !connected) {
        showToast('⚠️ 未连接到服务器');
        return;
      }
      go.mode = mode;
      var btns = document.querySelectorAll('.match-lobby-bar .mode-btn');
      for (var i = 0; i < btns.length; i++) {
        btns[i].classList.remove('active');
      }
      if (btn) btn.classList.add('active');

      if (mode === 'ai') {
        // Reset to AI mode
        document.getElementById('opponentInfo').classList.remove('show');
        document.getElementById('roomInfoBar').classList.remove('show');
        document.getElementById('blackName').textContent = '黑棋 (你)';
        document.getElementById('whiteName').textContent = '白棋 (AI)';
        document.getElementById('blackAvatar').src = currentUser && currentUser.avatar ? currentUser.avatar : '/images/default-avatar.png';
        document.getElementById('whiteAvatar').src = '/images/default-avatar.png';
        if (currentRoomId) {
          if (inQueue) {
            socket.emit('go_leave_queue');
            inQueue = false;
          }
          currentRoomId = null;
        }
        newGame();
        showToast('🤖 已切换到 AI 对战模式');
      }
    }

    function openMatchModal() {
      if (!connected) {
        showToast('⚠️ 未连接到服务器，请刷新页面重试');
        return;
      }
      document.getElementById('matchModal').classList.add('show');
      document.getElementById('matchModalContent').style.display = 'block';
      document.getElementById('matchWaiting').style.display = 'none';
    }

    function closeMatchModal() {
      document.getElementById('matchModal').classList.remove('show');
    }

    function startMatch() {
      if (!connected) {
        showToast('⚠️ 未连接到服务器');
        return;
      }
      if (inQueue) return;
      var mode = document.getElementById('matchModeSelect').value;
      var time = document.getElementById('matchTimeSelect').value;
      socket.emit('go_join_queue', { mode: mode, timeControl: time });
      document.getElementById('matchModalContent').style.display = 'none';
      document.getElementById('matchWaiting').style.display = 'block';
      document.getElementById('matchWaitingSub').textContent = (mode === 'ranked' ? '排位模式' : '休闲模式') + ' · ' + document.getElementById('matchTimeSelect').selectedOptions[0].text;
      showToast('🔍 已加入匹配队列...');
    }

    function cancelMatch() {
      if (!connected) return;
      socket.emit('go_leave_queue');
      inQueue = false;
      document.getElementById('matchModalContent').style.display = 'block';
      document.getElementById('matchWaiting').style.display = 'none';
      closeMatchModal();
      showToast('已取消匹配');
    }

    function openCreateRoomModal() {
      if (!connected) {
        showToast('⚠️ 未连接到服务器');
        return;
      }
      document.getElementById('createRoomModal').classList.add('show');
    }

    function openJoinRoomModal() {
      if (!connected) {
        showToast('⚠️ 未连接到服务器');
        return;
      }
      document.getElementById('joinRoomModal').classList.add('show');
    }

    function closeModal(id) {
      document.getElementById(id).classList.remove('show');
    }

    function createRoom() {
      if (!connected) return;
      var name = document.getElementById('roomNameInput').value || '我的房间';
      var password = document.getElementById('roomPasswordInput').value || '';
      var time = document.getElementById('roomTimeSelect').value;
      socket.emit('go_create_room', { roomName: name, password: password, timeControl: time });
      closeModal('createRoomModal');
      // Switch to online mode
      go.mode = 'online';
      var btns = document.querySelectorAll('.match-lobby-bar .mode-btn');
      for (var i = 0; i < btns.length; i++) btns[i].classList.remove('active');
    }

    function joinRoom() {
      if (!connected) return;
      var roomId = document.getElementById('joinRoomIdInput').value.trim();
      var password = document.getElementById('joinRoomPasswordInput').value || '';
      if (!roomId) {
        showToast('⚠️ 请输入房间号');
        return;
      }
      socket.emit('go_join_room', { roomId: roomId, password: password });
      closeModal('joinRoomModal');
      // Switch to online mode
      go.mode = 'online';
      var btns = document.querySelectorAll('.match-lobby-bar .mode-btn');
      for (var i = 0; i < btns.length; i++) btns[i].classList.remove('active');
    }

    // ---- Online Move Functions ----
    function sendOnlineMove(row, col) {
      if (!connected || !currentRoomId) return false;
      socket.emit('go_move', { roomId: currentRoomId, move: { row: row, col: col } });
      return true;
    }

    function sendOnlinePass() {
      if (!connected || !currentRoomId) return;
      socket.emit('go_move', { roomId: currentRoomId, move: { row: -1, col: -1, pass: true } });
    }

    function resignOnline() {
      if (!connected || !currentRoomId) return;
      if (confirm('确定要认输吗？')) {
        socket.emit('go_resign', { roomId: currentRoomId });
      }
    }

    function offerDrawOnline() {
      if (!connected || !currentRoomId) return;
      socket.emit('go_offer_draw', { roomId: currentRoomId });
      showToast('🤝 已发送和棋请求');
    }

    // ---- Fetch Rating ----
    function fetchRating() {
      var xhr = new XMLHttpRequest();
      xhr.open('GET', '/api/go/rating', true);
      xhr.setRequestHeader('X-Requested-With', 'XMLHttpRequest');
      xhr.onload = function() {
        if (xhr.status === 200) {
          try {
            var data = JSON.parse(xhr.responseText);
            var tier = data.tier || getTierName(data.rating);
            updateTierBadge(tier, data.rating);
            document.getElementById('gamesPlayed').textContent = data.games_played || 0;
            var wins = data.wins || 0;
            var total = data.games_played || 0;
            var winRate = total > 0 ? Math.round((wins / total) * 100) + '%' : '0%';
            document.getElementById('winRate').textContent = winRate;
            var streak = data.streak || 0;
            if (streak > 0) {
              document.getElementById('streakDisplay').textContent = '🔥 ' + streak + '连胜';
              document.getElementById('streakDisplay').className = 'value positive';
            } else if (streak < 0) {
              document.getElementById('streakDisplay').textContent = '💔 ' + Math.abs(streak) + '连败';
              document.getElementById('streakDisplay').className = 'value negative';
            } else {
              document.getElementById('streakDisplay').textContent = '—';
              document.getElementById('streakDisplay').className = 'value';
            }
          } catch(e) {
            // Ignore parse errors
          }
        }
      };
      xhr.send();
    }

    // ---- Handle Play Again ----
    function handlePlayAgain() {
      document.getElementById('gameoverModal').classList.remove('show');
      if (go.mode === 'online') {
        // Reset to AI mode
        go.mode = 'ai';
        var btns = document.querySelectorAll('.match-lobby-bar .mode-btn');
        for (var i = 0; i < btns.length; i++) btns[i].classList.remove('active');
        if (btns[0]) btns[0].classList.add('active');
        document.getElementById('opponentInfo').classList.remove('show');
        document.getElementById('roomInfoBar').classList.remove('show');
        document.getElementById('blackName').textContent = '黑棋 (你)';
        document.getElementById('whiteName').textContent = '白棋 (AI)';
        document.getElementById('blackAvatar').src = currentUser && currentUser.avatar ? currentUser.avatar : '/images/default-avatar.png';
        document.getElementById('whiteAvatar').src = '/images/default-avatar.png';
        currentRoomId = null;
        newGame();
      } else {
        newGame();
      }
    }

    // ---- Override newGame to handle online mode ----
    var originalNewGame = newGame;
    newGame = function() {
      originalNewGame();
      if (go.mode === 'online') {
        // Don't trigger AI in online mode
        go.locked = !isMyTurn;
        // Update names based on online mode
        if (onlinePlayerColor === 1) {
          document.getElementById('blackName').textContent = '黑棋 (' + (currentUser ? currentUser.username : '你') + ')';
          document.getElementById('whiteName').textContent = '白棋 (' + (opponentInfo ? opponentInfo.username : '对手') + ')';
        } else {
          document.getElementById('blackName').textContent = '黑棋 (' + (opponentInfo ? opponentInfo.username : '对手') + ')';
          document.getElementById('whiteName').textContent = '白棋 (' + (currentUser ? currentUser.username : '你') + ')';
        }
      }
    };

    // ---- Override canvas click handler for online mode ----
    canvas.addEventListener('click', function(e) {
      if (go.gameOver || go.locked || go.isAIThinking) return;
      if (go.mode === 'online') {
        if (!isMyTurn) {
          showToast('⏳ 等待对手落子');
          return;
        }
        if (go.currentPlayer !== onlinePlayerColor) return;
      } else {
        if (go.currentPlayer === 2) return; // AI's turn
      }

      var rect = canvas.getBoundingClientRect();
      var scaleX = canvas.width / rect.width;
      var scaleY = canvas.height / rect.height;
      var px = (e.clientX - rect.left) * scaleX;
      var py = (e.clientY - rect.top) * scaleY;
      var pos = pixelToBoard(px, py);

      if (!pos) return;

      if (go.mode === 'online') {
        // Online mode: send move via socket
        if (placeStone(pos.row, pos.col)) {
          isMyTurn = false;
          go.locked = true;
          sendOnlineMove(pos.row, pos.col);
        }
      } else {
        // AI mode: existing logic
        if (placeStone(pos.row, pos.col)) {
          if (!go.gameOver && go.currentPlayer === 2) {
            scheduleAIMove();
          }
        }
      }
    });

    // ---- Override passMove for online mode ----
    var originalPassMove = passMove;
    passMove = function() {
      if (go.gameOver || go.locked || go.isAIThinking) return;

      if (go.mode === 'online') {
        if (!isMyTurn) {
          showToast('⏳ 等待对手落子');
          return;
        }
        // Send pass move
        go.passCount++;
        go.boardHistory.push(cloneBoard(go.board));
        go.moveHistory.push({
          row: -1, col: -1,
          player: go.currentPlayer,
          captured: 0,
          pass: true
        });
        go.moveCount++;
        go.koPoint = null;

        if (go.passCount >= 2) {
          endGame();
          return;
        }

        go.currentPlayer = go.currentPlayer === 1 ? 2 : 1;
        isMyTurn = false;
        go.locked = true;

        drawBoard();
        updateUI();
        updateMoveHistory();
        sendOnlinePass();
        showToast('⏭️ 你选择了 Pass');
      } else {
        originalPassMove();
      }
    };

    // ---- Add resign/offer draw buttons in online mode ----
    function updateOnlineActions() {
      if (go.mode === 'online' && !go.gameOver) {
        var actions = document.querySelector('.game-actions');
        if (!document.getElementById('btnResign')) {
          var resignBtn = document.createElement('button');
          resignBtn.className = 'btn';
          resignBtn.id = 'btnResign';
          resignBtn.textContent = '🏳️ 认输';
          resignBtn.onclick = resignOnline;
          actions.appendChild(resignBtn);

          var drawBtn = document.createElement('button');
          drawBtn.className = 'btn';
          drawBtn.id = 'btnDraw';
          drawBtn.textContent = '🤝 求和';
          drawBtn.onclick = offerDrawOnline;
          actions.appendChild(drawBtn);
        }
      } else {
        var resignBtn = document.getElementById('btnResign');
        var drawBtn = document.getElementById('btnDraw');
        if (resignBtn) { resignBtn.remove(); }
        if (drawBtn) { drawBtn.remove(); }
      }
    }

    // Override updateUI to also update online actions
    var originalUpdateUI = updateUI;
    updateUI = function() {
      originalUpdateUI();
      updateOnlineActions();
    };

    // ========================================================================
    //  INITIALIZATION
    // ========================================================================

    // Initialize from EJS data
    var currentUser = <%- JSON.stringify(typeof user !== 'undefined' ? user : null) %>;

    // Initialize socket.io
    initSocket();

    newGame();
    updateUI();
    updateMoveHistory();

    // Fetch rating on load
    fetchRating();

    console.log('✅ 围棋游戏已加载');
  </script>
</body>
</html>