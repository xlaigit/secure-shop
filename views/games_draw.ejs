          { word: '亡羊补牢', difficulty: '中等', time: 50 },
          { word: '刻舟求剑', difficulty: '中等', time: 50 },
          { word: '对牛弹琴', difficulty: '中等', time: 45 },
          { word: '鹤立鸡群', difficulty: '困难', time: 45 },
          { word: '惊弓之鸟', difficulty: '困难', time: 40 },
          { word: '画龙点睛', difficulty: '困难', time: 40 },
          { word: '叶公好龙', difficulty: '地狱', time: 35 }
        ]
      },
      '风景': {
        levels: [
          { word: '日出', difficulty: '简单', time: 60 },
          { word: '大海', difficulty: '简单', time: 55 },
          { word: '森林', difficulty: '简单', time: 55 },
          { word: '瀑布', difficulty: '中等', time: 50 },
          { word: '雪山', difficulty: '中等', time: 50 },
          { word: '沙漠', difficulty: '中等', time: 45 },
          { word: '极光', difficulty: '困难', time: 45 },
          { word: '星空', difficulty: '困难', time: 40 },
          { word: '海底世界', difficulty: '困难', time: 40 },
          { word: '天空之城', difficulty: '地狱', time: 35 }
        ]
      }
    };

    const mode4Rewards = [
      { icon: '🖌️', name: '彩虹画笔', level: 2 },
      { icon: '✨', name: '星光笔刷', level: 4 },
      { icon: '🌈', name: '渐变背景', level: 6 },
      { icon: '🎨', name: '水彩效果', level: 8 },
      { icon: '👑', name: '黄金画框', level: 10 }
    ];

    function selectMode4Category(cat) {
      mode4Category = cat;
      document.querySelectorAll('#mode4CategoryPanel .category-card').forEach(el => {
        el.classList.toggle('active', el.dataset.cat === cat);
      });
      document.getElementById('mode4CategoryTag').textContent = cat;
      mode4Level = 1;
      mode4Score = 0;
      mode4Unlocks = [];
      startMode4Level();
    }

    function startMode4Level() {
      const data = mode4LevelData[mode4Category];
      if (!data || mode4Level > data.levels.length) {
        showResultModal('🏆', '恭喜通关！', '你完成了所有关卡！<br>总分：<span class="highlight">' + mode4Score + '</span>', '重新开始', '返回大厅');
        return;
      }

      const level = data.levels[mode4Level - 1];
      document.getElementById('mode4CategoryPanel').style.display = 'none';
      document.getElementById('mode4GameArea').style.display = 'block';
      document.getElementById('mode4RewardsPanel').style.display = 'block';
      mode4Active = true;
      mode4TimeLeft = level.time;
      mode4Stars = 0;

      document.getElementById('mode4Word').textContent = level.word;
      document.getElementById('mode4WordHint').textContent = `第 ${mode4Level} 关 · 难度：${level.difficulty}`;
      document.getElementById('mode4Level').textContent = mode4Level;
      updateMode4Stats();
      renderMode4Progress();
      renderMode4Rewards();

      initCanvas('mode4');
      startMode4Timer();
      // Start AI analysis
      mode4AiRound = 0;
      if (mode4AiInterval) clearInterval(mode4AiInterval);
      mode4AiInterval = setInterval(function() {
        if (!mode4Active) { clearInterval(mode4AiInterval); return; }
        mode4AiRound++;
        checkMode4Guess();
      }, 2500);
      // Reset AI guesses display
      const gl = document.getElementById('mode4AiGuessesList');
      if (gl) gl.innerHTML = '<div class="guess-item" style="opacity:0.4">AI 正在分析画作...</div>';
    }

    function startMode4Timer() {
      if (mode4Timer) clearInterval(mode4Timer);
      mode4Timer = setInterval(() => {
        mode4TimeLeft--;
        updateMode4Stats();
        if (mode4TimeLeft <= 0) {
          clearInterval(mode4Timer);
          endMode4Level();
        }
      }, 1000);
    }

    function updateMode4Stats() {
      document.getElementById('mode4Score').textContent = mode4Score;
      document.getElementById('mode4Timer').textContent = mode4TimeLeft;
      const timerEl = document.getElementById('mode4Timer');
      timerEl.classList.toggle('timer-warning', mode4TimeLeft <= 10);
    }

    function renderMode4Progress() {
      const data = mode4LevelData[mode4Category];
      if (!data) return;
      const container = document.getElementById('mode4LevelProgress');
      let html = '';
      for (let i = 0; i < data.levels.length; i++) {
        if (i > 0) {
          html += `<div class="level-line${i <= mode4Level - 1 ? ' completed' : ''}"></div>`;
        }
        let cls = 'level-dot';
        if (i < mode4Level - 1) cls += ' completed';
        else if (i === mode4Level - 1) cls += ' current';
        else cls += ' locked';
        html += `<div class="${cls}">${i + 1}</div>`;
      }
      container.innerHTML = html;
    }

    function renderMode4Rewards() {
      const container = document.getElementById('mode4RewardsGrid');
      container.innerHTML = mode4Rewards.map(r => {
        const unlocked = mode4Level - 1 >= r.level;
        return `<div class="reward-item${unlocked ? ' unlocked' : ''}">
          <div class="reward-icon">${r.icon}</div>
          <div class="reward-name">${unlocked ? r.name : '🔒 Lv.' + r.level}</div>
        </div>`;
      }).join('');
    }

    function renderMode4AiGuesses(guesses) {
      const container = document.getElementById('mode4AiGuessesList');
      if (!container) return;
      const display = guesses.slice(0, 6);
      container.innerHTML = display.map(function(g) {
        var cls = 'low-confidence';
        if (g.confidence >= 70) cls = 'high-confidence';
        else if (g.confidence >= 40) cls = 'medium-confidence';
        var tag = '';
        if (g.isVague) tag = '<span style="font-size:9px;color:rgba(255,255,255,0.3);margin-left:4px">[观察中]</span>';
        else if (g.isBroad) tag = '<span style="font-size:9px;color:rgba(255,255,255,0.3);margin-left:4px">[范围]</span>';
        return '<div class="guess-item ' + cls + '"><span class="guess-word">' + g.word + '</span><span class="guess-conf">' + g.confidence + '%</span>' + tag + '</div>';
      }).join('');
    }

    function checkMode4Guess() {
      if (!mode4Active) return;
      const data = mode4LevelData[mode4Category];
      if (!data) return;
      const level = data.levels[mode4Level - 1];
      if (!level) return;
      const targetWord = level.word;

      // Analyze canvas
      const features = analyzeDrawing('mode4');
      if (!features) return;
      const fillRatio = features.fillRatio;

      // If canvas is empty, show placeholder
      if (fillRatio < 0.005) {
        renderMode4AiGuesses([
          { word: '画布空白', confidence: 10, isVague: true },
          { word: '请开始绘画', confidence: 5, isVague: true }
        ]);
        return;
      }

      // Get suggested categories from canvas features
      const suggestedCats = suggestCategories(features);

      // Determine the AI word category for this mode4 theme
      var themeCategory = MODE4_CATEGORY_MAP[mode4Category] || null;

      // Always include words from the current theme category
      var categoryWords = [];
      if (themeCategory && AI_WORD_CATEGORIES[themeCategory]) {
        categoryWords = AI_WORD_CATEGORIES[themeCategory].slice();
        // Shuffle category words
        for (var ci = categoryWords.length - 1; ci > 0; ci--) {
          var cj = Math.floor(Math.random() * (ci + 1));
          var tmp = categoryWords[ci]; categoryWords[ci] = categoryWords[cj]; categoryWords[cj] = tmp;
        }
      }

      // Also pick from suggested categories
      var guessCount = 4 + Math.min(Math.floor(mode4AiRound * 0.5), 4);
      var selectedWords = [];

      // First, add category words (up to 8)
      for (var ci = 0; ci < categoryWords.length && ci < 8; ci++) {
        if (selectedWords.indexOf(categoryWords[ci]) === -1) {
          selectedWords.push(categoryWords[ci]);
        }
      }

      // Fill remaining slots from suggested categories
      if (selectedWords.length < guessCount + 3) {
        var extraWords = pickWordsFromCategories(suggestedCats, guessCount + 3, '');
        for (var ei = 0; ei < extraWords.length && selectedWords.length < guessCount + 3; ei++) {
          if (selectedWords.indexOf(extraWords[ei]) === -1) {
            selectedWords.push(extraWords[ei]);
          }
        }
      }

      // Ensure target word is always included if it's in the AI word pool
      var targetInPool = false;
      for (var catKey in AI_WORD_CATEGORIES) {
        if (AI_WORD_CATEGORIES[catKey].indexOf(targetWord) !== -1) {
          targetInPool = true;
          break;
        }
      }
      if (targetInPool && selectedWords.indexOf(targetWord) === -1) {
        selectedWords.push(targetWord);
      }

      // Base confidence based on canvas fill + rounds
      var baseConf = 20 + fillRatio * 150 + mode4AiRound * 3;
      baseConf = Math.min(baseConf, 80);

      var guesses = [];
      for (var i = 0; i < selectedWords.length && i < guessCount + 2; i++) {
        var conf = baseConf + Math.random() * 15 - i * 2;
        // Boost confidence for words from the current theme category
        if (themeCategory && categoryWords.indexOf(selectedWords[i]) !== -1) {
          conf += 8;
        }
        // Check if this word matches the target
        var isCorrect = selectedWords[i] === targetWord;
        if (isCorrect) {
          conf = Math.min(conf + 25, 95);
        }
        guesses.push({
          word: selectedWords[i],
          confidence: Math.round(Math.min(conf, 90)),
          isPrecise: true,
          isCorrect: isCorrect
        });
      }

      // Sort by confidence
      guesses.sort(function(a, b) { return b.confidence - a.confidence; });

      // Check if any guess is correct with high confidence
      var topGuess = guesses[0];
      if (topGuess && topGuess.isCorrect && topGuess.confidence >= 60 && mode4AiRound >= 2) {
        // AI guessed correctly! End the level
        endMode4Level(true);
        return;
      }

      renderMode4AiGuesses(guesses);
    }

    function submitMode4Drawing() {
      if (!mode4Active) return;
      // Force a check with bonus confidence
      mode4AiRound = Math.max(mode4AiRound, 3); // Boost AI round count
      const data = mode4LevelData[mode4Category];
      if (!data) return;
      const level = data.levels[mode4Level - 1];
      if (!level) return;
      const targetWord = level.word;

      // Analyze canvas
      const features = analyzeDrawing('mode4');
      if (!features) return;
      const fillRatio = features.fillRatio;

      if (fillRatio < 0.01) {
        showToast('画布内容太少，再多画一些吧！', 'error');
        return;
      }

      const suggestedCats = suggestCategories(features);
      var themeCategory = MODE4_CATEGORY_MAP[mode4Category] || null;

      // Build selected words list: first from theme category, then from suggested
      var selectedWords = [];
      if (themeCategory && AI_WORD_CATEGORIES[themeCategory]) {
        var catWords = AI_WORD_CATEGORIES[themeCategory].slice();
        for (var ci = catWords.length - 1; ci > 0; ci--) {
          var cj = Math.floor(Math.random() * (ci + 1));
          var tmp = catWords[ci]; catWords[ci] = catWords[cj]; catWords[cj] = tmp;
        }
        for (var ci = 0; ci < catWords.length && ci < 12; ci++) {
          if (selectedWords.indexOf(catWords[ci]) === -1) selectedWords.push(catWords[ci]);
        }
      }
      var extraWords = pickWordsFromCategories(suggestedCats, 10, '');
      for (var ei = 0; ei < extraWords.length && selectedWords.length < 15; ei++) {
        if (selectedWords.indexOf(extraWords[ei]) === -1) selectedWords.push(extraWords[ei]);
      }

      // Ensure target word is included if it's in the AI word pool
      var targetInPool = false;
      for (var catKey in AI_WORD_CATEGORIES) {
        if (AI_WORD_CATEGORIES[catKey].indexOf(targetWord) !== -1) {
          targetInPool = true; break;
        }
      }
      if (targetInPool && selectedWords.indexOf(targetWord) === -1) {
        selectedWords.push(targetWord);
      }

      var baseConf = 30 + fillRatio * 150 + mode4AiRound * 5;
      baseConf = Math.min(baseConf, 85);

      var found = false;
      var guesses = [];
      for (var i = 0; i < selectedWords.length && i < 12; i++) {
        var conf = baseConf + Math.random() * 15 - i * 3;
        // Boost for theme category words
        if (themeCategory && AI_WORD_CATEGORIES[themeCategory] &&
            AI_WORD_CATEGORIES[themeCategory].indexOf(selectedWords[i]) !== -1) {
          conf += 10;
        }
        var isCorrect = selectedWords[i] === targetWord;
        if (isCorrect) {
          conf = Math.min(conf + 30, 98);
          found = true;
        }
        guesses.push({
          word: selectedWords[i],
          confidence: Math.round(conf),
          isPrecise: true,
          isCorrect: isCorrect
        });
      }

      guesses.sort(function(a, b) { return b.confidence - a.confidence; });
      renderMode4AiGuesses(guesses);

      // Check if any guess is correct
      if (found) {
        var topGuess = guesses[0];
        if (topGuess && topGuess.isCorrect && topGuess.confidence >= 60) {
          endMode4Level(true);
          return;
        }
      }

      // Show a message if not correct
      showToast('AI 还没猜出来，继续画点细节吧！', 'warning');
    }

    function endMode4Level(guessed) {
      mode4Active = false;
      if (mode4Timer) clearInterval(mode4Timer);
      if (mode4AiInterval) { clearInterval(mode4AiInterval); mode4AiInterval = null; }

      const data = mode4LevelData[mode4Category];
      const level = data ? data.levels[mode4Level - 1] : null;
      const timeRatio = level ? mode4TimeLeft / level.time : 0;

      // Calculate stars: if guessed correctly, give stars based on time; otherwise time-based
      if (guessed) {
        mode4Stars = 1;
        if (timeRatio >= 0.7) mode4Stars = 3;
        else if (timeRatio >= 0.4) mode4Stars = 2;
      } else {
        if (timeRatio >= 0.7) mode4Stars = 3;
        else if (timeRatio >= 0.4) mode4Stars = 2;
        else if (timeRatio >= 0.1) mode4Stars = 1;
        else mode4Stars = 0;
      }

      // Update star display
      const starContainer = document.getElementById('mode4Stars');
      starContainer.innerHTML = '';
      for (let i = 0; i < 3; i++) {
        const span = document.createElement('span');
        span.className = 'star' + (i < mode4Stars ? ' filled' : '');
        span.textContent = '★';
        starContainer.appendChild(span);
      }

      // Score
      const levelScore = mode4Stars * 50 + (level ? mode4TimeLeft * 2 : 0);
      mode4Score += levelScore;

      showResultModal(
        guessed ? '🎉' : (mode4Stars > 0 ? '⭐' : '💔'),
        guessed ? 'AI 猜对了！' : (mode4Stars > 0 ? `获得 ${mode4Stars} 星！` : '时间到！'),
        `你画的是「${level ? level.word : ''}」<br>评价：<span class="highlight">${mode4Stars} 星</span> | 得分：<span class="highlight">+${levelScore}</span>`,
        mode4Stars > 0 ? '下一关' : '重试', '返回主题选择'
      );
    }

    // ============================================================
    // MODAL
    // ============================================================
    let resultModalCallback = null;

    function showResultModal(icon, title, body, btn1Text, btn2Text) {
      document.getElementById('resultIcon').textContent = icon;
      document.getElementById('resultTitle').textContent = title;
      document.getElementById('resultTitle').className = 'modal-title' + (title.includes('胜利') || title.includes('对') || title.includes('星') || title.includes('住') ? ' win' : ' lose');
      document.getElementById('resultBody').innerHTML = body;
      document.getElementById('resultBtn1').textContent = btn1Text || '继续';
      document.getElementById('resultBtn2').textContent = btn2Text || '返回';
      document.getElementById('resultModal').classList.add('show');
    }

    function closeResultModal() {
      document.getElementById('resultModal').classList.remove('show');
      // Handle mode-specific navigation
      if (currentMode === 'mode1') {
        mode1Active = false;
        if (mode1Timer) clearInterval(mode1Timer);
        document.getElementById('mode1StartBtn').disabled = false;
        document.getElementById('mode1StartBtn').textContent = '🎯 开始绘制';
      } else if (currentMode === 'mode2') {
        mode2Active = false;
        if (mode2Timer) clearInterval(mode2Timer);
        document.getElementById('mode2StartBtn').disabled = false;
        document.getElementById('mode2StartBtn').textContent = '🎨 AI 开始绘制';
      } else if (currentMode === 'mode3') {
        document.getElementById('mode3Lobby').style.display = 'block';
        document.getElementById('mode3GameArea').style.display = 'none';
        document.getElementById('mode3VotePanel').style.display = 'none';
        mode3GameActive = false;
      } else if (currentMode === 'mode4') {
        const data = mode4LevelData[mode4Category];
        const allDone = data && mode4Level > data.levels.length;
        if (allDone) {
          // All levels completed - restart from level 1
          mode4Level = 1;
          mode4Score = 0;
          mode4Unlocks = [];
          startMode4Level();
        } else if (mode4Stars > 0) {
          mode4Level++;
          startMode4Level();
        } else {
          document.getElementById('mode4CategoryPanel').style.display = 'block';
          document.getElementById('mode4GameArea').style.display = 'none';
          document.getElementById('mode4RewardsPanel').style.display = 'none';
        }
      }
    }

    // ============================================================
    // TOAST
    // ============================================================
    function showToast(msg, type) {
      const t = document.getElementById('toast');
      t.textContent = msg;
      t.className = 'toast';
      if (type === 'error') t.style.background = 'linear-gradient(135deg,#ef4444,#dc2626)';
      else if (type === 'warning') t.style.background = 'linear-gradient(135deg,#f59e0b,#d97706)';
      else t.style.background = 'linear-gradient(135deg,#667eea,#764ba2)';
      t.classList.add('show');
      setTimeout(() => t.classList.remove('show'), 2500);
    }

    // ============================================================
    // SOCKET.IO
    // ============================================================
    socket.on('draw_game_start', function(data) {
      showToast('游戏开始！');
    });

    socket.on('draw_round_start', function(data) {
      // Handle round data
      showToast('新回合开始！');
    });

    socket.on('draw_update', function(data) {
      // Handle drawing updates from other players
      if (data.username !== '<%= user.username %>') {
        addMode3ChatMessage('系统', `${data.username} 正在绘制...`);
      }
    });

    socket.on('draw_vote_start', function(data) {
      startMode3Vote();
    });

    socket.on('draw_result', function(data) {
      showResultModal(
        data.winner === '<%= user.username %>' ? '🎉' : '😅',
        data.winner === '<%= user.username %>' ? '你赢了！' : '你输了...',
        data.message || '游戏结束',
        '再来一局', '返回大厅'
      );
    });

    // ============================================================
    // INIT
    // ============================================================
    document.addEventListener('DOMContentLoaded', function() {
      // Init canvas for mode 1 (default active)
      setTimeout(() => initCanvas('mode1'), 200);
    });

    // Handle window resize (preserve canvas content)
    window.addEventListener('resize', function() {
      if (document.getElementById('mode1').classList.contains('active')) initCanvas('mode1', true);
      if (document.getElementById('mode2').classList.contains('active')) initCanvas('mode2', true);
      if (document.getElementById('mode3').classList.contains('active')) initCanvas('mode3', true);
      if (document.getElementById('mode4').classList.contains('active')) initCanvas('mode4', true);
    });

    // Enter key support for mode2 guess
    document.addEventListener('keydown', function(e) {
      if (e.key === 'Enter' && currentMode === 'mode2' && mode2Active) {
        submitMode2Guess();
      }
    });
  </script>
</body>
</html>