  <script src="/js/draw_recipes.js"></script>
  <script>
    const csrf = '<%= csrfToken %>';
    let socket;
    try {
      socket = io();
    } catch(e) {
      console.warn('Socket.io not available, multi-player features disabled');
      socket = { on: function(){}, emit: function(){}, id: 'offline' };
    }
    let currentMode = 'mode1';

    // ============================================================
    // CANVAS ENGINE
    // ============================================================
    const canvasStates = {};
    const canvasInitialized = {};

    /** Add event listeners to a canvas once */
    function setupCanvasListeners(mode) {
      const canvas = document.getElementById(mode + 'Canvas');
      if (!canvas || canvasInitialized[mode]) return;
      canvasInitialized[mode] = true;

      canvas.addEventListener('mousedown', e => startDraw(mode, e));
      canvas.addEventListener('mousemove', e => draw(mode, e));
      canvas.addEventListener('mouseup', () => stopDraw(mode));
      canvas.addEventListener('mouseleave', () => stopDraw(mode));

      canvas.addEventListener('touchstart', e => {
        e.preventDefault();
        const t = e.touches[0];
        const rect = canvas.getBoundingClientRect();
        startDraw(mode, { offsetX: t.clientX - rect.left, offsetY: t.clientY - rect.top });
      });
      canvas.addEventListener('touchmove', e => {
        e.preventDefault();
        const t = e.touches[0];
        const rect = canvas.getBoundingClientRect();
        draw(mode, { offsetX: t.clientX - rect.left, offsetY: t.clientY - rect.top });
      });
      canvas.addEventListener('touchend', e => { e.preventDefault(); stopDraw(mode); });
    }

    function initCanvas(mode, preserveContent) {
      const wrapper = document.getElementById(mode + 'CanvasWrapper');
      const canvas = document.getElementById(mode + 'Canvas');
      if (!canvas || !wrapper) return;

      const dpr = window.devicePixelRatio || 1;
      const w = wrapper.clientWidth;
      const h = wrapper.clientHeight;

      // Guard: don't init with zero dimensions
      if (w === 0 || h === 0) {
        setTimeout(() => initCanvas(mode, preserveContent), 100);
        return;
      }

      // Save existing content and state before re-initializing
      let oldDataUrl = null;
      let oldState = null;
      if (preserveContent && canvasStates[mode]) {
        oldDataUrl = canvas.toDataURL();
        oldState = Object.assign({}, canvasStates[mode]);
      }

      canvas.width = w * dpr;
      canvas.height = h * dpr;
      canvas.style.width = w + 'px';
      canvas.style.height = h + 'px';
      const ctx = canvas.getContext('2d');
      ctx.scale(dpr, dpr);

      // Set up listeners only once per canvas element
      setupCanvasListeners(mode);

      // Preserve existing state properties or create defaults
      const prev = canvasStates[mode] || {};
      canvasStates[mode] = {
        canvas, ctx, w, h,
        drawing: false,
        color: prev.color || '#000',
        brushSize: prev.brushSize || 4,
        eraser: prev.eraser || false,
        gridOn: prev.gridOn || false,
        undoStack: prev.undoStack || [],
        maxUndo: 30,
        lastX: 0, lastY: 0,
        strokeCount: 0,        // 跟踪笔画数量，用于AI猜词门槛
        strokeRects: []        // 每笔的包围盒 [{x1,y1,x2,y2}]
      };

      // Restore content if available
      if (oldDataUrl) {
        const img = new Image();
        img.onload = () => {
          ctx.clearRect(0, 0, w, h);
          ctx.drawImage(img, 0, 0, w, h);
        };
        img.src = oldDataUrl;
      } else {
        fillWhite(mode);
      }
    }

    function fillWhite(mode) {
      const s = canvasStates[mode];
      if (!s) return;
      s.ctx.fillStyle = '#fff';
      s.ctx.fillRect(0, 0, s.w, s.h);
      s.undoStack = [];
      s.strokeCount = 0;
      s.strokeRects = [];
    }

    function startDraw(mode, e) {
      const s = canvasStates[mode];
      if (!s) return;
      s.drawing = true;
      s.lastX = e.offsetX;
      s.lastY = e.offsetY;
      // Save state for undo
      s.undoStack.push(s.canvas.toDataURL());
      if (s.undoStack.length > s.maxUndo) s.undoStack.shift();
    }

    function draw(mode, e) {
      const s = canvasStates[mode];
      if (!s || !s.drawing) return;
      s.ctx.beginPath();
      s.ctx.moveTo(s.lastX, s.lastY);
      s.ctx.lineTo(e.offsetX, e.offsetY);
      s.ctx.strokeStyle = s.eraser ? '#fff' : s.color;
      s.ctx.lineWidth = s.eraser ? s.brushSize * 4 : s.brushSize;
      s.ctx.lineCap = 'round';
      s.ctx.lineJoin = 'round';
      s.ctx.stroke();
      s.lastX = e.offsetX;
      s.lastY = e.offsetY;
    }

    function stopDraw(mode) {
      const s = canvasStates[mode];
      if (!s) return;
      if (s.drawing) {
        s.strokeCount++;
      }
      s.drawing = false;
    }

    function setColor(mode, color) {
      const s = canvasStates[mode];
      if (!s) return;
      s.color = color;
      s.eraser = false;
      // Update UI
      document.getElementById(mode + 'ColorPicker').value = color;
      document.querySelectorAll('#' + mode + 'ColorPresets .color-preset').forEach(el => {
        el.classList.toggle('active', el.dataset.color === color);
      });
      const eraserBtn = document.getElementById(mode + 'Eraser');
      if (eraserBtn) eraserBtn.classList.remove('active');
    }

    function setBrush(mode, size) {
      const s = canvasStates[mode];
      if (!s) return;
      s.brushSize = size;
      document.querySelectorAll('#' + mode + 'Tools .brush-size-btn').forEach(el => {
        el.classList.toggle('active', parseInt(el.dataset.size) === size);
      });
    }

    function toggleEraser(mode) {
      const s = canvasStates[mode];
      if (!s) return;
      s.eraser = !s.eraser;
      document.getElementById(mode + 'Eraser').classList.toggle('active', s.eraser);
    }

    function undoDraw(mode) {
      const s = canvasStates[mode];
      if (!s || s.undoStack.length === 0) return;
      const img = new Image();
      img.onload = () => {
        s.ctx.clearRect(0, 0, s.w, s.h);
        s.ctx.drawImage(img, 0, 0, s.w, s.h);
      };
      img.src = s.undoStack.pop();
    }

    function clearCanvas(mode) {
      const s = canvasStates[mode];
      if (!s) return;
      s.undoStack.push(s.canvas.toDataURL());
      fillWhite(mode);
      showToast('画布已清空');
    }

    function toggleGrid(mode) {
      const s = canvasStates[mode];
      if (!s) return;
      s.gridOn = !s.gridOn;
      const wrapper = document.getElementById(mode + 'CanvasWrapper');
      wrapper.classList.toggle('grid-on', s.gridOn);
      document.getElementById(mode + 'GridBtn').classList.toggle('active', s.gridOn);
    }

    function saveCanvas(mode) {
      const s = canvasStates[mode];
      if (!s) return;
      const link = document.createElement('a');
      link.download = mode + '_drawing_' + Date.now() + '.png';
      link.href = s.canvas.toDataURL('image/png');
      link.click();
      showToast('已保存');
    }

    function getCanvasData(mode) {
      const s = canvasStates[mode];
      if (!s) return null;
      return s.canvas.toDataURL();
    }

    function loadCanvasData(mode, dataUrl) {
      const s = canvasStates[mode];
      if (!s) return;
      const img = new Image();
      img.onload = () => {
        s.ctx.clearRect(0, 0, s.w, s.h);
        s.ctx.drawImage(img, 0, 0, s.w, s.h);
      };
      img.src = dataUrl;
    }

