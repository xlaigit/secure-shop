    // MODE SWITCHING
    // ============================================================
    function switchMode(mode) {
      currentMode = mode;
      document.querySelectorAll('.mode-tab').forEach(t => t.classList.toggle('active', t.dataset.mode === mode));
      document.querySelectorAll('.game-layout').forEach(l => l.classList.toggle('active', l.id === mode));
      // Re-init canvas after layout becomes visible (preserve content)
      setTimeout(() => {
        if (mode === 'mode1') initCanvas('mode1', true);
        else if (mode === 'mode2') initCanvas('mode2', true);
        else if (mode === 'mode3') initCanvas('mode3', true);
        else if (mode === 'mode4') initCanvas('mode4', true);
      }, 100);
    }

    // ============================================================
    // MODE 1: 你画AI猜
    // ============================================================
    let mode1Active = false;
    let mode1Timer = null;
