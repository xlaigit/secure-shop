              <button onclick="sendMode3Chat()">发送</button>
            </div>
          </div>
        </div>
      </div>
    </div>

    <!-- ======================================================================== -->
    <!-- MODE 4: 主题闯关 -->
    <!-- ======================================================================== -->
    <div class="game-layout" id="mode4">
      <div class="game-main">
        <!-- Category Selection -->
        <div class="panel" id="mode4CategoryPanel">
          <div class="panel-title">选择主题</div>
          <div class="category-grid">
            <div class="category-card" data-cat="动漫" onclick="selectMode4Category('动漫')">
              <div class="cat-icon">📺</div>
              <div class="cat-name">动漫</div>
              <div class="cat-desc">动漫角色与场景</div>
            </div>
            <div class="category-card" data-cat="物品" onclick="selectMode4Category('物品')">
              <div class="cat-icon">📦</div>
              <div class="cat-name">物品</div>
              <div class="cat-desc">日常物品</div>
            </div>
            <div class="category-card" data-cat="成语" onclick="selectMode4Category('成语')">
              <div class="cat-icon">📜</div>
              <div class="cat-name">成语</div>
              <div class="cat-desc">四字成语</div>
            </div>
            <div class="category-card" data-cat="风景" onclick="selectMode4Category('风景')">
              <div class="cat-icon">🌄</div>
              <div class="cat-name">风景</div>
              <div class="cat-desc">自然与建筑</div>
            </div>
          </div>
        </div>

        <!-- Game Area -->
        <div class="panel" id="mode4GameArea" style="display:none">
          <div class="level-progress" id="mode4LevelProgress"></div>

          <div class="word-display" style="margin-bottom:12px">
            <div class="category-tag" id="mode4CategoryTag">动漫</div>
            <div class="word" id="mode4Word">准备开始</div>
            <div class="hint-text" id="mode4WordHint">第 1 关 · 难度：简单</div>
          </div>

          <div class="canvas-wrapper" id="mode4CanvasWrapper">
            <canvas id="mode4Canvas"></canvas>
          </div>

          <div class="tools-bar" id="mode4Tools">
            <div class="tool-group">
              <span class="tool-group-label">颜色</span>
              <div class="color-picker-wrap">
                <input type="color" id="mode4ColorPicker" value="#000000" onchange="setColor('mode4', this.value)">
              </div>
              <div class="color-presets" id="mode4ColorPresets">
                <div class="color-preset active" style="background:#000" data-color="#000" onclick="setColor('mode4','#000')"></div>
                <div class="color-preset" style="background:#ff6b6b" data-color="#ff6b6b" onclick="setColor('mode4','#ff6b6b')"></div>
                <div class="color-preset" style="background:#ffd700" data-color="#ffd700" onclick="setColor('mode4','#ffd700')"></div>
                <div class="color-preset" style="background:#2ecc71" data-color="#2ecc71" onclick="setColor('mode4','#2ecc71')"></div>
                <div class="color-preset" style="background:#3498db" data-color="#3498db" onclick="setColor('mode4','#3498db')"></div>
                <div class="color-preset" style="background:#a29bfe" data-color="#a29bfe" onclick="setColor('mode4','#a29bfe')"></div>
                <div class="color-preset" style="background:#fff" data-color="#fff" onclick="setColor('mode4','#fff')"></div>
              </div>
            </div>
            <div class="tool-group">
              <span class="tool-group-label">大小</span>
