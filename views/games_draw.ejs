    // 将所有词打平为通用池（用于随机选词）
    function flattenWordPool() {
      var all = [];
      var cats = Object.keys(AI_WORD_CATEGORIES);
      for (var ci = 0; ci < cats.length; ci++) {
        all = all.concat(AI_WORD_CATEGORIES[cats[ci]]);
      }
      return all;
    }
    var AI_GENERAL_WORD_POOL = flattenWordPool();

    // 提取画布像素特征（只做静态分析，不识别笔顺/运笔速度）
    function analyzeDrawing(mode) {
      var s = canvasStates[mode];
      if (!s) return null;
      var canvas = s.canvas;
      var ctx = s.ctx;
      var w = s.w, h = s.h;
      var imageData = ctx.getImageData(0, 0, w, h);
      var data = imageData.data;

      // 1. 计算非白色像素占比
      var nonWhitePixels = 0;
      var totalPixels = w * h;
      for (var i = 0; i < data.length; i += 4) {
        if (data[i] < 250 || data[i+1] < 250 || data[i+2] < 250) {
          nonWhitePixels++;
        }
      }
      var fillRatio = nonWhitePixels / totalPixels;

      // 2. 计算像素分布（判断画布内容集中在哪个区域）
      var minX = w, maxX = 0, minY = h, maxY = 0;
      var pixelCount = 0;
      for (var row = 0; row < h; row += 2) {
        for (var col = 0; col < w; col += 2) {
          var idx = (row * w + col) * 4;
          if (data[idx] < 250 || data[idx+1] < 250 || data[idx+2] < 250) {
            pixelCount++;
            if (col < minX) minX = col;
            if (col > maxX) maxX = col;
            if (row < minY) minY = row;
            if (row > maxY) maxY = row;
          }
        }
      }
      var contentWidth = (maxX - minX) / w;
      var contentHeight = (maxY - minY) / h;
      var contentArea = contentWidth * contentHeight;

      // 3. 水平/垂直线条检测
      var horizontalLines = 0, verticalLines = 0;
      var minLineLen = Math.min(w, h) * 0.12;

      // 水平扫描
      for (var row = 0; row < h; row += 3) {
        var inLine = false, lineLen = 0;
        for (var col = 0; col < w; col++) {
          var idx = (row * w + col) * 4;
          var isPixel = data[idx] < 250 || data[idx+1] < 250 || data[idx+2] < 250;
          if (isPixel) { if (!inLine) { inLine = true; lineLen = 0; } lineLen++; }
          else { if (inLine && lineLen >= minLineLen) horizontalLines++; inLine = false; lineLen = 0; }
        }
        if (inLine && lineLen >= minLineLen) horizontalLines++;
      }
      // 垂直扫描
      for (var col = 0; col < w; col += 3) {
        var inLine = false, lineLen = 0;
        for (var row = 0; row < h; row++) {
          var idx = (row * w + col) * 4;
          var isPixel = data[idx] < 250 || data[idx+1] < 250 || data[idx+2] < 250;
          if (isPixel) { if (!inLine) { inLine = true; lineLen = 0; } lineLen++; }
          else { if (inLine && lineLen >= minLineLen) verticalLines++; inLine = false; lineLen = 0; }
        }
        if (inLine && lineLen >= minLineLen) verticalLines++;
      }

      // 4. 检测画面形状倾向
      var isHorizontalDominant = horizontalLines > verticalLines * 1.5;
      var isVerticalDominant = verticalLines > horizontalLines * 1.5;
      var isBalanced = !isHorizontalDominant && !isVerticalDominant;

      // 5. 检测是否有封闭区域（圆形/矩形特征）
      var closedShapes = 0;
      for (var row = 3; row < h - 3; row += 8) {
        for (var col = 3; col < w - 3; col += 8) {
          var idx = (row * w + col) * 4;
          var isWhite = data[idx] > 240 && data[idx+1] > 240 && data[idx+2] > 240;
          if (isWhite) {
            var up = data[((row-3)*w + col)*4] < 240;
            var down = data[((row+3)*w + col)*4] < 240;
            var left = data[(row*w + col-3)*4] < 240;
            var right = data[(row*w + col+3)*4] < 240;
            if (up && down && left && right) closedShapes++;
          }
        }
      }

      // 6. 判断画面复杂度
      var complexity = 'empty';
      if (fillRatio > 0.15) complexity = 'complex';
      else if (fillRatio > 0.05) complexity = 'moderate';
      else if (fillRatio > 0.01) complexity = 'simple';

      // 7. 判断是否有"脸"的特征（圆形+内部点）
      var hasFaceFeatures = false;
      if (closedShapes >= 1 && fillRatio > 0.03 && fillRatio < 0.2) {
        hasFaceFeatures = true;
      }

      // 8. 判断是否有"大面积涂色"特征
      var hasLargeFill = fillRatio > 0.25;

      // 9. 判断是否有"细长形"特征
      var hasThinShape = (contentWidth > 0.6 && contentHeight < 0.3) || (contentHeight > 0.6 && contentWidth < 0.3);

      return {
        strokeCount: s.strokeCount,
        fillRatio: fillRatio,
        contentWidth: contentWidth,
        contentHeight: contentHeight,
        contentArea: contentArea,
        horizontalLines: horizontalLines,
        verticalLines: verticalLines,
        isHorizontalDominant: isHorizontalDominant,
        isVerticalDominant: isVerticalDominant,
        isBalanced: isBalanced,
        closedShapes: closedShapes,
        complexity: complexity,
        hasFaceFeatures: hasFaceFeatures,
        hasLargeFill: hasLargeFill,
        hasThinShape: hasThinShape
      };
    }

    // 根据画布特征推荐候选词类别
    function suggestCategories(features) {
      var suggestions = [];

      if (!features || features.fillRatio < 0.005) {
        return ['抽象符号', '日常物品']; // 默认
      }

      // 大面积涂色 → 圆形/大块物体
      if (features.hasLargeFill) {
        suggestions.push('食物');
        suggestions.push('自然风景');
      }

      // 有封闭区域 → 可能的圆形物体
      if (features.closedShapes >= 2) {
        suggestions.push('日常物品');
        suggestions.push('食物');
        suggestions.push('自然风景');
      }

      // 水平主导 → 长条形物体
      if (features.isHorizontalDominant) {
        suggestions.push('交通工具');
        suggestions.push('建筑场所');
      }

      // 垂直主导 → 高的物体
      if (features.isVerticalDominant) {
        suggestions.push('建筑场所');
        suggestions.push('动物');
        suggestions.push('自然风景');
      }

      // 平衡画面 → 可能的动物/人物
      if (features.isBalanced && features.fillRatio > 0.03) {
        suggestions.push('动物');
        suggestions.push('人物动作');
        suggestions.push('动漫人物');
      }

      // 有脸特征
      if (features.hasFaceFeatures) {
        suggestions.push('动漫人物');
      }

      // 细长形状
      if (features.hasThinShape) {
        suggestions.push('日常物品');
        suggestions.push('交通工具');
      }

      // 填充率很低（只有几笔）
      if (features.fillRatio < 0.02) {
        suggestions.push('抽象符号');
        suggestions.push('日常物品');
      }

      // 去重
      var unique = [];
      var seen = {};
      for (var i = 0; i < suggestions.length; i++) {
        if (!seen[suggestions[i]]) {
          seen[suggestions[i]] = true;
          unique.push(suggestions[i]);
        }
      }
      // 如果没推任何类别，补默认
      if (unique.length === 0) unique = ['日常物品', '食物', '动物'];
      return unique;
    }

    // 从推荐类别中选词
    function pickWordsFromCategories(categories, count, excludeWord) {
      var candidates = [];
      for (var ci = 0; ci < categories.length; ci++) {
        var cat = categories[ci];
        var words = AI_WORD_CATEGORIES[cat] || [];
        for (var wi = 0; wi < words.length; wi++) {
          if (words[wi] !== excludeWord) {
            candidates.push(words[wi]);
          }
        }
      }
      // 随机打乱选前N个
      var shuffled = candidates.sort(function() { return Math.random() - 0.5; });
      return shuffled.slice(0, count);
    }

    // 笼统模糊描述库（笔画不足3笔时使用）
    var VAGUE_DESCRIPTIONS = [
