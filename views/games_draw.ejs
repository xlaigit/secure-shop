<!DOCTYPE html>
<html lang="zh-CN">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>你画我猜 - 游戏中心</title>
  <link rel="icon" href="data:image/svg+xml,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 100 100'><text y='.9em' font-size='90'>🎨</text></svg>">
  <style>
    * { margin: 0; padding: 0; box-sizing: border-box; }
    body {
      font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
      background: linear-gradient(135deg, #0d0d1a, #1a0a2e, #16213e, #0d0d1a);
      background-size: 400% 400%;
      animation: gradientShift 15s ease infinite;
      min-height: 100vh; color: #fff;
    }
    @keyframes gradientShift {
      0% { background-position: 0% 50%; }
      50% { background-position: 100% 50%; }
      100% { background-position: 0% 50%; }
    }

    nav {
      background: rgba(0,0,0,0.4); backdrop-filter: blur(16px);
      padding: 12px 24px; display: flex; align-items: center; gap: 16px;
      border-bottom: 1px solid rgba(255,255,255,0.08);
      position: sticky; top: 0; z-index: 100;
    }
    nav a { color: rgba(255,255,255,0.7); text-decoration: none; font-size: 14px; padding: 6px 14px; border-radius: 8px; transition: all 0.2s; }
    nav a:hover { background: rgba(255,255,255,0.1); color: #fff; }
    nav .brand { font-size: 20px; font-weight: 700; background: linear-gradient(90deg, #ff6b6b, #ffd700, #6c5ce7); -webkit-background-clip: text; -webkit-text-fill-color: transparent; margin-right: auto; }
    nav .balance { background: rgba(255,215,0,0.15); color: #ffd700; padding: 6px 16px; border-radius: 20px; font-size: 14px; font-weight: 600; }

    .container { max-width: 1400px; margin: 0 auto; padding: 20px; }

    /* ============ Title ============ */
    .page-header { text-align: center; margin-bottom: 24px; }
    .page-header h1 { font-size: 36px; font-weight: 800; background: linear-gradient(90deg, #ff6b6b, #ffd700, #6c5ce7); -webkit-background-clip: text; -webkit-text-fill-color: transparent; }
    .page-header p { color: rgba(255,255,255,0.5); font-size: 14px; margin-top: 4px; }

    /* ============ Mode Tabs ============ */
    .mode-tabs {
      display: flex; gap: 8px; justify-content: center; margin-bottom: 24px; flex-wrap: wrap;
    }
    .mode-tab {
      padding: 10px 24px; border: 1px solid rgba(255,255,255,0.12);
      border-radius: 30px; background: rgba(0,0,0,0.3);
      color: rgba(255,255,255,0.6); font-size: 14px; font-weight: 600;
      cursor: pointer; transition: all 0.3s; backdrop-filter: blur(8px);
    }
    .mode-tab:hover { background: rgba(255,255,255,0.08); color: #fff; }
    .mode-tab.active { background: linear-gradient(135deg, #6c5ce7, #a29bfe); color: #fff; border-color: transparent; box-shadow: 0 4px 20px rgba(108,92,231,0.3); }
    .mode-tab .badge { display: inline-block; background: rgba(255,215,0,0.2); color: #ffd700; font-size: 10px; padding: 2px 8px; border-radius: 10px; margin-left: 6px; vertical-align: middle; }

    /* ============ Game Layout ============ */
    .game-layout { display: none; gap: 20px; }
    .game-layout.active { display: flex; }

    .game-main { flex: 1; min-width: 0; }
    .game-sidebar { width: 300px; flex-shrink: 0; }

    /* ============ Glassmorphism Panel ============ */
    .panel {
      background: rgba(0,0,0,0.35); backdrop-filter: blur(12px);
      border: 1px solid rgba(255,255,255,0.08);
      border-radius: 20px; padding: 20px; margin-bottom: 16px;
    }
    .panel-title {
      font-size: 13px; font-weight: 700; color: rgba(255,255,255,0.5);
      text-transform: uppercase; letter-spacing: 1px; margin-bottom: 12px;
    }

    /* ============ Canvas Area ============ */
    .canvas-wrapper {
      position: relative; background: #fff; border-radius: 16px;
      overflow: hidden; aspect-ratio: 4/3; cursor: crosshair;
    }
    .canvas-wrapper canvas {
      display: block; width: 100%; height: 100%;
    }
    .canvas-wrapper.grid-on canvas {
      background-image:
        linear-gradient(rgba(0,0,0,0.05) 1px, transparent 1px),
        linear-gradient(90deg, rgba(0,0,0,0.05) 1px, transparent 1px);
      background-size: 20px 20px;
    }

    /* ============ Drawing Tools ============ */
    .tools-bar {
      display: flex; gap: 8px; align-items: center; flex-wrap: wrap; margin-top: 12px;
    }
    .tools-bar .tool-group {
      display: flex; gap: 4px; align-items: center;
      background: rgba(0,0,0,0.2); border-radius: 12px; padding: 4px 6px;
    }
    .tools-bar .tool-group-label { font-size: 10px; color: rgba(255,255,255,0.4); padding: 0 4px; }
    .tool-btn {
      width: 32px; height: 32px; border-radius: 8px; border: 1px solid rgba(255,255,255,0.1);
      background: rgba(255,255,255,0.05); color: rgba(255,255,255,0.7); cursor: pointer;
      display: flex; align-items: center; justify-content: center; font-size: 14px; transition: all 0.2s;
    }
    .tool-btn:hover { background: rgba(255,255,255,0.12); color: #fff; }
    .tool-btn.active { background: rgba(108,92,231,0.3); border-color: #6c5ce7; color: #fff; }
    .tool-btn.danger { color: #ff6b6b; }
    .tool-btn.danger:hover { background: rgba(255,107,107,0.15); }

    .brush-size-btn {
      width: 28px; height: 28px; border-radius: 50%; border: 2px solid rgba(255,255,255,0.15);
      background: transparent; cursor: pointer; transition: all 0.2s; display: flex; align-items: center; justify-content: center;
    }
    .brush-size-btn .dot {
      border-radius: 50%; background: rgba(255,255,255,0.6); transition: all 0.2s;
    }
    .brush-size-btn:hover { border-color: rgba(255,255,255,0.3); }
    .brush-size-btn.active { border-color: #6c5ce7; background: rgba(108,92,231,0.15); }
    .brush-size-btn.active .dot { background: #a29bfe; }

    .color-picker-wrap {
      position: relative; width: 32px; height: 32px; overflow: hidden; border-radius: 8px; border: 2px solid rgba(255,255,255,0.15); cursor: pointer;
    }
    .color-picker-wrap input[type="color"] {
      position: absolute; top: -4px; left: -4px; width: calc(100% + 8px); height: calc(100% + 8px); cursor: pointer; border: none; padding: 0;
    }

    .color-presets {
      display: flex; gap: 4px; align-items: center;
    }
    .color-preset {
      width: 20px; height: 20px; border-radius: 50%; border: 2px solid rgba(255,255,255,0.1); cursor: pointer; transition: all 0.2s;
    }
    .color-preset:hover { transform: scale(1.2); }
    .color-preset.active { border-color: #fff; box-shadow: 0 0 8px rgba(255,255,255,0.3); }

    /* ============ Word Display ============ */
    .word-display {
      text-align: center; padding: 16px; border-radius: 16px;
      background: rgba(108,92,231,0.1); border: 1px solid rgba(108,92,231,0.2);
    }
    .word-display .word { font-size: 28px; font-weight: 800; color: #ffd700; letter-spacing: 4px; }
    .word-display .hint-text { font-size: 13px; color: rgba(255,255,255,0.5); margin-top: 4px; }
    .word-display .category-tag {
      display: inline-block; background: rgba(108,92,231,0.2); color: #a29bfe;
      font-size: 11px; padding: 2px 12px; border-radius: 10px; margin-top: 6px;
    }

    /* ============ AI Guess Panel ============ */
    .ai-guesses { display: flex; flex-direction: column; gap: 6px; }
    .ai-guess-item {
      display: flex; align-items: center; gap: 10px;
      padding: 8px 12px; border-radius: 10px;
      background: rgba(0,0,0,0.2); transition: all 0.3s;
    }
    .ai-guess-item .guess-text { flex: 1; font-size: 14px; font-weight: 600; }
    .ai-guess-item .guess-bar-wrap {
      width: 100px; height: 6px; background: rgba(255,255,255,0.1); border-radius: 3px; overflow: hidden;
    }
    .ai-guess-item .guess-bar {
      height: 100%; border-radius: 3px; transition: width 0.5s ease;
    }
    .ai-guess-item .guess-pct { font-size: 12px; font-weight: 700; min-width: 40px; text-align: right; }
    .ai-guess-item.high-confidence .guess-bar { background: linear-gradient(90deg, #2ecc71, #27ae60); }
    .ai-guess-item.high-confidence .guess-pct { color: #2ecc71; }
    .ai-guess-item.medium-confidence .guess-bar { background: linear-gradient(90deg, #f39c12, #e67e22); }
    .ai-guess-item.medium-confidence .guess-pct { color: #f39c12; }
    .ai-guess-item.low-confidence .guess-bar { background: linear-gradient(90deg, #e74c3c, #c0392b); }
    .ai-guess-item.low-confidence .guess-pct { color: #e74c3c; }
    .guesses-header { font-size: 13px; font-weight: 600; color: #374151; margin-bottom: 6px; }
    .guesses-list { display: flex; flex-direction: column; gap: 4px; }
    .guess-item { display: flex; align-items: center; padding: 5px 10px; border-radius: 8px; font-size: 13px; background: rgba(255,255,255,0.05); }
    .guess-item.high-confidence { background: rgba(46,204,113,0.12); }
    .guess-item.medium-confidence { background: rgba(243,156,18,0.12); }
    .guess-item.low-confidence { background: rgba(231,76,60,0.08); }
    .guess-word { flex: 1; font-weight: 600; }
    .guess-conf { font-size: 12px; font-weight: 700; min-width: 36px; text-align: right; }
    .guess-item.high-confidence .guess-conf { color: #2ecc71; }
    .guess-item.medium-confidence .guess-conf { color: #f39c12; }
    .guess-item.low-confidence .guess-conf { color: #e74c3c; }

    .ai-thinking {
      display: flex; align-items: center; gap: 8px; padding: 10px; color: rgba(255,255,255,0.5); font-size: 13px;
    }
    .ai-thinking .dots span {
      display: inline-block; width: 6px; height: 6px; border-radius: 50%;
      background: rgba(255,255,255,0.3); margin: 0 2px; animation: dotBounce 1.4s ease infinite;
    }
    .ai-thinking .dots span:nth-child(2) { animation-delay: 0.2s; }
    .ai-thinking .dots span:nth-child(3) { animation-delay: 0.4s; }
    @keyframes dotBounce {
      0%, 80%, 100% { transform: scale(0.6); }
      40% { transform: scale(1); background: rgba(255,255,255,0.6); }
    }

    /* ============ Score & Timer ============ */
    .stats-bar {
      display: flex; gap: 16px; justify-content: center; flex-wrap: wrap;
    }
    .stat-item {
      text-align: center; padding: 8px 20px;
      background: rgba(0,0,0,0.2); border-radius: 12px; min-width: 80px;
    }
    .stat-item .stat-value { font-size: 24px; font-weight: 800; color: #ffd700; }
    .stat-item .stat-label { font-size: 11px; color: rgba(255,255,255,0.4); text-transform: uppercase; letter-spacing: 1px; }
    .stat-item .stat-value.timer-warning { color: #ff6b6b; animation: pulse 0.5s ease infinite; }
    @keyframes pulse {
      0%, 100% { opacity: 1; }
      50% { opacity: 0.5; }
    }

    /* ============ Guess Input (Mode 2) ============ */
    .guess-input-row {
      display: flex; gap: 8px;
    }
    .guess-input-row input {
      flex: 1; background: rgba(0,0,0,0.4); border: 2px solid rgba(255,255,255,0.12);
      border-radius: 12px; padding: 10px 16px; color: #fff; font-size: 16px; outline: none;
    }
    .guess-input-row input:focus { border-color: #6c5ce7; }
    .guess-input-row button {
      padding: 10px 24px; border: none; border-radius: 12px;
      background: linear-gradient(90deg, #6c5ce7, #a29bfe); color: #fff;
      font-size: 14px; font-weight: 600; cursor: pointer; transition: all 0.2s;
    }
    .guess-input-row button:hover { transform: scale(1.05); }
    .guess-input-row button:disabled { opacity: 0.4; cursor: not-allowed; transform: none; }
    .guess-input-row button.secondary { background: rgba(255,255,255,0.1); color: rgba(255,255,255,0.7); }
    .guess-input-row button.secondary:hover { background: rgba(255,255,255,0.15); }

    .hint-btn {
      padding: 10px 16px; border: 1px solid rgba(255,215,0,0.3); border-radius: 12px;
      background: rgba(255,215,0,0.1); color: #ffd700; font-size: 13px; font-weight: 600;
      cursor: pointer; transition: all 0.2s;
    }
    .hint-btn:hover { background: rgba(255,215,0,0.2); }
    .hint-btn:disabled { opacity: 0.4; cursor: not-allowed; }

    /* ============ Chat Box ============ */
    .chat-box {
      display: flex; flex-direction: column; height: 300px;
    }
    .chat-messages {
      flex: 1; overflow-y: auto; padding: 8px; margin-bottom: 8px;
      display: flex; flex-direction: column; gap: 4px;
    }
    .chat-messages::-webkit-scrollbar { width: 4px; }
    .chat-messages::-webkit-scrollbar-thumb { background: rgba(255,255,255,0.15); border-radius: 2px; }
    .chat-msg {
      padding: 6px 10px; border-radius: 10px; font-size: 13px;
      background: rgba(255,255,255,0.05); max-width: 90%;
    }
    .chat-msg .chat-user { font-weight: 700; color: #a29bfe; font-size: 11px; }
    .chat-msg .chat-text { color: rgba(255,255,255,0.8); }
    .chat-msg.system { background: rgba(255,215,0,0.08); text-align: center; }
    .chat-msg.system .chat-text { color: #ffd700; font-size: 12px; }

    .chat-input-row {
      display: flex; gap: 6px;
    }
    .chat-input-row input {
      flex: 1; background: rgba(0,0,0,0.4); border: 1px solid rgba(255,255,255,0.1);
      border-radius: 10px; padding: 8px 12px; color: #fff; font-size: 13px; outline: none;
    }
    .chat-input-row input:focus { border-color: #6c5ce7; }
    .chat-input-row button {
      padding: 8px 14px; border: none; border-radius: 10px;
      background: linear-gradient(90deg, #6c5ce7, #a29bfe); color: #fff;
      font-size: 13px; font-weight: 600; cursor: pointer; transition: all 0.2s;
    }
    .chat-input-row button:hover { transform: scale(1.05); }

    /* ============ Player List (Mode 3) ============ */
    .player-list { display: flex; flex-direction: column; gap: 6px; }
    .player-item {
      display: flex; align-items: center; gap: 10px;
      padding: 8px 12px; border-radius: 10px;
      background: rgba(0,0,0,0.2); transition: all 0.2s;
    }
    .player-item .player-avatar {
      width: 32px; height: 32px; border-radius: 50%;
      background: linear-gradient(135deg, #6c5ce7, #a29bfe);
      display: flex; align-items: center; justify-content: center;
      font-size: 14px; font-weight: 700; color: #fff;
    }
    .player-item .player-name { flex: 1; font-size: 14px; font-weight: 600; }
    .player-item .player-status { font-size: 11px; color: rgba(255,255,255,0.4); }
    .player-item .player-status.done { color: #2ecc71; }
    .player-item .player-status.undercover { color: #ff6b6b; }
    .player-item.me { border: 1px solid rgba(108,92,231,0.3); }

    /* ============ Vote Phase ============ */
    .vote-panel { text-align: center; }
    .vote-panel p { margin-bottom: 12px; font-size: 14px; color: rgba(255,255,255,0.7); }
    .vote-options {
      display: flex; flex-wrap: wrap; gap: 8px; justify-content: center;
    }
    .vote-option {
      padding: 8px 20px; border: 1px solid rgba(255,255,255,0.15); border-radius: 30px;
      background: rgba(0,0,0,0.2); color: #fff; font-size: 14px; font-weight: 600;
      cursor: pointer; transition: all 0.2s;
    }
    .vote-option:hover { background: rgba(108,92,231,0.2); border-color: #6c5ce7; }
    .vote-option:disabled { opacity: 0.4; cursor: not-allowed; }

    /* ============ Category Select (Mode 4) ============ */
    .category-grid {
      display: grid; grid-template-columns: repeat(auto-fill, minmax(120px, 1fr)); gap: 10px;
    }
    .category-card {
      padding: 20px 12px; text-align: center; border-radius: 16px;
      background: rgba(0,0,0,0.2); border: 1px solid rgba(255,255,255,0.08);
      cursor: pointer; transition: all 0.3s;
    }
    .category-card:hover { background: rgba(108,92,231,0.1); border-color: rgba(108,92,231,0.3); transform: translateY(-2px); }
    .category-card.active { background: rgba(108,92,231,0.15); border-color: #6c5ce7; box-shadow: 0 4px 20px rgba(108,92,231,0.2); }
    .category-card .cat-icon { font-size: 32px; margin-bottom: 6px; }
    .category-card .cat-name { font-size: 13px; font-weight: 600; color: rgba(255,255,255,0.8); }
    .category-card .cat-desc { font-size: 11px; color: rgba(255,255,255,0.4); margin-top: 2px; }
    .category-card.locked { opacity: 0.5; cursor: not-allowed; }
    .category-card.locked .cat-icon { filter: grayscale(1); }

    /* ============ Level Progress ============ */
    .level-progress {
      display: flex; gap: 8px; align-items: center; justify-content: center; margin-bottom: 16px;
    }
    .level-dot {
      width: 36px; height: 36px; border-radius: 50%;
      border: 2px solid rgba(255,255,255,0.12);
      display: flex; align-items: center; justify-content: center;
      font-size: 14px; font-weight: 700; transition: all 0.3s;
    }
    .level-dot.completed { border-color: #2ecc71; background: rgba(46,204,113,0.1); color: #2ecc71; }
    .level-dot.current { border-color: #ffd700; background: rgba(255,215,0,0.1); color: #ffd700; animation: pulse 1s ease infinite; }
    .level-dot.locked { color: rgba(255,255,255,0.2); }
    .level-line { width: 30px; height: 2px; background: rgba(255,255,255,0.1); }
    .level-line.completed { background: #2ecc71; }

    /* ============ Star Rating ============ */
    .stars { display: flex; gap: 4px; justify-content: center; }
    .star { font-size: 28px; color: rgba(255,255,255,0.15); transition: all 0.3s; }
    .star.filled { color: #ffd700; text-shadow: 0 0 10px rgba(255,215,0,0.3); }
    .star.half { position: relative; }
    .star.half::before { content: '★'; position: absolute; left: 0; width: 50%; overflow: hidden; color: #ffd700; }

    /* ============ Unlock Rewards ============ */
    .rewards-grid {
      display: grid; grid-template-columns: repeat(auto-fill, minmax(80px, 1fr)); gap: 8px;
    }
    .reward-item {
      text-align: center; padding: 10px 6px; border-radius: 12px;
      background: rgba(0,0,0,0.2); border: 1px solid rgba(255,255,255,0.06);
      transition: all 0.3s;
    }
    .reward-item.unlocked { border-color: rgba(255,215,0,0.3); background: rgba(255,215,0,0.05); }
    .reward-item .reward-icon { font-size: 24px; }
    .reward-item .reward-name { font-size: 10px; color: rgba(255,255,255,0.5); margin-top: 4px; }
    .reward-item.unlocked .reward-name { color: #ffd700; }

    /* ============ Modal ============ */
    .modal-overlay {
      display: none; position: fixed; inset: 0; z-index: 999;
      background: rgba(0,0,0,0.7); backdrop-filter: blur(8px);
      align-items: center; justify-content: center;
    }
    .modal-overlay.show { display: flex; }
    .modal {
      background: linear-gradient(135deg, #1a1a2e, #16213e);
      border: 1px solid rgba(255,255,255,0.1);
      border-radius: 24px; padding: 36px; max-width: 500px; width: 90%;
      text-align: center; animation: modalIn 0.3s ease;
    }
    @keyframes modalIn {
      from { transform: scale(0.8); opacity: 0; }
      to { transform: scale(1); opacity: 1; }
    }
    .modal .modal-icon { font-size: 64px; margin-bottom: 12px; }
    .modal .modal-title { font-size: 28px; font-weight: 800; margin-bottom: 8px; }
    .modal .modal-title.win { color: #2ecc71; }
    .modal .modal-title.lose { color: #ff6b6b; }
    .modal .modal-body { color: rgba(255,255,255,0.7); font-size: 14px; margin-bottom: 20px; line-height: 1.6; }
    .modal .modal-body .highlight { color: #ffd700; font-weight: 700; }
    .modal .modal-btn {
      padding: 12px 36px; border: none; border-radius: 30px;
      background: linear-gradient(90deg, #6c5ce7, #a29bfe); color: #fff;
      font-size: 16px; font-weight: 700; cursor: pointer; transition: all 0.2s;
    }
    .modal .modal-btn:hover { transform: scale(1.05); }
    .modal .modal-btn.secondary { background: rgba(255,255,255,0.1); margin-left: 10px; }
    .modal .modal-btn.secondary:hover { background: rgba(255,255,255,0.15); }

    /* ============ Toast ============ */
    .toast {
      position: fixed; top: 80px; left: 50%; transform: translateX(-50%);
      background: rgba(0,0,0,0.85); color: #fff; padding: 12px 28px;
      border-radius: 12px; font-size: 15px; z-index: 9999;
      opacity: 0; transition: opacity 0.3s; pointer-events: none;
    }
    .toast.show { opacity: 1; }

    /* ============ Responsive ============ */
    @media (max-width: 900px) {
      .game-layout.active { flex-direction: column; }
      .game-sidebar { width: 100%; }
      .game-sidebar .panel { margin-bottom: 12px; }
    }

    /* ============ Empty State ============ */
    .empty-state { text-align: center; padding: 40px 20px; }
    .empty-state .empty-icon { font-size: 48px; margin-bottom: 12px; opacity: 0.5; }
    .empty-state p { color: rgba(255,255,255,0.4); font-size: 14px; }

    /* ============ Undercover Role Reveal ============ */
    .role-reveal {
      text-align: center; padding: 20px; border-radius: 16px;
      background: rgba(255,215,0,0.08); border: 1px solid rgba(255,215,0,0.2);
      margin-bottom: 12px;
    }
    .role-reveal .role-label { font-size: 12px; color: rgba(255,255,255,0.5); text-transform: uppercase; letter-spacing: 2px; }
    .role-reveal .role-word { font-size: 24px; font-weight: 800; color: #ffd700; margin-top: 4px; }

    /* ============ Lobby (Pre-game) ============ */
    .lobby-section {
      text-align: center; padding: 40px 20px;
    }
    .lobby-section .lobby-title { font-size: 20px; font-weight: 700; margin-bottom: 12px; }
    .lobby-section .lobby-desc { color: rgba(255,255,255,0.5); font-size: 13px; margin-bottom: 20px; }
    .lobby-btn {
      padding: 14px 40px; border: none; border-radius: 30px;
      background: linear-gradient(90deg, #6c5ce7, #a29bfe); color: #fff;
      font-size: 16px; font-weight: 700; cursor: pointer; transition: all 0.2s;
    }
    .lobby-btn:hover { transform: scale(1.05); }
    .lobby-btn:disabled { opacity: 0.4; cursor: not-allowed; transform: none; }
    .lobby-btn.secondary { background: rgba(255,255,255,0.1); }
    .lobby-btn.secondary:hover { background: rgba(255,255,255,0.15); }
    .lobby-btn.danger { background: linear-gradient(90deg, #ff6b6b, #ee5a24); }
    .lobby-btn.danger:hover { transform: scale(1.05); }

    .lobby-players {
      display: flex; flex-wrap: wrap; gap: 12px; justify-content: center; margin: 20px 0;
    }
    .lobby-player-card {
      padding: 16px; border-radius: 16px; text-align: center;
      background: rgba(0,0,0,0.2); border: 1px solid rgba(255,255,255,0.08);
      min-width: 80px; transition: all 0.2s;
    }
    .lobby-player-card .lp-avatar {
      width: 44px; height: 44px; border-radius: 50%;
      background: linear-gradient(135deg, #6c5ce7, #a29bfe);
      display: flex; align-items: center; justify-content: center;
      font-size: 18px; font-weight: 700; color: #fff; margin: 0 auto 6px;
    }
    .lobby-player-card .lp-name { font-size: 12px; font-weight: 600; color: rgba(255,255,255,0.7); }
    .lobby-player-card .lp-host { font-size: 10px; color: #ffd700; margin-top: 2px; }

    .lobby-code {
      display: inline-block; background: rgba(255,255,255,0.05); border: 1px dashed rgba(255,255,255,0.15);
      border-radius: 10px; padding: 8px 20px; font-size: 18px; font-weight: 700;
      letter-spacing: 4px; color: #a29bfe; margin: 12px 0;
      font-family: monospace;
    }

    /* ============ Category Picker ============ */
    .cat-picker { display: flex; flex-wrap: wrap; gap: 8px; justify-content: center; }
    .cat-pick-btn {
      padding: 8px 20px; border: 1px solid rgba(255,255,255,0.12); border-radius: 20px;
      background: rgba(0,0,0,0.2); color: rgba(255,255,255,0.7); font-size: 13px; font-weight: 600;
      cursor: pointer; transition: all 0.2s;
    }
    .cat-pick-btn:hover { background: rgba(108,92,231,0.1); border-color: rgba(108,92,231,0.3); }
    .cat-pick-btn.active { background: rgba(108,92,231,0.2); border-color: #6c5ce7; color: #a29bfe; }

    /* ============ AI Drawing Animation ============ */
    .ai-drawing-indicator {
      position: absolute; top: 12px; left: 12px; z-index: 10;
      background: rgba(0,0,0,0.6); backdrop-filter: blur(8px);
      border-radius: 10px; padding: 6px 14px; font-size: 12px; color: #a29bfe; font-weight: 600;
      display: flex; align-items: center; gap: 6px;
    }
    .ai-drawing-indicator .pulse-dot {
      width: 8px; height: 8px; border-radius: 50%; background: #a29bfe;
      animation: pulse 1s ease infinite;
    }
  </style>
</head>
<body>
  <nav>
    <a href="/games" class="brand">🎨 你画我猜</a>
    <a href="/games">🎮 游戏中心</a>
    <a href="/games/blackjack">🃏 21点</a>
    <a href="/games/dice">🎲 骰子</a>
    <a href="/games/slot">🎰 老虎机</a>
    <a href="/games/guess">🔢 猜数字</a>
    <span class="balance">💰 <span id="balanceDisplay"><%= user.balance.toFixed(2) %></span> 金币</span>
  </nav>

  <div class="toast" id="toast"></div>

  <div class="container">
    <div class="page-header">
      <h1>🎨 你画我猜</h1>
      <p>AI 绘画对战 · 多人竞技 · 创意无限</p>
    </div>

    <!-- Mode Tabs -->
    <div class="mode-tabs">
      <div class="mode-tab active" data-mode="mode1" onclick="switchMode('mode1')">✏️ 你画AI猜</div>
      <div class="mode-tab" data-mode="mode2" onclick="switchMode('mode2')">🤖 AI画你猜</div>
      <div class="mode-tab" data-mode="mode3" onclick="switchMode('mode3')">🕵️ 卧底绘画 <span class="badge">多人</span></div>
      <div class="mode-tab" data-mode="mode4" onclick="switchMode('mode4')">🏆 主题闯关</div>
    </div>

    <!-- ======================================================================== -->
    <!-- MODE 1: 你画AI猜 -->
    <!-- ======================================================================== -->
    <div class="game-layout active" id="mode1">
      <div class="game-main">
        <div class="panel">
          <div class="word-display" id="mode1WordDisplay">
            <div class="category-tag" id="mode1Category">动物</div>
            <div class="word" id="mode1Word">点击开始抽题</div>
            <div class="hint-text" id="mode1Hint">选择一个分类，然后点击"开始绘制"</div>
          </div>

          <div class="canvas-wrapper" id="mode1CanvasWrapper">
            <canvas id="mode1Canvas"></canvas>
          </div>

          <div class="tools-bar" id="mode1Tools">
            <div class="tool-group">
              <span class="tool-group-label">颜色</span>
              <div class="color-picker-wrap">
                <input type="color" id="mode1ColorPicker" value="#000000" onchange="setColor('mode1', this.value)">
              </div>
              <div class="color-presets" id="mode1ColorPresets">
                <div class="color-preset active" style="background:#000" data-color="#000" onclick="setColor('mode1','#000')"></div>
                <div class="color-preset" style="background:#ff6b6b" data-color="#ff6b6b" onclick="setColor('mode1','#ff6b6b')"></div>
                <div class="color-preset" style="background:#ffd700" data-color="#ffd700" onclick="setColor('mode1','#ffd700')"></div>
                <div class="color-preset" style="background:#2ecc71" data-color="#2ecc71" onclick="setColor('mode1','#2ecc71')"></div>
                <div class="color-preset" style="background:#3498db" data-color="#3498db" onclick="setColor('mode1','#3498db')"></div>
                <div class="color-preset" style="background:#a29bfe" data-color="#a29bfe" onclick="setColor('mode1','#a29bfe')"></div>
                <div class="color-preset" style="background:#fff" data-color="#fff" onclick="setColor('mode1','#fff')"></div>
              </div>
            </div>

            <div class="tool-group">
              <span class="tool-group-label">大小</span>
              <button class="brush-size-btn active" data-size="4" onclick="setBrush('mode1',4)"><div class="dot" style="width:4px;height:4px"></div></button>
              <button class="brush-size-btn" data-size="2" onclick="setBrush('mode1',2)"><div class="dot" style="width:2px;height:2px"></div></button>
              <button class="brush-size-btn" data-size="8" onclick="setBrush('mode1',8)"><div class="dot" style="width:8px;height:8px"></div></button>
              <button class="brush-size-btn" data-size="12" onclick="setBrush('mode1',12)"><div class="dot" style="width:12px;height:12px"></div></button>
            </div>

            <div class="tool-group">
              <button class="tool-btn" onclick="toggleEraser('mode1')" id="mode1Eraser" title="橡皮擦">🧹</button>
              <button class="tool-btn" onclick="undoDraw('mode1')" title="撤销">↩️</button>
              <button class="tool-btn danger" onclick="clearCanvas('mode1')" title="清空">🗑️</button>
              <button class="tool-btn" onclick="toggleGrid('mode1')" id="mode1GridBtn" title="网格">📐</button>
              <button class="tool-btn" onclick="saveCanvas('mode1')" title="保存">💾</button>
            </div>
          </div>

          <div class="stats-bar" style="margin-top:12px">
            <div class="stat-item">
              <div class="stat-value" id="mode1Score">0</div>
              <div class="stat-label">得分</div>
            </div>
            <div class="stat-item">
              <div class="stat-value" id="mode1Timer">60</div>
              <div class="stat-label">⏱ 秒</div>
            </div>
            <div class="stat-item">
              <div class="stat-value" id="mode1Streak">0</div>
              <div class="stat-label">🔥 连击</div>
            </div>
          </div>
        </div>

        <div class="panel" style="text-align:center">
          <div class="cat-picker" id="mode1CatPicker">
            <div class="cat-pick-btn active" data-cat="动物" onclick="selectCategory('mode1','动物')">🐾 动物</div>
            <div class="cat-pick-btn" data-cat="食物" onclick="selectCategory('mode1','食物')">🍔 食物</div>
            <div class="cat-pick-btn" data-cat="物品" onclick="selectCategory('mode1','物品')">📦 物品</div>
            <div class="cat-pick-btn" data-cat="动作" onclick="selectCategory('mode1','动作')">🏃 动作</div>
            <div class="cat-pick-btn" data-cat="表情" onclick="selectCategory('mode1','表情')">😊 表情</div>
          </div>
          <button class="lobby-btn" id="mode1StartBtn" onclick="startMode1()" style="margin-top:10px">🎯 开始绘制</button>
        </div>
      </div>

      <div class="game-sidebar">
        <div class="panel">
          <div class="panel-title">🤖 AI 猜测</div>
          <div class="ai-guesses" id="mode1AiGuesses">
            <div class="empty-state">
              <div class="empty-icon">🤔</div>
              <p>AI 正在等待你开始绘制...</p>
            </div>
          </div>
        </div>
      </div>
    </div>

    <!-- ======================================================================== -->
    <!-- MODE 2: AI画你猜 -->
    <!-- ======================================================================== -->
    <div class="game-layout" id="mode2">
      <div class="game-main">
        <div class="panel">
          <div class="word-display" id="mode2WordDisplay">
            <div class="category-tag">AI 绘制中</div>
            <div class="word" id="mode2Word">❓</div>
            <div class="hint-text" id="mode2Hint">AI 正在绘制，请仔细观察</div>
          </div>

          <div class="canvas-wrapper" id="mode2CanvasWrapper">
            <div class="ai-drawing-indicator" id="mode2AiIndicator" style="display:none">
              <span class="pulse-dot"></span>
              AI 正在绘制...
            </div>
            <canvas id="mode2Canvas"></canvas>
          </div>

          <div class="stats-bar" style="margin-top:12px">
            <div class="stat-item">
              <div class="stat-value" id="mode2Score">0</div>
              <div class="stat-label">得分</div>
            </div>
            <div class="stat-item">
              <div class="stat-value" id="mode2Timer">30</div>
              <div class="stat-label">⏱ 秒</div>
            </div>
            <div class="stat-item">
              <div class="stat-value" id="mode2Round">0</div>
              <div class="stat-label">回合</div>
            </div>
          </div>

          <div class="guess-input-row" style="margin-top:12px">
            <input type="text" id="mode2GuessInput" placeholder="输入你的猜测..." disabled>
            <button id="mode2GuessBtn" onclick="submitMode2Guess()" disabled>猜</button>
            <button class="hint-btn" id="mode2HintBtn" onclick="useMode2Hint()" disabled>💡 提示</button>
          </div>
        </div>

        <div class="panel" style="text-align:center">
          <div class="cat-picker" id="mode2CatPicker">
            <div class="cat-pick-btn active" data-cat="动物" onclick="selectCategory('mode2','动物')">🐾 动物</div>
            <div class="cat-pick-btn" data-cat="食物" onclick="selectCategory('mode2','食物')">🍔 食物</div>
            <div class="cat-pick-btn" data-cat="物品" onclick="selectCategory('mode2','物品')">📦 物品</div>
            <div class="cat-pick-btn" data-cat="风景" onclick="selectCategory('mode2','风景')">🌄 风景</div>
            <div class="cat-pick-btn" data-cat="动漫" onclick="selectCategory('mode2','动漫')">📺 动漫</div>
          </div>
          <button class="lobby-btn" id="mode2StartBtn" onclick="startMode2()" style="margin-top:10px">🎨 AI 开始绘制</button>
        </div>
      </div>

      <div class="game-sidebar">
        <div class="panel">
          <div class="panel-title">📝 猜测记录</div>
          <div id="mode2GuessHistory" style="display:flex;flex-direction:column;gap:4px;min-height:60px">
            <div class="empty-state">
              <div class="empty-icon">🤷</div>
              <p>还没有猜测记录</p>
            </div>
          </div>
        </div>
      </div>
    </div>

    <!-- ======================================================================== -->
    <!-- MODE 3: 卧底绘画局 -->
    <!-- ======================================================================== -->
    <div class="game-layout" id="mode3">
      <div class="game-main">
        <!-- Lobby -->
        <div class="panel" id="mode3Lobby">
          <div class="lobby-section">
            <div class="lobby-title">🕵️ 卧底绘画局</div>
            <div class="lobby-desc">4-8 人一起玩，每人画一个词，卧底画的是不一样的词！找出卧底赢得胜利！</div>
            <div class="lobby-code" id="mode3RoomCode">等待创建...</div>
            <div class="lobby-players" id="mode3LobbyPlayers">
              <div class="empty-state">
                <div class="empty-icon">👥</div>
                <p>等待玩家加入...</p>
              </div>
            </div>
            <div style="display:flex;gap:10px;justify-content:center;flex-wrap:wrap">
              <button class="lobby-btn" id="mode3CreateBtn" onclick="createMode3Room()">🏠 创建房间</button>
              <button class="lobby-btn secondary" id="mode3JoinBtn" onclick="joinMode3Room()">🚪 加入房间</button>
              <button class="lobby-btn danger" id="mode3LeaveBtn" onclick="leaveMode3Room()" style="display:none">🚪 离开房间</button>
              <button class="lobby-btn" id="mode3StartGameBtn" onclick="startMode3Game()" style="display:none">🎯 开始游戏</button>
            </div>
            <div style="margin-top:12px;display:none" id="mode3JoinInput">
              <input type="text" id="mode3RoomCodeInput" placeholder="输入房间号" style="background:rgba(0,0,0,0.4);border:2px solid rgba(255,255,255,0.12);border-radius:12px;padding:10px 16px;color:#fff;font-size:16px;text-align:center;outline:none;width:200px;letter-spacing:4px">
              <button class="lobby-btn" onclick="doJoinMode3Room()" style="margin-left:8px;padding:10px 24px;font-size:14px">确认加入</button>
            </div>
          </div>
        </div>

        <!-- Game Area -->
        <div class="panel" id="mode3GameArea" style="display:none">
          <div class="role-reveal" id="mode3RoleReveal">
            <div class="role-label">你的身份</div>
            <div class="role-word" id="mode3RoleWord">---</div>
          </div>

          <div class="word-display" style="margin-bottom:12px">
            <div class="word" id="mode3WordToDraw">你的词：---</div>
            <div class="hint-text" id="mode3WordHint">请根据你的词作画</div>
          </div>

          <div class="canvas-wrapper" id="mode3CanvasWrapper">
            <canvas id="mode3Canvas"></canvas>
          </div>

          <div class="tools-bar" id="mode3Tools">
            <div class="tool-group">
              <span class="tool-group-label">颜色</span>
              <div class="color-picker-wrap">
                <input type="color" id="mode3ColorPicker" value="#000000" onchange="setColor('mode3', this.value)">
              </div>
              <div class="color-presets" id="mode3ColorPresets">
                <div class="color-preset active" style="background:#000" data-color="#000" onclick="setColor('mode3','#000')"></div>
                <div class="color-preset" style="background:#ff6b6b" data-color="#ff6b6b" onclick="setColor('mode3','#ff6b6b')"></div>
                <div class="color-preset" style="background:#ffd700" data-color="#ffd700" onclick="setColor('mode3','#ffd700')"></div>
                <div class="color-preset" style="background:#2ecc71" data-color="#2ecc71" onclick="setColor('mode3','#2ecc71')"></div>
                <div class="color-preset" style="background:#3498db" data-color="#3498db" onclick="setColor('mode3','#3498db')"></div>
                <div class="color-preset" style="background:#a29bfe" data-color="#a29bfe" onclick="setColor('mode3','#a29bfe')"></div>
                <div class="color-preset" style="background:#fff" data-color="#fff" onclick="setColor('mode3','#fff')"></div>
              </div>
            </div>
            <div class="tool-group">
              <span class="tool-group-label">大小</span>
              <button class="brush-size-btn active" data-size="4" onclick="setBrush('mode3',4)"><div class="dot" style="width:4px;height:4px"></div></button>
              <button class="brush-size-btn" data-size="2" onclick="setBrush('mode3',2)"><div class="dot" style="width:2px;height:2px"></div></button>
              <button class="brush-size-btn" data-size="8" onclick="setBrush('mode3',8)"><div class="dot" style="width:8px;height:8px"></div></button>
              <button class="brush-size-btn" data-size="12" onclick="setBrush('mode3',12)"><div class="dot" style="width:12px;height:12px"></div></button>
            </div>
            <div class="tool-group">
              <button class="tool-btn" onclick="toggleEraser('mode3')" id="mode3Eraser" title="橡皮擦">🧹</button>
              <button class="tool-btn" onclick="undoDraw('mode3')" title="撤销">↩️</button>
              <button class="tool-btn danger" onclick="clearCanvas('mode3')" title="清空">🗑️</button>
              <button class="tool-btn" onclick="toggleGrid('mode3')" id="mode3GridBtn" title="网格">📐</button>
            </div>
          </div>

          <!-- Vote Phase -->
          <div class="vote-panel" id="mode3VotePanel" style="display:none;margin-top:12px">
            <p>🕵️ 投票时间！选出你认为的卧底：</p>
            <div class="vote-options" id="mode3VoteOptions"></div>
          </div>

          <div class="stats-bar" style="margin-top:12px">
            <div class="stat-item">
              <div class="stat-value" id="mode3Timer">120</div>
              <div class="stat-label">⏱ 秒</div>
            </div>
            <div class="stat-item">
              <div class="stat-value" id="mode3RoundNum">1</div>
              <div class="stat-label">回合</div>
            </div>
            <div class="stat-item">
              <div class="stat-value" id="mode3PlayersOnline">0</div>
              <div class="stat-label">在线</div>
            </div>
          </div>
        </div>
      </div>

      <div class="game-sidebar">
        <!-- Player List -->
        <div class="panel">
          <div class="panel-title">👥 玩家列表</div>
          <div class="player-list" id="mode3PlayerList">
            <div class="empty-state">
              <div class="empty-icon">👥</div>
              <p>暂无玩家</p>
            </div>
          </div>
        </div>

        <!-- Chat -->
        <div class="panel">
          <div class="panel-title">💬 聊天</div>
          <div class="chat-box">
