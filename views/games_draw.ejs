    // 干扰词注入（增加杂音，防止AI过早锁定）
    function getInterferenceWords(count, features) {
      var pool = AI_GENERAL_WORD_POOL.slice();
      // 根据画面特征过滤：杂乱的图增加更多干扰词
      var extra = features && features.isMessy ? count + 3 : count;
      var shuffled = pool.sort(function() { return Math.random() - 0.5; });
      return shuffled.slice(0, extra);
    }

    // 主AI猜词函数（基于画布特征智能推理）
    function simulateMode1Ai() {
      if (!mode1Active) return;

      var aiRound = 0;
      var lastGuesses = [];

      var aiInterval = setInterval(function() {
        if (!mode1Active) { clearInterval(aiInterval); return; }
        aiRound++;

        // 获取画布分析结果
        var curFeatures = analyzeDrawing('mode1');
        if (!curFeatures) return;

        var fillRatio = curFeatures.fillRatio;
        var strokeCount = curFeatures.strokeCount;
        var guesses = [];

        // ---- 阶段1：几乎没画任何东西（fillRatio < 0.005）----
        if (fillRatio < 0.005) {
          var descs = ['空白画布', '还没开始画', '等待绘画中', '请画点东西'];
          for (var i = 0; i < 3; i++) {
            guesses.push({
              word: descs[i % descs.length],
              confidence: Math.round(10 + Math.random() * 10),
              isVague: true
            });
          }
          renderAiGuesses(guesses);
          return;
        }

        // 根据画布特征推荐类别
        var suggestedCats = suggestCategories(curFeatures);

        // ---- 阶段2：很少笔画（fillRatio < 0.02）----
        // 输出模糊描述 + 少量类别猜测
        if (fillRatio < 0.02) {
          guesses.push({
            word: '线条图案',
            confidence: Math.round(20 + Math.random() * 15),
            isVague: true
          });
          // 从推荐类别中挑2个类别词
          var catWords = pickWordsFromCategories(suggestedCats, 2, mode1Word);
          for (var i = 0; i < catWords.length; i++) {
            guesses.push({
              word: catWords[i] + '?',
              confidence: Math.round(10 + Math.random() * 10),
              isBroad: true
            });
          }
          renderAiGuesses(guesses);
          return;
        }

        // ---- 阶段3：有了一定内容（fillRatio >= 0.02）----
        // 从推荐类别中选4~6个具体词
        var guessCount = 4 + Math.min(Math.floor(aiRound * 0.5), 4); // 4~8个
        var selectedWords = pickWordsFromCategories(suggestedCats, guessCount + 3, mode1Word);

        // 基础信心随填充率和轮次增加
        var baseConf = 20 + fillRatio * 150 + aiRound * 3;
        baseConf = Math.min(baseConf, 80);

        for (var i = 0; i < selectedWords.length && i < guessCount; i++) {
          var conf = baseConf + Math.random() * 15 - i * 2;
          guesses.push({
            word: selectedWords[i],
            confidence: Math.round(Math.min(conf, 88)),
            isPrecise: true
          });
        }

        // 按信心排序
        guesses.sort(function(a, b) { return b.confidence - a.confidence; });

        // 检查是否猜中：最高信心词 >= 70% 且 轮次 >= 2
        var topGuess = guesses[0];
        if (topGuess && topGuess.confidence >= 70 && aiRound >= 2 && topGuess.word === mode1Word) {
          clearInterval(aiInterval);
          if (mode1Active) {
            var bonus = Math.max(10, Math.floor((60 - mode1TimeLeft) * 2));
            mode1Score += bonus;
            mode1Streak++;
            showToast('🎉 AI 猜对了！+' + bonus + ' 分');
            updateMode1Stats();
            renderAiGuesses(guesses);
            setTimeout(function() { endMode1(true); }, 500);
          }
          return;
        }

        // 如果最高信心词接近正确（>65%），且轮次足够，尝试加入更多同类词
        if (aiRound >= 4 && fillRatio > 0.05) {
          // 再从推荐类别补充一批词
          var extraWords = pickWordsFromCategories(suggestedCats, 3, mode1Word);
          for (var i = 0; i < extraWords.length; i++) {
            // 避免重复
            var isDup = false;
            for (var j = 0; j < guesses.length; j++) {
              if (guesses[j].word === extraWords[i]) { isDup = true; break; }
            }
            if (!isDup) {
              guesses.push({
                word: extraWords[i],
                confidence: Math.round(baseConf + Math.random() * 10 - 5),
                isPrecise: true
              });
            }
          }
          guesses.sort(function(a, b) { return b.confidence - a.confidence; });
          // 重新检查猜中
          if (guesses[0] && guesses[0].confidence >= 72 && guesses[0].word === mode1Word) {
            clearInterval(aiInterval);
            if (mode1Active) {
              var bonus = Math.max(10, Math.floor((60 - mode1TimeLeft) * 2));
              mode1Score += bonus;
              mode1Streak++;
              showToast('🎉 AI 猜对了！+' + bonus + ' 分');
              updateMode1Stats();
              renderAiGuesses(guesses);
              setTimeout(function() { endMode1(true); }, 500);
            }
            return;
          }
        }

        renderAiGuesses(guesses);

        // 时间耗尽（12轮 = 30秒）
        if (aiRound >= 12) {
          clearInterval(aiInterval);
          if (mode1Active) endMode1(false);
        }
      }, 2500);
    }

    // 渲染AI猜测结果
    function renderAiGuesses(guesses) {
      var container = document.getElementById('mode1AiGuesses');
      if (!container) return;
      // 只显示前8个
      var display = guesses.slice(0, 8);
      container.innerHTML = display.map(function(g) {
        var cls = 'low-confidence';
        if (g.confidence >= 70) cls = 'high-confidence';
        else if (g.confidence >= 40) cls = 'medium-confidence';
        var tag = '';
        if (g.isVague) tag = '<span style="font-size:9px;color:rgba(255,255,255,0.3);margin-left:4px">[观察中]</span>';
        else if (g.isBroad) tag = '<span style="font-size:9px;color:rgba(255,255,255,0.3);margin-left:4px">[猜测]</span>';
        else if (g.isPrecise) tag = '<span style="font-size:9px;color:rgba(255,255,255,0.3);margin-left:4px">[推理]</span>';
        return '<div class="ai-guess-item ' + cls + '">' +
          '<span class="guess-text">' + g.word + tag + '</span>' +
          '<div class="guess-bar-wrap"><div class="guess-bar" style="width:' + g.confidence + '%"></div></div>' +
          '<span class="guess-pct">' + g.confidence + '%</span>' +
        '</div>';
      }).join('');
    }

    function endMode1(won) {
      mode1Active = false;
      if (mode1Timer) clearInterval(mode1Timer);
      document.getElementById('mode1StartBtn').disabled = false;
      document.getElementById('mode1StartBtn').textContent = '🎯 开始绘制';

      showResultModal(
        won ? '🎉' : '⏰',
        won ? 'AI猜对了！' : '时间到！',
        won
          ? `AI 在 ${60 - mode1TimeLeft} 秒内猜出了「${mode1Word}」！<br>得分：<span class="highlight">+${mode1Score}</span> | 连击：<span class="highlight">${mode1Streak}x</span>`
          : `AI 没能猜出「${mode1Word}」<br>得分：<span class="highlight">${mode1Score}</span>`,
        '再来一局', '返回大厅'
      );
    }

    // ============================================================
    // MODE 2: AI画你猜
    // ============================================================
    let mode2Active = false;
    let mode2Timer = null;
    let mode2TimeLeft = 30;
    let mode2Category = '动物';
    let mode2Score = 0;
    let mode2Round = 0;
    let mode2Word = '';
    let mode2HintsLeft = 3;
    let mode2GuessHistory = [];

    const mode2Words = {
      '动物': ['猫', '狗', '兔子', '大象', '长颈鹿', '企鹅', '海豚', '蝴蝶', '老鹰', '孔雀'],
      '食物': ['苹果', '蛋糕', '披萨', '汉堡', '寿司', '冰淇淋', '火锅', '包子', '饺子', '西瓜'],
      '物品': ['手机', '电脑', '台灯', '雨伞', '闹钟', '眼镜', '背包', '杯子', '吉他', '钢琴'],
      '风景': ['山', '大海', '日落', '星空', '森林', '瀑布', '沙漠', '彩虹', '雪地', '草原'],
      '动漫': ['龙猫', '皮卡丘', '哆啦A梦', '海贼王', '火影', '柯南', '千与千寻', '幽灵公主', '天空之城', '龙珠']
    };

    // AI drawing data loaded from /js/draw_recipes.js via window.aiDrawingRecipes
    // Fallback patterns if external file hasn't loaded
    const aiDrawingPatterns = window.aiDrawingRecipes || {};

    function startMode2() {
      if (mode2Active) return;
      const words = mode2Words[mode2Category] || mode2Words['动物'];
      mode2Word = words[Math.floor(Math.random() * words.length)];
      mode2Round++;
      mode2HintsLeft = 3;
      mode2TimeLeft = 30;
      mode2GuessHistory = [];

      document.getElementById('mode2Word').textContent = '❓';
      document.getElementById('mode2WordDisplay').querySelector('.category-tag').textContent = mode2Category;
      document.getElementById('mode2Hint').textContent = 'AI 正在绘制，请仔细观察...';
      document.getElementById('mode2GuessInput').disabled = true;
      document.getElementById('mode2GuessBtn').disabled = true;
      document.getElementById('mode2HintBtn').disabled = true;
      document.getElementById('mode2StartBtn').disabled = true;
      document.getElementById('mode2StartBtn').textContent = '绘制中...';
      document.getElementById('mode2GuessHistory').innerHTML = '';
      document.getElementById('mode2AiIndicator').style.display = 'flex';

      document.getElementById('mode2Round').textContent = mode2Round;
      updateMode2Stats();

      initCanvas('mode2');
      mode2Active = true;

      // AI draws on canvas
      simulateMode2Drawing();
    }

    function simulateMode2Drawing() {
      const s = canvasStates['mode2'];
      if (!s) return;
      fillWhite('mode2');

      const recipe = aiDrawingPatterns[mode2Word];
      if (!recipe || !recipe.strokes || recipe.strokes.length === 0) {
        // Fallback: draw a simple indicator
        s.ctx.fillStyle = '#999';
        s.ctx.font = '20px Arial';
        s.ctx.textAlign = 'center';
        s.ctx.fillText('?' + mode2Word + '?', s.w / 2, s.h / 2);
        setTimeout(() => {
          document.getElementById('mode2AiIndicator').style.display = 'none';
          document.getElementById('mode2Word').textContent = '❓';
          document.getElementById('mode2Hint').textContent = 'AI 画完了！输入你的猜测！';
          document.getElementById('mode2GuessInput').disabled = false;
          document.getElementById('mode2GuessBtn').disabled = false;
          document.getElementById('mode2HintBtn').disabled = false;
          document.getElementById('mode2GuessInput').focus();
          startMode2Timer();
        }, 500);
        return;
      }

      const strokes = recipe.strokes;
      let step = 0;
      const delay = Math.max(150, Math.min(400, 600 / strokes.length));

      function drawStroke(stroke) {
        const w = s.w, h = s.h;
        s.ctx.save();
        s.ctx.strokeStyle = stroke.color || '#000';
        s.ctx.lineWidth = stroke.width || 2;
        s.ctx.lineCap = 'round';
        s.ctx.lineJoin = 'round';

        switch (stroke.type) {
          case 'line':
            s.ctx.beginPath();
            s.ctx.moveTo(stroke.x * w, stroke.y * h);
            s.ctx.lineTo(stroke.x2 * w, stroke.y2 * h);
            s.ctx.stroke();
            break;
          case 'circle':
            s.ctx.beginPath();
            s.ctx.arc(stroke.x * w, stroke.y * h, stroke.r * w, 0, Math.PI * 2);
            s.ctx.stroke();
            if (stroke.fill) {
              s.ctx.fillStyle = stroke.color;
              s.ctx.fill();
            }
            break;
          case 'fill':
            s.ctx.fillStyle = stroke.color;
            // Fill the shape described by the stroke's coordinates
            if (stroke.rx !== undefined && stroke.ry !== undefined) {
              // Fill ellipse
              s.ctx.beginPath();
              s.ctx.ellipse(stroke.x * w, stroke.y * h, stroke.rx * w, stroke.ry * h, 0, 0, Math.PI * 2);
              s.ctx.fill();
            } else if (stroke.r !== undefined) {
              // Fill circle
              s.ctx.beginPath();
              s.ctx.arc(stroke.x * w, stroke.y * h, stroke.r * w, 0, Math.PI * 2);
              s.ctx.fill();
            } else if (stroke.w !== undefined && stroke.h !== undefined) {
              // Fill triangle
              s.ctx.beginPath();
              var cx = stroke.x * w, cy = stroke.y * h;
              var bw = stroke.w * w / 2, bh = stroke.h * h;
              s.ctx.moveTo(cx, cy - bh);
              s.ctx.lineTo(cx - bw, cy);
              s.ctx.lineTo(cx + bw, cy);
              s.ctx.closePath();
              s.ctx.fill();
            } else {
              // Fallback: fill entire canvas
              s.ctx.fillRect(0, 0, w, h);
            }
            break;
          case 'ellipse':
            s.ctx.beginPath();
            s.ctx.ellipse(stroke.x * w, stroke.y * h, stroke.rx * w, stroke.ry * h, 0, 0, Math.PI * 2);
            s.ctx.stroke();
            break;
          case 'rect':
            s.ctx.strokeRect(stroke.x * w, stroke.y * h, stroke.w * w, stroke.h * h);
            if (stroke.fill) {
              s.ctx.fillStyle = stroke.color;
              s.ctx.fillRect(stroke.x * w, stroke.y * h, stroke.w * w, stroke.h * h);
            }
            break;
          case 'triangle':
            s.ctx.beginPath();
            var cx = stroke.x * w, cy = stroke.y * h;
            var bw = stroke.w * w / 2, bh = stroke.h * h;
            s.ctx.moveTo(cx, cy - bh);
            s.ctx.lineTo(cx - bw, cy);
            s.ctx.lineTo(cx + bw, cy);
            s.ctx.closePath();
            s.ctx.stroke();
            if (stroke.fill) {
              s.ctx.fillStyle = stroke.color;
              s.ctx.fill();
            }
            break;
          case 'arc':
            s.ctx.beginPath();
            s.ctx.arc(stroke.x * w, stroke.y * h, stroke.r * w, stroke.start || 0, stroke.end || Math.PI);
            s.ctx.stroke();
            break;
        }
        s.ctx.restore();
      }

      const drawInterval = setInterval(() => {
        if (!mode2Active) { clearInterval(drawInterval); return; }
        if (step >= strokes.length) {
          clearInterval(drawInterval);
          document.getElementById('mode2AiIndicator').style.display = 'none';
          document.getElementById('mode2Word').textContent = '❓';
          document.getElementById('mode2Hint').textContent = 'AI 画完了！输入你的猜测！';
          document.getElementById('mode2GuessInput').disabled = false;
          document.getElementById('mode2GuessBtn').disabled = false;
          document.getElementById('mode2HintBtn').disabled = false;
          document.getElementById('mode2GuessInput').focus();
          startMode2Timer();
          return;
        }

        drawStroke(strokes[step]);
        step++;
      }, delay);
    }

    function startMode2Timer() {
      if (mode2Timer) clearInterval(mode2Timer);
      mode2Timer = setInterval(() => {
        mode2TimeLeft--;
        updateMode2Stats();
        if (mode2TimeLeft <= 0) {
          clearInterval(mode2Timer);
          endMode2(false);
        }
      }, 1000);
    }

    function updateMode2Stats() {
      document.getElementById('mode2Score').textContent = mode2Score;
      document.getElementById('mode2Timer').textContent = mode2TimeLeft;
      const timerEl = document.getElementById('mode2Timer');
      timerEl.classList.toggle('timer-warning', mode2TimeLeft <= 10);
    }

    function submitMode2Guess() {
      if (!mode2Active) return;
      const input = document.getElementById('mode2GuessInput');
      const guess = input.value.trim();
      if (!guess) { showToast('请输入你的猜测'); return; }

      const history = document.getElementById('mode2GuessHistory');
      const div = document.createElement('div');
      div.style.cssText = 'padding:6px 10px;border-radius:8px;font-size:13px;background:rgba(0,0,0,0.15);display:flex;justify-content:space-between';

      const correct = guess.includes(mode2Word) || mode2Word.includes(guess);
      if (correct) {
        div.innerHTML = `<span style="color:#2ecc71">✅ ${guess}</span><span style="color:#2ecc71;font-weight:700">正确！</span>`;
        history.appendChild(div);
        input.value = '';
        endMode2(true);
      } else {
        div.innerHTML = `<span style="color:rgba(255,255,255,0.6)">❌ ${guess}</span><span style="color:#ff6b6b">错误</span>`;
        history.appendChild(div);
        input.value = '';
        input.focus();
        // Remove empty state
        const empty = history.querySelector('.empty-state');
        if (empty) empty.remove();
      }
    }

    function useMode2Hint() {
      if (!mode2Active || mode2HintsLeft <= 0) return;
      mode2HintsLeft--;
      const hintBtn = document.getElementById('mode2HintBtn');
      hintBtn.textContent = `💡 提示 (${mode2HintsLeft})`;

      // Give a hint: show first character or category
      const hint = `这个词是「${mode2Category}」类，共 ${mode2Word.length} 个字`;
      showToast(`💡 ${hint}`);
      document.getElementById('mode2Hint').textContent = hint;

      if (mode2HintsLeft <= 0) hintBtn.disabled = true;
    }

    function endMode2(won) {
      mode2Active = false;
      if (mode2Timer) clearInterval(mode2Timer);
      document.getElementById('mode2StartBtn').disabled = false;
      document.getElementById('mode2StartBtn').textContent = '🎨 AI 开始绘制';
      document.getElementById('mode2GuessInput').disabled = true;
      document.getElementById('mode2GuessBtn').disabled = true;
      document.getElementById('mode2HintBtn').disabled = true;
      document.getElementById('mode2AiIndicator').style.display = 'none';

      if (won) {
        const timeBonus = Math.max(5, mode2TimeLeft);
        const roundBonus = mode2Round * 10;
        const totalBonus = timeBonus + roundBonus;
        mode2Score += totalBonus;
        updateMode2Stats();
        document.getElementById('mode2Word').textContent = mode2Word;
        showResultModal(
          '🎉',
          '猜对了！',
          `答案是「${mode2Word}」<br>时间奖励：<span class="highlight">+${timeBonus}</span> | 回合奖励：<span class="highlight">+${roundBonus}</span>`,
          '下一轮', '返回大厅'
        );
      } else {
        document.getElementById('mode2Word').textContent = mode2Word;
        document.getElementById('mode2Hint').textContent = `答案是「${mode2Word}」`;
        showResultModal(
          '⏰',
          '时间到！',
          `答案是「${mode2Word}」<br>得分：<span class="highlight">${mode2Score}</span>`,
          '再来一轮', '返回大厅'
        );
      }
    }

    // ============================================================
    // MODE 3: 卧底绘画局
    // ============================================================
    let mode3InRoom = false;
    let mode3IsHost = false;
    let mode3RoomCode = '';
    let mode3Players = [];
    let mode3Role = '平民';
    let mode3Word = '';
    let mode3GameActive = false;
    let mode3Timer = null;
    let mode3TimeLeft = 120;
    let mode3HasVoted = false;

    const mode3WordPairs = {
      '动物': [['猫', '狗'], ['兔子', '老鼠'], ['老虎', '狮子'], ['大象', '河马'], ['企鹅', '海鸥']],
      '食物': [['苹果', '梨'], ['蛋糕', '面包'], ['披萨', '馅饼'], ['汉堡', '三明治'], ['饺子', '馄饨']],
      '物品': [['手机', '平板'], ['电脑', '电视'], ['雨伞', '雨衣'], ['眼镜', '望远镜'], ['背包', '手提包']]
    };

    function createMode3Room() {
      mode3RoomCode = Math.random().toString(36).substring(2, 8).toUpperCase();
      document.getElementById('mode3RoomCode').textContent = mode3RoomCode;
      document.getElementById('mode3CreateBtn').style.display = 'none';
      document.getElementById('mode3JoinBtn').style.display = 'none';
      document.getElementById('mode3LeaveBtn').style.display = 'inline-block';
      document.getElementById('mode3StartGameBtn').style.display = 'inline-block';
      mode3InRoom = true;
      mode3IsHost = true;

      socket.emit('draw_join_game', { room: mode3RoomCode, username: '<%= user.username %>' });

      // Add self to player list
      mode3Players = [{ username: '<%= user.username %>', isHost: true }];
      updateMode3PlayerList();
      showToast('房间已创建：' + mode3RoomCode);
    }

    function joinMode3Room() {
      document.getElementById('mode3JoinInput').style.display = 'block';
    }

    function doJoinMode3Room() {
      const code = document.getElementById('mode3RoomCodeInput').value.trim().toUpperCase();
      if (!code || code.length < 4) { showToast('请输入有效的房间号'); return; }
      mode3RoomCode = code;
      document.getElementById('mode3RoomCode').textContent = mode3RoomCode;
      document.getElementById('mode3CreateBtn').style.display = 'none';
      document.getElementById('mode3JoinBtn').style.display = 'none';
      document.getElementById('mode3JoinInput').style.display = 'none';
      document.getElementById('mode3LeaveBtn').style.display = 'inline-block';
      mode3InRoom = true;
      mode3IsHost = false;

      socket.emit('draw_join_game', { room: mode3RoomCode, username: '<%= user.username %>' });
      showToast('已加入房间：' + mode3RoomCode);
    }

    function leaveMode3Room() {
      socket.emit('draw_leave_game', { room: mode3RoomCode });
      mode3InRoom = false;
      mode3IsHost = false;
      mode3RoomCode = '';
      mode3Players = [];
      document.getElementById('mode3RoomCode').textContent = '等待创建...';
      document.getElementById('mode3CreateBtn').style.display = 'inline-block';
      document.getElementById('mode3JoinBtn').style.display = 'inline-block';
      document.getElementById('mode3LeaveBtn').style.display = 'none';
      document.getElementById('mode3StartGameBtn').style.display = 'none';
      document.getElementById('mode3JoinInput').style.display = 'none';
      document.getElementById('mode3Lobby').style.display = 'block';
      document.getElementById('mode3GameArea').style.display = 'none';
      updateMode3PlayerList();
      showToast('已离开房间');
    }

    function startMode3Game() {
      if (!mode3IsHost) { showToast('只有房主可以开始游戏'); return; }
      if (mode3Players.length < 4) { showToast('至少需要4名玩家'); return; }

      // Pick a random category and word pair
      const cats = Object.keys(mode3WordPairs);
      const cat = cats[Math.floor(Math.random() * cats.length)];
      const pair = mode3WordPairs[cat][Math.floor(Math.random() * mode3WordPairs[cat].length)];

      // Undercover is the first player (random)
      const undercoverIdx = Math.floor(Math.random() * mode3Players.length);

      socket.emit('draw_submit', {
        room: mode3RoomCode,
        action: 'start_game',
        category: cat,
        word1: pair[0],
        word2: pair[1],
        undercoverIdx: undercoverIdx
      });

      // Local setup
      setupMode3Game(pair[0], pair[1], undercoverIdx);
    }

    function setupMode3Game(word1, word2, undercoverIdx) {
      document.getElementById('mode3Lobby').style.display = 'none';
      document.getElementById('mode3GameArea').style.display = 'block';
      mode3GameActive = true;
      mode3TimeLeft = 120;
      mode3HasVoted = false;

      const isUndercover = mode3Players[undercoverIdx] && mode3Players[undercoverIdx].username === '<%= user.username %>';
      mode3Role = isUndercover ? '卧底' : '平民';
      mode3Word = isUndercover ? word2 : word1;

      document.getElementById('mode3RoleWord').textContent = isUndercover ? '🕵️ 卧底' : '👤 平民';
      document.getElementById('mode3WordToDraw').textContent = '你的词：' + mode3Word;
      document.getElementById('mode3WordHint').textContent = isUndercover
        ? '你的词和其他人不一样！小心不要暴露！'
        : '画出你的词，找出卧底！';

      updateMode3Stats();
      initCanvas('mode3');
      startMode3Timer();
      showToast('游戏开始！');
    }

    function startMode3Timer() {
      if (mode3Timer) clearInterval(mode3Timer);
      mode3Timer = setInterval(() => {
        mode3TimeLeft--;
        updateMode3Stats();
        if (mode3TimeLeft <= 0) {
          clearInterval(mode3Timer);
          startMode3Vote();
        }
      }, 1000);
    }

    function updateMode3Stats() {
      document.getElementById('mode3Timer').textContent = mode3TimeLeft;
      document.getElementById('mode3PlayersOnline').textContent = mode3Players.length;
      const timerEl = document.getElementById('mode3Timer');
      timerEl.classList.toggle('timer-warning', mode3TimeLeft <= 20);
    }

    function updateMode3PlayerList() {
      const container = document.getElementById('mode3PlayerList');
      const lobbyContainer = document.getElementById('mode3LobbyPlayers');
      if (mode3Players.length === 0) {
        container.innerHTML = '<div class="empty-state"><div class="empty-icon">👥</div><p>暂无玩家</p></div>';
        lobbyContainer.innerHTML = '<div class="empty-state"><div class="empty-icon">👥</div><p>等待玩家加入...</p></div>';
        return;
      }

      const listHtml = mode3Players.map(p => {
        const isMe = p.username === '<%= user.username %>';
        const initial = p.username.charAt(0).toUpperCase();
        return `<div class="player-item${isMe ? ' me' : ''}">
          <div class="player-avatar">${initial}</div>
          <span class="player-name">${p.username}${isMe ? ' (我)' : ''}${p.isHost ? ' 👑' : ''}</span>
          <span class="player-status">${p.done ? '✅ 已提交' : '✏️ 绘制中'}</span>
        </div>`;
      }).join('');

      container.innerHTML = listHtml;
      lobbyContainer.innerHTML = mode3Players.map(p => {
        const initial = p.username.charAt(0).toUpperCase();
        return `<div class="lobby-player-card">
          <div class="lp-avatar">${initial}</div>
          <div class="lp-name">${p.username}</div>
          ${p.isHost ? '<div class="lp-host">👑 房主</div>' : ''}
        </div>`;
      }).join('');
    }

    function startMode3Vote() {
      mode3GameActive = false;
      document.getElementById('mode3VotePanel').style.display = 'block';
      const options = document.getElementById('mode3VoteOptions');
      options.innerHTML = mode3Players.map((p, i) =>
        `<button class="vote-option" onclick="submitMode3Vote(${i})" ${mode3HasVoted ? 'disabled' : ''}>
          ${p.username}
        </button>`
      ).join('');
      showToast('🕵️ 投票时间！选出卧底！');
    }

    function submitMode3Vote(idx) {
      if (mode3HasVoted) return;
      mode3HasVoted = true;
      const target = mode3Players[idx];
      socket.emit('draw_vote', { room: mode3RoomCode, target: target.username });
      document.querySelectorAll('#mode3VoteOptions .vote-option').forEach(b => b.disabled = true);
      showToast('已投票：' + target.username);

      // Simulate result
      setTimeout(() => {
        const undercoverPlayer = mode3Players.find(p => p.isUndercover) || mode3Players[Math.floor(Math.random() * mode3Players.length)];
        const caught = undercoverPlayer && idx === mode3Players.indexOf(undercoverPlayer);
        const isUndercover = mode3Role === '卧底';
        showResultModal(
          caught ? '🕵️' : '😅',
          caught ? '卧底被抓住了！' : '卧底逃脱了！',
          caught
            ? `卧底是「${undercoverPlayer.username}」！<br>平民们获得了胜利！`
            : `卧底「${undercoverPlayer.username}」成功隐藏了身份！<br>卧底获胜！`,
          '再来一局', '返回大厅'
        );
      }, 1500);
    }

    function sendMode3Chat() {
      const input = document.getElementById('mode3ChatInput');
      const msg = input.value.trim();
      if (!msg) return;
      input.value = '';
      socket.emit('draw_chat', { room: mode3RoomCode, username: '<%= user.username %>', message: msg });
      addMode3ChatMessage('<%= user.username %>', msg);
    }

    function addMode3ChatMessage(username, msg) {
      const container = document.getElementById('mode3ChatMessages');
      const div = document.createElement('div');
      div.className = 'chat-msg';
      div.innerHTML = `<span class="chat-user">${username}: </span><span class="chat-text">${msg}</span>`;
      container.appendChild(div);
      container.scrollTop = container.scrollHeight;
    }

    // ============================================================
    // MODE 4: 主题闯关
    // ============================================================
