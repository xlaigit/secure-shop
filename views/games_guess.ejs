<!DOCTYPE html>
<html lang="zh-CN">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>猜数字 - 游戏中心</title>
  <link rel="icon" href="data:image/svg+xml,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 100 100'><text y='.9em' font-size='90'>🔢</text></svg>">
  <style>
    * { margin: 0; padding: 0; box-sizing: border-box; }
    body {
      font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
      background: linear-gradient(135deg, #0a1628, #1a2744, #0a1628);
      min-height: 100vh; color: #fff;
    }
    nav {
      background: rgba(0,0,0,0.3); backdrop-filter: blur(12px);
      padding: 12px 24px; display: flex; align-items: center; gap: 16px;
      border-bottom: 1px solid rgba(255,255,255,0.08);
    }
    nav a { color: rgba(255,255,255,0.7); text-decoration: none; font-size: 14px; padding: 6px 14px; border-radius: 8px; transition: all 0.2s; }
    nav a:hover { background: rgba(255,255,255,0.1); color: #fff; }
    nav .brand { font-size: 20px; font-weight: 700; color: #ffd700; margin-right: auto; }
    nav .balance { background: rgba(255,215,0,0.15); color: #ffd700; padding: 6px 16px; border-radius: 20px; font-size: 14px; font-weight: 600; }

    .container { max-width: 560px; margin: 0 auto; padding: 40px 20px; text-align: center; }
    .title { font-size: 32px; font-weight: 800; color: #ffd700; margin-bottom: 6px; }
    .subtitle { color: rgba(255,255,255,0.5); font-size: 14px; margin-bottom: 30px; }

    .game-box {
      background: rgba(0,0,0,0.3); border: 1px solid rgba(255,255,255,0.1);
      border-radius: 24px; padding: 30px; position: relative;
    }

    .attempts-bar {
      display: flex; gap: 8px; justify-content: center; margin-bottom: 24px;
    }
    .attempt-dot {
      width: 40px; height: 40px; border-radius: 50%;
      border: 2px solid rgba(255,255,255,0.15);
      display: flex; align-items: center; justify-content: center;
      font-size: 16px; font-weight: 700; transition: all 0.3s;
    }
    .attempt-dot.used { border-color: #ff6b6b; background: rgba(255,107,107,0.1); color: #ff6b6b; }
    .attempt-dot.active { border-color: #ffd700; background: rgba(255,215,0,0.1); color: #ffd700; animation: pulse 1s ease infinite; }
    .attempt-dot.win-dot { border-color: #2ecc71; background: rgba(46,204,113,0.1); color: #2ecc71; }
    @keyframes pulse {
      0%, 100% { transform: scale(1); }
      50% { transform: scale(1.1); }
    }

    .range-display {
      font-size: 48px; font-weight: 800; margin-bottom: 8px;
      background: linear-gradient(90deg, #3498db, #2ecc71);
      -webkit-background-clip: text; -webkit-text-fill-color: transparent;
    }
    .range-label { font-size: 14px; color: rgba(255,255,255,0.4); margin-bottom: 20px; }

    .hint-area {
      font-size: 20px; font-weight: 600; min-height: 40px; margin-bottom: 16px;
    }
    .hint-area.hint-cold { color: #3498db; }
    .hint-area.hint-hot { color: #e74c3c; }
    .hint-area.hint-win { color: #2ecc71; }
    .hint-area.hint-lose { color: rgba(255,255,255,0.4); }

    .guess-input-area {
      display: flex; gap: 10px; justify-content: center; margin-bottom: 20px; flex-wrap: wrap;
    }
    .guess-input-area input {
      background: rgba(0,0,0,0.4); border: 2px solid rgba(255,255,255,0.15);
      border-radius: 12px; padding: 12px 18px; color: #fff; font-size: 24px;
      width: 120px; text-align: center; outline: none;
    }
    .guess-input-area input:focus { border-color: #ffd700; }
    .guess-input-area button {
      padding: 12px 30px; border: none; border-radius: 12px;
      background: linear-gradient(90deg, #3498db, #2980b9); color: #fff;
      font-size: 16px; font-weight: 600; cursor: pointer; transition: all 0.2s;
    }
    .guess-input-area button:hover { transform: scale(1.05); }
    .guess-input-area button:disabled { opacity: 0.4; cursor: not-allowed; transform: none; }

    .guess-history {
      display: flex; flex-wrap: wrap; gap: 8px; justify-content: center; margin-bottom: 20px; min-height: 40px;
    }
    .guess-chip {
      padding: 6px 16px; border-radius: 20px; font-size: 14px; font-weight: 600;
    }
    .guess-chip.low { background: rgba(52,152,219,0.15); color: #3498db; }
    .guess-chip.high { background: rgba(231,76,60,0.15); color: #e74c3c; }
    .guess-chip.win-chip { background: rgba(46,204,113,0.15); color: #2ecc71; }

    .bet-area { display: flex; gap: 10px; align-items: center; justify-content: center; margin-bottom: 20px; flex-wrap: wrap; }
    .bet-area input {
      background: rgba(0,0,0,0.4); border: 2px solid rgba(255,215,0,0.3);
      border-radius: 12px; padding: 10px 18px; color: #fff; font-size: 18px;
      width: 140px; text-align: center; outline: none;
    }
    .bet-area input:disabled { opacity: 0.4; }
    .bet-area input:focus { border-color: #ffd700; }
    .bet-area .quick-bet button {
      background: rgba(255,255,255,0.1); border: 1px solid rgba(255,255,255,0.15);
      border-radius: 8px; color: #fff; padding: 8px 14px; cursor: pointer; font-size: 14px; transition: all 0.2s;
    }
    .bet-area .quick-bet button:disabled { opacity: 0.3; cursor: not-allowed; }
    .bet-area .quick-bet button:hover:not(:disabled) { background: rgba(255,215,0,0.2); border-color: #ffd700; }

    .btn-start {
      padding: 14px 50px; border: none; border-radius: 30px;
      background: linear-gradient(90deg, #2ecc71, #27ae60); color: #fff;
      font-size: 18px; font-weight: 700; cursor: pointer; transition: all 0.2s;
    }
    .btn-start:hover { transform: scale(1.05); }
    .btn-start:disabled { opacity: 0.4; cursor: not-allowed; transform: none; }

    .btn-new { padding: 12px 36px; border: none; border-radius: 30px; background: linear-gradient(90deg, #9C27B0, #7B1FA2); color: #fff; font-size: 16px; font-weight: 600; cursor: pointer; transition: all 0.2s; display: none; }
    .btn-new:hover { transform: scale(1.05); }

    .payout-table { background: rgba(0,0,0,0.3); border-radius: 16px; padding: 16px; margin-top: 20px; }
    .payout-table h3 { font-size: 14px; color: rgba(255,255,255,0.5); margin-bottom: 8px; }
    .payout-table .row { display: flex; justify-content: space-between; padding: 4px 0; font-size: 14px; color: rgba(255,255,255,0.7); }

    .toast {
      position: fixed; top: 80px; left: 50%; transform: translateX(-50%);
      background: rgba(0,0,0,0.85); color: #fff; padding: 12px 28px;
      border-radius: 12px; font-size: 15px; z-index: 999;
      opacity: 0; transition: opacity 0.3s; pointer-events: none;
    }
    .toast.show { opacity: 1; }
  </style>
</head>
<body>
  <nav>
    <a href="/games" class="brand">🔢 猜数字</a>
    <a href="/games">🎮 游戏中心</a>
    <a href="/games/blackjack">🃏 21点</a>
    <a href="/games/dice">🎲 骰子</a>
    <a href="/games/slot">🎰 老虎机</a>
    <span class="balance">💰 <span id="balanceDisplay"><%= user.balance.toFixed(2) %></span> 金币</span>
  </nav>

  <div class="toast" id="toast"></div>

  <div class="container">
    <div class="title">🔢 猜数字</div>
    <div class="subtitle">在 5 次机会内猜中 1-100 之间的数字，赢 3 倍奖励！</div>

    <div class="game-box">
      <!-- 下注区（新游戏前显示） -->
      <div class="bet-area" id="betArea">
        <input type="number" id="betInput" value="50" min="10" step="10">
        <div class="quick-bet">
          <button onclick="setBet(10)">10</button>
          <button onclick="setBet(50)">50</button>
          <button onclick="setBet(100)">100</button>
          <button onclick="setBet(<%= Math.floor(user.balance) %>)">All-in</button>
        </div>
        <button class="btn-start" id="startBtn" onclick="startGame()">🎯 开始游戏</button>
      </div>

      <!-- 游戏区域 -->
      <div id="gameArea" style="display:none">
        <div class="attempts-bar" id="attemptsBar"></div>

        <div class="range-display" id="rangeDisplay">1 - 100</div>
        <div class="range-label">范围</div>

        <div class="hint-area" id="hintArea">输入你的猜测</div>

        <div class="guess-history" id="guessHistory"></div>

        <div class="guess-input-area">
          <input type="number" id="guessInput" min="1" max="100" placeholder="?" autofocus>
          <button id="guessBtn" onclick="makeGuess()">🔍 猜</button>
        </div>

        <button class="btn-new" id="newGameBtn" onclick="startGame()">🔄 再来一局</button>
      </div>
    </div>

    <div class="payout-table">
      <h3>📊 规则</h3>
      <div class="row"><span>猜中数字</span><span>3 倍赔付</span></div>
      <div class="row"><span>5次机会</span><span>每次猜错会提示大小</span></div>
    </div>
  </div>

  <script>
    let gameActive = false;
    const csrf = '<%= csrfToken %>';

    function showToast(msg) {
      const t = document.getElementById('toast');
      t.textContent = msg; t.classList.add('show');
      setTimeout(() => t.classList.remove('show'), 2500);
    }
    function setBet(v) { document.getElementById('betInput').value = v; }

    function startGame() {
      const bet = parseFloat(document.getElementById('betInput').value);
      if (!bet || bet < 10) { showToast('最低下注 10 金币'); return; }

      document.getElementById('startBtn').disabled = true;
      document.getElementById('startBtn').textContent = '准备中…';

      fetch('/api/games/guess/start', {
        method: 'POST',
        headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
        body: 'bet=' + bet + '&_csrf=' + encodeURIComponent(csrf)
      })
      .then(r => r.json())
      .then(data => {
        if (!data.ok) { showToast(data.msg); document.getElementById('startBtn').disabled = false; document.getElementById('startBtn').textContent = '🎯 开始游戏'; return; }

        document.getElementById('balanceDisplay').textContent = data.balance.toFixed(2);
        document.getElementById('betArea').style.display = 'none';
        document.getElementById('gameArea').style.display = 'block';
        document.getElementById('newGameBtn').style.display = 'none';
        document.getElementById('guessBtn').style.display = 'inline-block';
        document.getElementById('guessInput').disabled = false;
        document.getElementById('guessInput').value = '';
        document.getElementById('guessInput').focus();
        document.getElementById('hintArea').textContent = '输入你的猜测';
        document.getElementById('hintArea').className = 'hint-area';
        document.getElementById('rangeDisplay').textContent = '1 - 100';
        document.getElementById('guessHistory').innerHTML = '';
        gameActive = true;

        renderAttempts(0, 5);
      })
      .catch(() => { showToast('网络错误'); document.getElementById('startBtn').disabled = false; document.getElementById('startBtn').textContent = '🎯 开始游戏'; });
    }

    function renderAttempts(used, total) {
      const bar = document.getElementById('attemptsBar');
      bar.innerHTML = '';
      for (let i = 0; i < total; i++) {
        const dot = document.createElement('div');
        dot.className = 'attempt-dot';
        if (i < used) dot.classList.add('used');
        else if (i === used) dot.classList.add('active');
        dot.textContent = i + 1;
        bar.appendChild(dot);
      }
    }

    function makeGuess() {
      if (!gameActive) return;
      const guess = parseInt(document.getElementById('guessInput').value);
      if (isNaN(guess) || guess < 1 || guess > 100) { showToast('请输入 1-100 之间的数字'); return; }

      document.getElementById('guessBtn').disabled = true;
      document.getElementById('guessInput').disabled = true;

      fetch('/api/games/guess/play', {
        method: 'POST',
        headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
        body: 'guess=' + guess + '&_csrf=' + encodeURIComponent(csrf)
      })
      .then(r => r.json())
      .then(data => {
        if (!data.ok) { showToast(data.msg); document.getElementById('guessBtn').disabled = false; document.getElementById('guessInput').disabled = false; return; }

        // 更新尝试次数条
        renderAttempts(data.attempts, data.maxAttempts);

        // 更新历史
        const history = document.getElementById('guessHistory');
        const chip = document.createElement('div');
        chip.className = 'guess-chip';
        if (data.win) {
          chip.classList.add('win-chip');
          chip.textContent = `✅ ${guess}`;
        } else if (data.hint && data.hint.includes('小了')) {
          chip.classList.add('low');
          chip.textContent = `⬆ ${guess}`;
        } else if (data.hint && data.hint.includes('大了')) {
          chip.classList.add('high');
          chip.textContent = `⬇ ${guess}`;
        }
        history.appendChild(chip);

        // 更新提示
        const hint = document.getElementById('hintArea');
        if (data.win) {
          hint.textContent = `🎉 猜中了！就是 ${data.secret}！赢得 ${data.bet * 3} 金币！`;
          hint.className = 'hint-area hint-win';
          // 标记所有点数为绿色
          document.querySelectorAll('.attempt-dot').forEach(d => d.classList.add('win-dot'));
          gameActive = false;
          endGame();
        } else if (data.done) {
          hint.textContent = `😞 游戏结束！正确答案是 ${data.secret}`;
          hint.className = 'hint-area hint-lose';
          gameActive = false;
          endGame();
        } else {
          hint.textContent = data.hint;
          hint.className = 'hint-area ' + (data.remaining <= 2 ? 'hint-hot' : 'hint-cold');
          document.getElementById('guessInput').value = '';
          document.getElementById('guessInput').disabled = false;
          document.getElementById('guessBtn').disabled = false;
          document.getElementById('guessInput').focus();
        }

        // 更新余额
        if (data.balance) document.getElementById('balanceDisplay').textContent = data.balance.toFixed(2);
      })
      .catch(() => { showToast('网络错误'); document.getElementById('guessBtn').disabled = false; document.getElementById('guessInput').disabled = false; });
    }

    function endGame() {
      document.getElementById('guessBtn').style.display = 'none';
      document.getElementById('newGameBtn').style.display = 'inline-block';
      document.getElementById('guessInput').disabled = true;
    }

    // 回车键提交
    document.addEventListener('keydown', function(e) {
      if (e.key === 'Enter') {
        if (!gameActive && document.getElementById('startBtn').style.display !== 'none') {
          startGame();
        } else if (gameActive) {
          makeGuess();
        }
      }
    });
  </script>
</body>
</html>