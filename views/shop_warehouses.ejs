<!DOCTYPE html>
<html lang="zh-CN">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>仓库管理 - <%= shop.name %></title>
  <style>
    *{box-sizing:border-box;margin:0;padding:0}
    body{font-family:-apple-system,BlinkMacSystemFont,'Segoe UI',sans-serif;background:#f3f4f6;color:#1f2937;min-height:100vh}
    .container{max-width:800px;margin:0 auto;padding:20px}
    .header{background:linear-gradient(135deg,#667eea,#764ba2);color:white;padding:24px;border-radius:16px;margin-bottom:20px}
    .header h1{font-size:22px;margin-bottom:4px}
    .card{background:white;border-radius:16px;padding:20px;margin-bottom:16px;box-shadow:0 1px 3px rgba(0,0,0,.06)}
    .card h3{font-size:16px;margin-bottom:12px;display:flex;align-items:center;gap:8px}
    .form-row{display:flex;gap:10px;flex-wrap:wrap}
    .form-row input{flex:1;min-width:140px;padding:10px 12px;border:2px solid #e5e7eb;border-radius:10px;font-size:14px;font-family:inherit}
    .form-row input:focus{outline:none;border-color:#667eea}
    .btn{padding:10px 18px;border:none;border-radius:10px;font-size:14px;font-weight:600;cursor:pointer;font-family:inherit;transition:all .15s}
    .btn-primary{background:linear-gradient(135deg,#667eea,#764ba2);color:white}
    .btn-danger{background:#fee2e2;color:#dc2626}
    .wh-item{display:flex;justify-content:space-between;align-items:center;padding:12px 0;border-bottom:1px solid #f3f4f6}
    .wh-item:last-child{border-bottom:none}
    .wh-info{flex:1}
    .wh-name{font-weight:600;font-size:15px}
    .wh-addr{font-size:13px;color:#6b7280}
    .back{display:inline-block;margin-bottom:16px;color:#667eea;text-decoration:none;font-size:14px;font-weight:500}
    .empty{text-align:center;padding:40px;color:#9ca3af}
  </style>
</head>
<body>
<div class="container">
  <a class="back" href="/shop/manage">← 返回店铺管理</a>
  <div class="header">
    <h1>🏭 仓库管理</h1>
    <p style="opacity:0.85"><%= shop.name %></p>
  </div>
  <div class="card">
    <h3>➕ 添加仓库</h3>
    <form method="POST" action="/shop/warehouses/add" class="form-row">
      <input name="name" placeholder="仓库名称（如：上海仓）" required>
      <input name="address" placeholder="地址（选填）">
      <input name="city" list="cityList" placeholder="仓库所在城市" style="flex:1;min-width:140px;padding:10px 12px;border:2px solid #e5e7eb;border-radius:10px;font-size:14px;font-family:inherit" autocomplete="off">
      <select name="city" style="flex:1;min-width:140px;padding:10px 12px;border:2px solid #e5e7eb;border-radius:10px;font-size:14px;font-family:inherit">
        <option value="">选择城市</option>
        <option value="北京">北京</option>
        <option value="上海">上海</option>
        <option value="广州">广州</option>
        <option value="深圳">深圳</option>
        <option value="杭州">杭州</option>
        <option value="成都">成都</option>
        <option value="武汉">武汉</option>
        <option value="南京">南京</option>
        <option value="重庆">重庆</option>
        <option value="天津">天津</option>
        <option value="西安">西安</option>
        <option value="长沙">长沙</option>
        <option value="郑州">郑州</option>
        <option value="苏州">苏州</option>
        <option value="厦门">厦门</option>
      </select>
      <button type="submit" class="btn btn-primary">添加</button>
    </form>
  </div>
  <div class="card">
    <h3>📋 仓库列表</h3>
    <% if (warehouses.length === 0) { %>
      <div class="empty">暂无仓库，请添加</div>
    <% } else { %>
      <% warehouses.forEach(function(w) { %>
        <div class="wh-item">
          <div class="wh-info">
            <div class="wh-name"><%= w.name %></div>
            <div class="wh-addr"><%= w.address || '未填写地址' %></div>
          </div>
          <form method="POST" action="/shop/warehouses/delete/<%= w.id %>" onsubmit="return confirm('确定删除该仓库？')">
            <button class="btn btn-danger">删除</button>
          </form>
        </div>
      <% }) %>
    <% } %>
  </div>
</div>
<datalist id="cityList">
