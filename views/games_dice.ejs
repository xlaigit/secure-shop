<!DOCTYPE html>
<html lang="zh-CN">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>骰子游戏 - 游戏中心</title>
  <link rel="icon" href="data:image/svg+xml,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 100 100'><text y='.9em' font-size='90'>🎲</text></svg>">
  <style>
    * { margin: 0; padding: 0; box-sizing: border-box; }
    body {
      font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
      background: linear-gradient(135deg, #1a0033, #2d1b69, #1a0033);
      min-height: 100vh; color: #fff;
    }
    nav {
      background: rgba(0,0,0,0.3); backdrop-filter: blur(12px);
      padding: 12px 24px; display: flex; align-items: center; gap: 16px;
      border-bottom: 1px solid rgba(255,255,255,0.08);
    }
    nav a { color: rgba(255,255,255,0.7); text-decoration: none; font-size: 14px; padding: 6px 14px; border-radius: 8px; transition: all 0.2s; }
    nav a:hover { background: rgba(255,255,255,0.1); color: #fff; }
    nav .brand { font-size: 20px; font-weight: 700; color: #ffd700; margin-right: auto; }
    nav .balance { background: rgba(255,215,0,0.15); color: #ffd700; padding: 6px 16px; border-radius: 20px; font-size: 14px; font-weight: 600; }

    .container { max-width: 600px; margin: 0 auto; padding: 40px 20px; text-align: center; }
    .title { font-size: 32px; font-weight: 800; color: #ffd700; margin-bottom: 6px; }
    .subtitle { color: rgba(255,255,255,0.5); font-size: 14px; margin-bottom: 30px; }

    /* ==================== 3D 骰子 ==================== */
    .dice-scene {
      width: 200px; height: 200px;
      margin: 10px auto 30px;
      perspective: 800px;
      perspective-origin: 50% 50%;
    }
    .dice-cube {
      width: 200px; height: 200px;
      position: relative;
      transform-style: preserve-3d;
      transform: rotateX(-10deg) rotateY(20deg);
    }

    .dice-face {
      position: absolute;
      width: 200px; height: 200px;
      background: linear-gradient(145deg, #ffffff, #e8e8e8);
      border: 2px solid rgba(0,0,0,0.08);
      border-radius: 28px;
      box-shadow: inset 0 0 30px rgba(0,0,0,0.06), 0 4px 20px rgba(0,0,0,0.15);
      display: grid;
      padding: 20px;
    }

    /* 骰子面定位 */
    .face-1 { transform: rotateX(0deg) translateZ(100px); }
    .face-6 { transform: rotateX(180deg) translateZ(100px); }
    .face-2 { transform: rotateY(90deg) translateZ(100px); }
    .face-5 { transform: rotateY(-90deg) translateZ(100px); }
    .face-3 { transform: rotateX(-90deg) translateZ(100px); }
    .face-4 { transform: rotateX(90deg) translateZ(100px); }

    /* 骰子点 - 通用网格布局 */
    .dice-face { grid-template-columns: repeat(3, 1fr); grid-template-rows: repeat(3, 1fr); }
    .dot {
      width: 28px; height: 28px;
      background: radial-gradient(circle at 35% 35%, #333, #111);
      border-radius: 50%;
      box-shadow: inset 0 2px 4px rgba(255,255,255,0.2), 0 2px 4px rgba(0,0,0,0.3);
      justify-self: center; align-self: center;
      transition: all 0.1s;
    }

    /* 每个面的点布局 */
    .face-1 .dot { grid-column: 2; grid-row: 2; }
    .face-2 .dot:nth-child(1) { grid-column: 3; grid-row: 1; }
    .face-2 .dot:nth-child(2) { grid-column: 1; grid-row: 3; }
    .face-3 .dot:nth-child(1) { grid-column: 3; grid-row: 1; }
    .face-3 .dot:nth-child(2) { grid-column: 2; grid-row: 2; }
    .face-3 .dot:nth-child(3) { grid-column: 1; grid-row: 3; }
    .face-4 .dot:nth-child(1) { grid-column: 1; grid-row: 1; }
    .face-4 .dot:nth-child(2) { grid-column: 3; grid-row: 1; }
    .face-4 .dot:nth-child(3) { grid-column: 1; grid-row: 3; }
    .face-4 .dot:nth-child(4) { grid-column: 3; grid-row: 3; }
    .face-5 .dot:nth-child(1) { grid-column: 1; grid-row: 1; }
    .face-5 .dot:nth-child(2) { grid-column: 3; grid-row: 1; }
    .face-5 .dot:nth-child(3) { grid-column: 2; grid-row: 2; }
    .face-5 .dot:nth-child(4) { grid-column: 1; grid-row: 3; }
    .face-5 .dot:nth-child(5) { grid-column: 3; grid-row: 3; }
    .face-6 .dot:nth-child(1) { grid-column: 1; grid-row: 1; }
    .face-6 .dot:nth-child(2) { grid-column: 3; grid-row: 1; }
    .face-6 .dot:nth-child(3) { grid-column: 1; grid-row: 2; }
    .face-6 .dot:nth-child(4) { grid-column: 3; grid-row: 2; }
    .face-6 .dot:nth-child(5) { grid-column: 1; grid-row: 3; }
    .face-6 .dot:nth-child(6) { grid-column: 3; grid-row: 3; }

    /* 桌面阴影 */
    .dice-shadow {
      width: 160px; height: 40px;
      margin: -20px auto 30px;
      background: radial-gradient(ellipse, rgba(0,0,0,0.25) 0%, transparent 70%);
      border-radius: 50%;
      transition: all 0.5s;
    }
    .dice-shadow.rolling {
      animation: shadowPulse 2.2s ease;
    }
    @keyframes shadowPulse {
      0% { transform: scale(1); opacity: 1; }
      30% { transform: scale(0.7); opacity: 0.5; }
      70% { transform: scale(0.8); opacity: 0.6; }
      100% { transform: scale(1); opacity: 1; }
    }

    /* ==================== 控制区 ==================== */
    .guess-grid {
      display: flex; gap: 10px; justify-content: center; flex-wrap: wrap;
      margin-bottom: 24px;
    }
    .guess-btn {
      width: 64px; height: 64px; border: 2px solid rgba(255,255,255,0.15);
      border-radius: 16px; background: rgba(255,255,255,0.05);
      color: #fff; font-size: 28px; cursor: pointer;
      transition: all 0.2s; display: flex; align-items: center; justify-content: center;
    }
    .guess-btn:hover { border-color: #ffd700; background: rgba(255,215,0,0.1); transform: translateY(-3px); }
    .guess-btn.selected { border-color: #ffd700; background: rgba(255,215,0,0.2); box-shadow: 0 0 20px rgba(255,215,0,0.3); }
    .guess-btn:disabled { opacity: 0.4; cursor: not-allowed; transform: none; }

    .bet-area { display: flex; gap: 10px; align-items: center; justify-content: center; margin-bottom: 20px; flex-wrap: wrap; }
    .bet-area input {
      background: rgba(0,0,0,0.4); border: 2px solid rgba(255,215,0,0.3);
      border-radius: 12px; padding: 10px 18px; color: #fff; font-size: 18px;
      width: 140px; text-align: center; outline: none;
    }
    .bet-area input:focus { border-color: #ffd700; }
    .bet-area .quick-bet button {
      background: rgba(255,255,255,0.1); border: 1px solid rgba(255,255,255,0.15);
      border-radius: 8px; color: #fff; padding: 8px 14px; cursor: pointer; font-size: 14px; transition: all 0.2s;
    }
    .bet-area .quick-bet button:hover { background: rgba(255,215,0,0.2); border-color: #ffd700; }

    .btn-roll {
      padding: 14px 50px; border: none; border-radius: 30px;
      background: linear-gradient(90deg, #f7971e, #ffd200); color: #000;
      font-size: 18px; font-weight: 700; cursor: pointer;
      transition: all 0.2s; margin-bottom: 20px;
    }
    .btn-roll:hover { transform: scale(1.05); box-shadow: 0 0 30px rgba(255,215,0,0.3); }
    .btn-roll:disabled { opacity: 0.4; cursor: not-allowed; transform: none; }

    .result { font-size: 24px; font-weight: 700; margin-bottom: 16px; min-height: 40px; }
    .result.win { color: #ffd700; }
    .result.lose { color: #ff6b6b; }

    .payout-table { background: rgba(0,0,0,0.3); border-radius: 16px; padding: 16px; margin-top: 20px; }
    .payout-table h3 { font-size: 14px; color: rgba(255,255,255,0.5); margin-bottom: 8px; }
    .payout-table .row { display: flex; justify-content: space-between; padding: 4px 0; font-size: 14px; color: rgba(255,255,255,0.7); }

    .toast {
      position: fixed; top: 80px; left: 50%; transform: translateX(-50%);
      background: rgba(0,0,0,0.85); color: #fff; padding: 12px 28px;
      border-radius: 12px; font-size: 15px; z-index: 999;
      opacity: 0; transition: opacity 0.3s; pointer-events: none;
    }
    .toast.show { opacity: 1; }

    @media (max-width: 500px) {
      .dice-scene { width: 160px; height: 160px; }
      .dice-face { width: 160px; height: 160px; }
      .face-1 { transform: rotateX(0deg) translateZ(80px); }
      .face-6 { transform: rotateX(180deg) translateZ(80px); }
      .face-2 { transform: rotateY(90deg) translateZ(80px); }
      .face-5 { transform: rotateY(-90deg) translateZ(80px); }
      .face-3 { transform: rotateX(-90deg) translateZ(80px); }
      .face-4 { transform: rotateX(90deg) translateZ(80px); }
      .dice-cube { width: 160px; height: 160px; }
      .dot { width: 22px; height: 22px; }
    }
  </style>
</head>
<body>
  <nav>
    <a href="/games" class="brand">🎲 骰子游戏</a>
    <a href="/games">🎮 游戏中心</a>
    <a href="/games/blackjack">🃏 21点</a>
    <a href="/games/slot">🎰 老虎机</a>
    <a href="/games/guess">🔢 猜数字</a>
    <span class="balance">💰 <span id="balanceDisplay"><%= user.balance.toFixed(2) %></span> 金币</span>
  </nav>

  <div class="toast" id="toast"></div>

  <div class="container">
    <div class="title">🎲 3D 骰子</div>
    <div class="subtitle">猜中骰子点数即赢 5 倍赔付！</div>

    <!-- 3D 骰子 -->
    <div class="dice-scene">
      <div class="dice-cube" id="diceCube">
        <div class="dice-face face-1">
          <div class="dot"></div>
        </div>
        <div class="dice-face face-2">
          <div class="dot"></div><div class="dot"></div>
        </div>
        <div class="dice-face face-3">
          <div class="dot"></div><div class="dot"></div><div class="dot"></div>
        </div>
        <div class="dice-face face-4">
          <div class="dot"></div><div class="dot"></div><div class="dot"></div><div class="dot"></div>
        </div>
        <div class="dice-face face-5">
          <div class="dot"></div><div class="dot"></div><div class="dot"></div><div class="dot"></div><div class="dot"></div>
        </div>
        <div class="dice-face face-6">
          <div class="dot"></div><div class="dot"></div><div class="dot"></div><div class="dot"></div><div class="dot"></div><div class="dot"></div>
        </div>
      </div>
    </div>
    <div class="dice-shadow" id="diceShadow"></div>

    <div class="result" id="result"></div>

    <div class="guess-grid" id="guessGrid">
      <% for (let i = 1; i <= 6; i++) { %>
        <button class="guess-btn" onclick="selectGuess(<%= i %>)" data-val="<%= i %>">
          <%= ['⚀','⚁','⚂','⚃','⚄','⚅'][i-1] %>
        </button>
      <% } %>
    </div>

    <div class="bet-area">
      <input type="number" id="betInput" value="50" min="10" step="10">
      <div class="quick-bet">
        <button onclick="setBet(10)">10</button>
        <button onclick="setBet(50)">50</button>
        <button onclick="setBet(100)">100</button>
        <button onclick="setBet(<%= Math.floor(user.balance) %>)">All-in</button>
      </div>
    </div>

    <button class="btn-roll" id="rollBtn" onclick="rollDice()">🎲 掷骰子</button>

    <div class="payout-table">
      <h3>📊 赔付规则</h3>
      <div class="row"><span>猜中数字</span><span>5 倍赔付</span></div>
      <div class="row"><span>猜错</span><span>失去赌注</span></div>
    </div>
  </div>

  <script>
    let selectedGuess = null;
    let isRolling = false;
    let currentRotX = -10;
    let currentRotY = 20;
    let idleRAF = null;
    let idleStartTime = null;
    const csrf = '<%= csrfToken %>';

    // 骰子面 → 旋转角度（使对应面朝向屏幕）
    // 每个面的CSS定位：face-N是 rotateX/Y(deg) translateZ(100px)
    // 要让该面朝前，需将整个立方体旋转该面的反向角度
    const faceAngles = {
      1: { x: 0, y: 0 },
      2: { x: 0, y: -90 },
      3: { x: 90, y: 0 },
      4: { x: -90, y: 0 },
      5: { x: 0, y: 90 },
      6: { x: 180, y: 0 }
    };

    // ========== Idle 晃动动画（JS实现，精确追踪角度） ==========
    function startIdleAnimation() {
      const cube = document.getElementById('diceCube');
      idleStartTime = Date.now();
      cube.style.transition = 'none';

      function animate() {
        if (isRolling) { idleRAF = requestAnimationFrame(animate); return; }
        const elapsed = (Date.now() - idleStartTime) / 1000;
        const phase = (elapsed % 4) / 4; // 4秒一个周期
        const angle = phase * Math.PI * 2;

        // 平滑正弦摆动：X从-10到-5，Y从20到25
        const rotX = -10 + 5 * (Math.sin(angle) * 0.5 + 0.5);
        const rotY = 20 + 5 * (Math.cos(angle) * 0.5 + 0.5);

        currentRotX = rotX;
        currentRotY = rotY;
        cube.style.transform = 'rotateX(' + rotX + 'deg) rotateY(' + rotY + 'deg)';

        idleRAF = requestAnimationFrame(animate);
      }
      idleRAF = requestAnimationFrame(animate);
    }

    function stopIdleAnimation() {
      if (idleRAF) {
        cancelAnimationFrame(idleRAF);
        idleRAF = null;
      }
    }

    // ========== UI 函数 ==========
    function showToast(msg) {
      const t = document.getElementById('toast');
      t.textContent = msg; t.classList.add('show');
      setTimeout(() => t.classList.remove('show'), 2500);
    }
    function setBet(v) { document.getElementById('betInput').value = v; }
    function selectGuess(n) {
      document.querySelectorAll('.guess-btn').forEach(b => b.classList.remove('selected'));
      document.querySelector(`.guess-btn[data-val="${n}"]`).classList.add('selected');
      selectedGuess = n;
    }

    // ========== 掷骰子 ==========
    function rollDice() {
      if (isRolling) return;
      const bet = parseFloat(document.getElementById('betInput').value);
      if (!bet || bet < 10) { showToast('最低下注 10 金币'); return; }
      if (!selectedGuess) { showToast('请先选择一个点数'); return; }

      isRolling = true;
      document.getElementById('rollBtn').disabled = true;
      document.getElementById('result').textContent = '';
      document.getElementById('diceShadow').classList.add('rolling');

      fetch('/api/games/dice/roll', {
        method: 'POST',
        headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
        body: 'bet=' + bet + '&guess=' + selectedGuess + '&_csrf=' + encodeURIComponent(csrf)
      })
      .then(r => r.json())
      .then(data => {
        const result = data.roll;
        const target = faceAngles[result];

        // 1) 停止idle动画，记录当前角度
        stopIdleAnimation();

        // 2) 从当前精确角度计算到目标的最短路径
        const effX = ((currentRotX % 360) + 360) % 360;
        const effY = ((currentRotY % 360) + 360) % 360;

        let diffX = target.x - effX;
        let diffY = target.y - effY;
        if (diffX > 180) diffX -= 360;
        else if (diffX < -180) diffX += 360;
        if (diffY > 180) diffY -= 360;
        else if (diffY < -180) diffY += 360;

        // 3) 额外旋转圈数
        const extraSpinsX = 3 + Math.floor(Math.random() * 2);
        const extraSpinsY = 2 + Math.floor(Math.random() * 3);
        diffX += extraSpinsX * 360;
        diffY += extraSpinsY * 360;

        // 4) 累积到当前角度
        currentRotX += diffX;
        currentRotY += diffY;

        // 5) 应用滚动过渡和变换
        const cube = document.getElementById('diceCube');
        cube.style.transition = 'transform 2.4s cubic-bezier(0.08, 0.52, 0.24, 1.0)';
        // 强制重排以确保transition生效
        void cube.offsetWidth;
        cube.style.transform = 'rotateX(' + currentRotX + 'deg) rotateY(' + currentRotY + 'deg)';

        // 6) 动画结束后显示结果
        setTimeout(() => {
          document.getElementById('diceShadow').classList.remove('rolling');

          const resultEl = document.getElementById('result');
          if (data.win) {
            resultEl.className = 'result win';
            resultEl.textContent = '🎉 中了！骰子是 ' + result + ' 点，赢得 ' + data.payout + ' 金币！';
            showToast('🎉 +' + data.payout + ' 金币！');
          } else {
            resultEl.className = 'result lose';
            resultEl.textContent = '😞 骰子是 ' + result + ' 点，猜错了';
          }
          document.getElementById('balanceDisplay').textContent = data.balance.toFixed(2);
          isRolling = false;
          document.getElementById('rollBtn').disabled = false;
        }, 2500);
      })
      .catch(() => { showToast('网络错误'); isRolling = false; document.getElementById('rollBtn').disabled = false; });
    }

    // 页面加载后启动idle动画
    document.addEventListener('DOMContentLoaded', startIdleAnimation);
  </script>
</body>
</html>