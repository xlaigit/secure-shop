<!DOCTYPE html>
<html>
<head>
  <meta charset="UTF-8">
  <title><%= group.name %> - 群聊</title>
  <style>
    :root{--bg:#07111f;--panel:#0f172a;--panel2:#111c2f;--text:#f8fafc;--muted:#94a3b8;--accent:#38bdf8;--accent2:#34d399;--border:rgba(255,255,255,0.12);--self:#1e40af;--other:#1e293b}
    *{box-sizing:border-box} body{margin:0;font-family:Inter,Segoe UI,Arial,sans-serif;background:linear-gradient(135deg,#07111f,#111827);color:var(--text)}
    .nav{display:flex;justify-content:space-between;align-items:center;padding:14px 24px;background:rgba(15,23,42,0.95);backdrop-filter:blur(10px);border-bottom:1px solid var(--border)}
    .nav a{color:#dbeafe;text-decoration:none;margin-left:10px;padding:6px 10px;border-radius:999px;font-size:14px} .nav a:hover{background:rgba(56,189,248,0.16)}
    .wrap{max-width:800px;margin:20px auto;padding:0 16px 24px}
    .card{background:rgba(15,23,42,0.92);border:1px solid var(--border);border-radius:20px;box-shadow:0 20px 40px rgba(0,0,0,0.25)}
    .chat{display:flex;flex-direction:column;height:620px}
    .header{padding:14px 16px;border-bottom:1px solid var(--border);display:flex;justify-content:space-between;align-items:center}
    .members{padding:10px 16px;border-bottom:1px solid var(--border);background:rgba(255,255,255,0.03);display:flex;flex-wrap:wrap;gap:6px;align-items:center}
    .member-pill{display:inline-flex;align-items:center;gap:4px;padding:4px 10px;background:rgba(52,211,153,0.16);color:#bbf7d0;border-radius:999px;font-size:12px}
    .member-pill img{width:18px;height:18px;border-radius:50%;object-fit:cover}
    .messages{flex:1;overflow-y:auto;padding:16px;background:linear-gradient(180deg,rgba(56,189,248,0.04),rgba(255,255,255,0.01))}
    .msg{display:flex;margin:8px 0;align-items:flex-start;gap:8px}
    .msg.self{flex-direction:row-reverse}
    .msg-avatar{width:34px;height:34px;border-radius:50%;background:var(--accent);display:flex;align-items:center;justify-content:center;font-size:14px;font-weight:700;flex-shrink:0;overflow:hidden}
    .msg-avatar img{width:100%;height:100%;object-fit:cover}
    .msg-body{max-width:65%}
    .msg-bubble{padding:10px 14px;border-radius:16px;background:var(--other);line-height:1.45;word-break:break-all}
    .msg.self .msg-bubble{background:var(--self)}
    .msg-name{font-size:12px;color:var(--muted);margin-bottom:2px}
    .msg-time{font-size:11px;color:var(--muted);margin-top:4px}
    .msg.self .msg-time{text-align:right}
    .input-area{display:flex;padding:12px;border-top:1px solid var(--border);gap:10px;background:rgba(0,0,0,0.2);border-radius:0 0 20px 20px}
    .input-area input{flex:1;padding:11px 16px;border:1px solid var(--border);border-radius:999px;background:#0b1220;color:var(--text);font-size:14px;outline:none}
    .input-area input:focus{border-color:var(--accent)}
    .input-area button{border:none;border-radius:999px;padding:10px 22px;background:linear-gradient(90deg,var(--accent),#2563eb);color:#fff;cursor:pointer;font-weight:600;font-size:14px}
    .input-area button:hover{opacity:0.9}
    .back{color:var(--accent);text-decoration:none;font-size:14px;margin-bottom:12px;display:inline-block}
    .back:hover{text-decoration:underline}
    .sys-msg{text-align:center;color:var(--muted);font-size:12px;padding:8px 0}
  </style>
</head>
<body>
  <div class="nav">
    <div><strong>💬 <%= group.name %></strong></div>
    <div>
      <a href="/chat">← 群列表</a>
      <a href="/shop">商城</a>
      <a href="/friends">好友</a>
      <a href="/logout">注销</a>
    </div>
  </div>
  <div class="wrap">
    <div class="card chat">
      <div class="header">
        <span>👥 <strong><%= group.name %></strong></span>
        <span style="color:var(--muted);font-size:13px"><%= members.length %> 人</span>
      </div>
      <div class="members">
        <span style="color:var(--muted);font-size:13px;margin-right:6px">成员：</span>
        <% members.forEach(function(m){ %>
          <span class="member-pill">
            <% if (m.avatar && m.avatar.length > 0){ %><img src="<%= m.avatar %>"><% } %>
            <%= m.username %>
          </span>
        <% }); %>
      </div>
      <div class="messages" id="messages">
        <% messages.forEach(function(m){ %>
          <div class="msg <%= m.from_user == user.id ? 'self' : '' %>">
            <div class="msg-avatar">
              <% if (m.avatar && m.avatar.length > 0){ %><img src="<%= m.avatar %>"><% } else { %><%= m.username.charAt(0).toUpperCase() %><% } %>
            </div>
            <div class="msg-body">
              <% if (m.from_user != user.id) { %><div class="msg-name"><%= m.username %></div><% } %>
              <div class="msg-bubble"><%= m.message %></div>
              <div class="msg-time"><%= m.time %></div>
            </div>
          </div>
        <% }); %>
      </div>
      <div class="input-area">
        <input id="msgInput" placeholder="输入消息..." maxlength="500">
        <button id="sendBtn">发送</button>
      </div>
    </div>
  </div>
  <script src="/socket.io/socket.io.js"></script>
  <script>
  (function(){
    var socket = io();
    var groupId = <%= group.id %>;
    var userId = <%= user.id %>;
    var username = '<%= user.username %>';
    var msgs = document.getElementById('messages');
    var inp = document.getElementById('msgInput');
    var sendBtn = document.getElementById('sendBtn');

    function scrollBottom() { msgs.scrollTop = msgs.scrollHeight; }

    function addMsg(data, isSelf) {
      var div = document.createElement('div');
      div.className = 'msg' + (isSelf ? ' self' : '');
      var avatarHtml;
      if (data.avatar) {
        avatarHtml = '<img src="' + data.avatar + '">';
      } else {
        avatarHtml = (data.from || '?').charAt(0).toUpperCase();
      }
      div.innerHTML = '<div class="msg-avatar">' + avatarHtml + '</div>' +
        '<div class="msg-body">' + (isSelf ? '' : '<div class="msg-name">' + data.from + '</div>') +
        '<div class="msg-bubble">' + data.message + '</div>' +
        '<div class="msg-time">' + data.time + '</div></div>';
      msgs.appendChild(div);
      scrollBottom();
    }

    function sendMsg() {
      var m = inp.value.trim();
      if (!m) return;
      socket.emit('groupMsg', { groupId: groupId, message: m });
      inp.value = '';
      inp.focus();
    }

    socket.on('connect', function() {
      socket.emit('login', { id: userId, username: username });
      socket.emit('joinGroup', groupId);
      socket.emit('markRead', { groupId: groupId });
    });

    socket.on('newGroupMsg', function(data) {
      if (data.groupId === groupId) {
        addMsg(data, data.fromId === userId);
        socket.emit('markRead', { groupId: groupId });
      }
    });

    sendBtn.onclick = sendMsg;
    inp.onkeypress = function(e) { if (e.key === 'Enter') sendMsg(); };

    scrollBottom();
  })();
  </script>
</body>
</html>