    <input type="hidden" name="_csrf" value="<%= csrfToken %>">
    <label>店铺名：<input name="name" required></label><br>
    <label>描述：<textarea name="desc"></textarea></label><br>
    <button type="submit">创建</button>
  </form>
</body></html>