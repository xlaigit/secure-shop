    at Module._extensions..js (node:internal/modules/cjs/loader:1308:10)
    at Module.load (node:internal/modules/cjs/loader:1117:32)
    at Module._load (node:internal/modules/cjs/loader:958:12)
    at Function.executeUserEntryPoint [as runMain] (node:internal/modules/run_main:81:12)
    at node:internal/main/run_main_module:23:47

      <h3 style="font-size:18px;margin-bottom:12px">📦 快递追踪</h3>
      <% shipments.forEach(function(s) { %>
        <div style="display:flex;justify-content:space-between;align-items:center;padding:12px 0;border-bottom:1px solid #f3f4f6">
          <div>
            <strong><%= s.product_name %></strong>
            <span style="color:#6b7280;margin-left:8px;font-size:13px"><%= s.carrier %> · <%= s.tracking_number %></span>
            <span style="color:#6b7280;margin-left:8px;font-size:13px">运费¥<%= s.shipping_fee || 0 %></span>
          </div>
          <div>
            <% if (s.status === 'shipped') { %><span style="color:#f59e0b;font-weight:600">🚚 运输中</span>
            <% } else if (s.status === 'delivered') { %><span style="color:#10b981;font-weight:600">📬 已送达</span>
            <% } %>
            <a href="/orders/<%= s.order_id %>/track" style="margin-left:12px;color:#4338ca;text-decoration:none;font-size:13px">查看→</a>
          </div>
        </div>
      <% }) %>
    </div>
    <% } %>
  </div>

  <script>
  (function(){
   document.querySelectorAll('.flash-timer').forEach(function(el){
    var end = new Date(el.dataset.end).getTime();
    var span = el.querySelector('.countdown');
    if(!span) return;
    function tick(){
      var left = end - Date.now();
      if(left <= 0){ span.textContent = '已结束'; return; }
      var h = Math.floor(left / 3600000);
      var m = Math.floor((left % 3600000) / 60000);
      var s = Math.floor((left % 60000) / 1000);
      span.textContent = h + '时' + m + '分' + s + '秒';
      setTimeout(tick, 1000);
    }
    tick();
   });
 })();
 </script>

</body>
</html>