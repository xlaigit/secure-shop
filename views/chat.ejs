<!DOCTYPE html>
<html>
<head>
  <meta charset="UTF-8">
  <title>聊天室</title>
  <style>
    :root{--bg:#07111f;--panel:#0f172a;--panel2:#111c2f;--text:#f8fafc;--muted:#94a3b8;--accent:#38bdf8;--accent2:#34d399;--border:rgba(255,255,255,0.12)}
    *{box-sizing:border-box} body{margin:0;font-family:Inter,Segoe UI,Arial,sans-serif;background:linear-gradient(135deg,#07111f,#111827);color:var(--text)}
    .nav{display:flex;justify-content:space-between;align-items:center;padding:16px 24px;background:rgba(15,23,42,0.95);backdrop-filter:blur(10px);border-bottom:1px solid var(--border)}
    .nav a{color:#dbeafe;text-decoration:none;margin-left:10px;padding:6px 10px;border-radius:999px} .nav a:hover{background:rgba(56,189,248,0.16)}
    .wrap{max-width:1200px;margin:20px auto;padding:0 16px 24px}
    .shell{display:grid;grid-template-columns:1.4fr 0.6fr;gap:20px}
    .card{background:rgba(15,23,42,0.92);border:1px solid var(--border);border-radius:20px;box-shadow:0 20px 40px rgba(0,0,0,0.25)}
    .chat{display:flex;flex-direction:column;height:620px}
    .header{padding:14px 16px;border-bottom:1px solid var(--border);display:flex;justify-content:space-between;align-items:center}
    .members{padding:10px 16px;border-bottom:1px solid var(--border);background:rgba(255,255,255,0.03)}
    .messages{flex:1;overflow-y:auto;padding:16px;background:linear-gradient(180deg,rgba(56,189,248,0.04),rgba(255,255,255,0.01))}
    .msg{margin:10px 0;max-width:82%;padding:10px 12px;border-radius:14px;background:rgba(56,189,248,0.16);border:1px solid rgba(56,189,248,0.2)}
    .msg .user{font-weight:700;color:#bae6fd;font-size:13px;margin-bottom:6px}
    .msg .text{word-break:break-all;line-height:1.45}
    .msg .time{font-size:11px;color:var(--muted);margin-top:6px}
    .msg .report{font-size:11px;color:#fca5a5;cursor:pointer;margin-left:10px;text-decoration:none;opacity:0.7;transition:opacity 0.15s}
    .msg .report:hover{opacity:1;text-decoration:underline}
    .file-msg{background:rgba(52,211,153,0.12);border-color:rgba(52,211,153,0.2)}
    .file-msg a{color:#bbf7d0}
    .input-area{display:flex;padding:12px;border-top:1px solid var(--border);gap:10px}
    .input-area input{flex:1;padding:11px 12px;border:1px solid var(--border);border-radius:999px;background:#0b1220;color:var(--text)}
    .input-area button{border:none;border-radius:999px;padding:10px 16px;background:linear-gradient(90deg,var(--accent),#2563eb);color:#fff;cursor:pointer}
    .sidebar{padding:18px;display:flex;flex-direction:column;gap:14px;height:fit-content}
    .side-card{padding:16px;border:1px solid var(--border);border-radius:16px;background:rgba(255,255,255,0.03)}
    .side-card h3{margin:0 0 12px;font-size:16px}
    .side-card input[type=file]{width:100%;margin-bottom:8px}
    .side-card button{width:100%;padding:10px;border:none;border-radius:10px;background:linear-gradient(90deg,var(--accent2),#059669);color:#fff;cursor:pointer}
    .pill{display:inline-block;margin:2px 4px;padding:4px 8px;background:rgba(52,211,153,0.16);color:#bbf7d0;border-radius:999px;font-size:12px}
    .group-item{display:flex;align-items:center;padding:14px 16px;border-bottom:1px solid var(--border);text-decoration:none;color:var(--text);transition:background .15s;cursor:pointer}
    .group-item:hover{background:rgba(56,189,248,0.08)}
    .group-avatar{width:44px;height:44px;border-radius:12px;background:linear-gradient(135deg,var(--accent),#2563eb);display:flex;align-items:center;justify-content:center;font-size:18px;font-weight:700;flex-shrink:0;margin-right:12px}
    .group-info{flex:1;min-width:0}
    .group-name{font-weight:600;font-size:15px;display:flex;align-items:center;gap:8px}
    .group-preview{color:var(--muted);font-size:13px;margin-top:3px;white-space:nowrap;overflow:hidden;text-overflow:ellipsis}
    .group-arrow{color:var(--muted);font-size:20px;margin-left:8px;flex-shrink:0}
    .badge{display:inline-block;background:#ef4444;color:#fff;font-size:11px;min-width:18px;height:18px;line-height:18px;text-align:center;border-radius:9px;padding:0 5px;font-weight:700;animation:pulse .6s ease-in-out}
    @keyframes pulse{0%,100%{transform:scale(1)}50%{transform:scale(1.15)}}
  </style>
</head>
<body>
  <div class="nav">
    <div><strong>💬 群聊</strong></div>
    <div>
      <a href="/shop">商城</a>
      <a href="/orders">订单</a>
      <a href="/friends">好友</a>
      <a href="/chat">群聊</a>
      <a href="/shop/create">开店</a>
      <a href="/profile">头像</a>
      <a href="/logout">注销</a>
    </div>
  </div>
  <div class="wrap">
    <div class="shell">
      <div class="card" style="height:620px;display:flex;flex-direction:column">
        <div class="header">
          <div><strong>💬 群聊列表</strong></div>
          <a href="/friends" style="background:linear-gradient(90deg,var(--accent),#2563eb);color:#fff;padding:8px 16px;border-radius:999px;text-decoration:none;font-size:14px;font-weight:600">+ 创建群聊</a>
        </div>
        <div id="groupList" style="flex:1;overflow-y:auto">
          <div style="text-align:center;padding:60px 20px;color:var(--muted)">加载中...</div>
        </div>
      </div>
      <div class="sidebar">
        <div class="card side-card">
          <h3>📋 快捷操作</h3>
          <a href="/friends" style="display:block;width:100%;padding:10px;text-align:center;border:none;border-radius:10px;background:linear-gradient(90deg,var(--accent),#2563eb);color:#fff;text-decoration:none;font-weight:600;margin-bottom:8px">➕ 创建群聊</a>
          <a href="/chat/public" style="display:block;width:100%;padding:10px;text-align:center;border:none;border-radius:10px;background:linear-gradient(90deg,var(--accent2),#059669);color:#fff;text-decoration:none;font-weight:600">🌐 公共聊天室</a>
        </div>
      </div>
    </div>
  </div>
  <script src="/socket.io/socket.io.js"></script>
  <script>
  (function(){
    var socket = io();
    var userId = <%= user.id %>;
    var username = '<%= user.username %>';
    var listEl = document.getElementById('groupList');

    function loadGroups() {
      fetch('/api/groups').then(function(r){return r.json()}).then(function(groups){
        if (!groups.length) {
          listEl.innerHTML = '<div style="text-align:center;padding:60px 20px"><div style="font-size:48px;margin-bottom:12px">💬</div><div style="color:var(--muted);margin-bottom:16px">还没有群聊</div><a href="/friends" style="display:inline-block;padding:10px 24px;background:linear-gradient(90deg,var(--accent),#2563eb);color:#fff;border-radius:999px;text-decoration:none;font-weight:600">去创建群聊</a></div>';
          return;
        }
        var html = '';
        groups.forEach(function(g){
          var badge = g.unread > 0 ? '<span class="badge">'+g.unread+'</span>' : '';
          html += '<a href="/chat/group/'+g.id+'" class="group-item" data-id="'+g.id+'">'+
            '<div class="group-avatar">'+g.name.charAt(0)+'</div>'+
            '<div class="group-info"><div class="group-name">'+g.name+badge+'</div>'+
            '<div class="group-preview">'+g.unread+' 条未读消息</div></div>'+
            '<div class="group-arrow">›</div></a>';
        });
        listEl.innerHTML = html;
      });
    }

    socket.on('connect', function(){
      socket.emit('login', { id: userId, username: username, page: '群聊列表' });
      socket.emit('getUnread');
      loadGroups();
    });

    socket.on('groupUnread', function(data){
      var el = document.querySelector('.group-item[data-id="'+data.groupId+'"]');
      if (el) {
        var badge = el.querySelector('.badge');
        if (data.unread > 0) {
          if (badge) badge.textContent = data.unread;
          else {
            var nb = document.createElement('span');
            nb.className = 'badge';
            nb.textContent = data.unread;
            el.querySelector('.group-name').appendChild(nb);
          }
        } else {
          if (badge) badge.remove();
        }
      }
    });

    socket.on('unreadUpdate', function(data){
      loadGroups();
      var badge = document.getElementById('chatBadge');
      if (badge) {
        var total = data.privateUnread || 0;
        if (data.groups) data.groups.forEach(function(g){ total += g.unread || 0; });
        badge.textContent = total > 99 ? '99+' : total;
        badge.style.display = total > 0 ? 'inline-block' : 'none';
      }
    });
  })();
  </script>
</body>
</html>