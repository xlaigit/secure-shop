<!DOCTYPE html>
<html>
<head>
  <meta charset="UTF-8">
  <title>好友与群聊</title>
  <style>
    :root{--bg:#0f172a;--card:#111827;--card2:#1f2937;--text:#f9fafb;--muted:#9ca3af;--accent:#38bdf8;--accent2:#34d399;--border:rgba(255,255,255,0.1)}
    *{box-sizing:border-box} body{margin:0;font-family:Inter,Segoe UI,Arial,sans-serif;background:linear-gradient(135deg,#0f172a,#111827);color:var(--text)}
    .nav{display:flex;justify-content:space-between;align-items:center;padding:16px 24px;background:rgba(17,24,39,0.9);backdrop-filter:blur(10px);border-bottom:1px solid var(--border)}
    .nav a{color:#dbeafe;text-decoration:none;margin-left:12px;padding:6px 10px;border-radius:999px} .nav a:hover{background:rgba(56,189,248,0.16)}
    .wrap{max-width:1100px;margin:24px auto;padding:0 16px 32px}
    .hero{background:linear-gradient(120deg,rgba(56,189,248,0.18),rgba(52,211,153,0.14));border:1px solid var(--border);border-radius:20px;padding:20px 24px;box-shadow:0 20px 40px rgba(0,0,0,0.25)}
    .hero h2{margin:0 0 8px;font-size:24px}
    .hero p{margin:0;color:#cbd5e1}
    .grid{display:grid;grid-template-columns:1.2fr 0.8fr;gap:20px;margin-top:20px}
    .panel{background:rgba(17,24,39,0.9);border:1px solid var(--border);border-radius:18px;padding:18px;box-shadow:0 15px 30px rgba(0,0,0,0.2)}
    .panel h3{margin:0 0 12px;font-size:18px}
    .input-row{display:flex;gap:10px;flex-wrap:wrap}
    .input-row input{flex:1;min-width:220px;padding:10px 12px;border:1px solid var(--border);border-radius:10px;background:#0b1220;color:var(--text)}
    .btn{border:none;border-radius:999px;padding:10px 14px;cursor:pointer;color:#fff;background:linear-gradient(90deg,var(--accent),#2563eb)}
    .btn.secondary{background:linear-gradient(90deg,var(--accent2),#059669)}
    .btn.danger{background:linear-gradient(90deg,#fb7185,#ef4444)}
    .list{list-style:none;padding:0;margin:12px 0 0;display:grid;gap:10px}
    .item{display:flex;align-items:center;justify-content:space-between;padding:12px 14px;border:1px solid var(--border);border-radius:14px;background:rgba(255,255,255,0.03)}
    .item .left{display:flex;align-items:center;gap:10px}
    .chip{display:inline-block;padding:4px 8px;border-radius:999px;font-size:12px;background:rgba(56,189,248,0.16);color:#bae6fd}
    .muted{color:var(--muted)}
    .actions{display:flex;gap:8px;flex-wrap:wrap;align-items:center}
    .actions a,.actions button{padding:8px 10px;border:none;border-radius:10px;color:#fff;background:#374151;text-decoration:none;cursor:pointer}
    .actions a.primary{background:linear-gradient(90deg,var(--accent),#2563eb)}
    .checkbox-row{display:flex;align-items:center;gap:8px}
    .small{font-size:13px}
  </style>
</head>
<body>
  <div class="nav">
    <div><strong>🤝 好友与群聊</strong></div>
    <div>
      <a href="/shop">商城</a>
      <a href="/friends">好友</a>
      <a href="/chat">群聊</a>
      <a href="/shop/create">开店</a>
      <a href="/logout">注销</a>
    </div>
  </div>
  <div class="wrap">
    <div class="hero">
      <h2>连接好友，轻松拉群</h2>
      <p>快速添加好友，选择成员后即可进入群聊，体验更顺畅的社交互动。</p>
    </div>
    <div class="grid">
      <div class="panel">
        <h3>➕ 添加好友</h3>
        <form method="POST" action="/friend/add" class="input-row">
          <input type="hidden" name="_csrf" value="<%= csrfToken %>">
          <input name="username" placeholder="输入好友用户名" required>
          <button class="btn" type="submit">添加</button>
        </form>

        <h3 style="margin-top:20px">🧑‍🤝‍🧑 好友列表</h3>
        <form method="POST" action="/friend/group">
          <input type="hidden" name="_csrf" value="<%= csrfToken %>">
          <div class="actions" style="margin-bottom:10px">
            <button class="btn secondary" type="submit">拉群进入聊天</button>
          </div>
          <ul class="list">
            <% friends.forEach(f => { %>
              <% if (f.status !== 'pending') { %>
                <li class="item">
                  <div class="left">
                    <input type="checkbox" name="friend_ids[]" value="<%= f.friend_id %>">
                    <div>
                      <div><strong><%= f.username %></strong></div>
                      <div class="muted small">已是好友</div>
                    </div>
                  </div>
                  <div class="actions">
                    <a class="primary" href="/chat/private/<%= f.friend_id %>">私聊</a>
                    <form method="POST" action="/friend/delete/<%= f.id %>" style="display:inline">
                      <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                      <button class="danger" type="submit">删除</button>
                    </form>
                  </div>
                </li>
              <% } %>
            <% }) %>
          </ul>
        </form>
      </div>

      <div class="panel">
        <h3>📬 好友申请</h3>
        <ul class="list">
          <% friends.forEach(f => { %>
            <% if (f.status === 'pending') { %>
              <li class="item">
                <div>
                  <div><strong><%= f.username %></strong></div>
                  <div class="muted small">等待你处理</div>
                </div>
                <div class="actions">
                  <% if (f.friend_id != user.id) { %>
                    <form method="POST" action="/friend/accept/<%= f.id %>" style="display:inline">
                      <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                      <button class="btn" type="submit">接受</button>
                    </form>
                  <% } else { %>
                    <span class="chip">等待对方接受</span>
                  <% } %>
                  <form method="POST" action="/friend/delete/<%= f.id %>" style="display:inline">
                    <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                    <button class="danger" type="submit">忽略</button>
                  </form>
                </div>
              </li>
            <% } %>
          <% }) %>
        </ul>
      </div>
    </div>
  </div>
</body>
</html>