<!DOCTYPE html>
<html lang="zh-CN">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= product.name %> · 安全练习商城</title>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
  <style>
    *{box-sizing:border-box;margin:0;padding:0}
    body{font-family:'Inter','Segoe UI',Arial,sans-serif;background:linear-gradient(150deg,#f0f4ff 0%,#faf0ff 40%,#fef7ed 100%);min-height:100vh;color:#1f2937}
    .nav{background:rgba(255,255,255,0.85);backdrop-filter:blur(16px);-webkit-backdrop-filter:blur(16px);padding:12px 28px;box-shadow:0 1px 8px rgba(0,0,0,0.06);display:flex;justify-content:space-between;align-items:center;flex-wrap:wrap;gap:10px;position:sticky;top:0;z-index:50;border-bottom:1px solid rgba(255,255,255,0.5)}
    .nav .brand{display:flex;align-items:center;gap:10px;font-weight:700;font-size:15px;letter-spacing:-0.3px;color:#1f2937}
    .nav .brand-icon{width:34px;height:34px;background:linear-gradient(135deg,#6366f1,#a855f7);border-radius:10px;display:flex;align-items:center;justify-content:center;box-shadow:0 2px 8px rgba(99,102,241,0.3)}
    .nav .brand-icon svg{width:18px;height:18px;color:white}
    .nav .menu{display:flex;flex-wrap:wrap;gap:3px;align-items:center}
    .nav .menu a{padding:7px 12px;text-decoration:none;color:#4b5563;border-radius:8px;font-size:13px;font-weight:500;transition:all 0.2s}
    .nav .menu a:hover{background:#f3f4f6;color:#6366f1}
    .nav .menu a.active{background:linear-gradient(135deg,#6366f1,#a855f7);color:white;box-shadow:0 2px 8px rgba(99,102,241,0.3)}
    .nav .menu a.danger{color:#ef4444}
    .nav .menu a.danger:hover{background:#fef2f2;color:#dc2626}
    .container{max-width:1100px;margin:0 auto;padding:24px}

    .breadcrumb{display:flex;align-items:center;gap:8px;font-size:13px;color:#6b7280;margin-bottom:20px;flex-wrap:wrap}
    .breadcrumb a{color:#6366f1;text-decoration:none;font-weight:500}
    .breadcrumb a:hover{text-decoration:underline}
    .breadcrumb span{color:#9ca3af}

    .detail-card{background:white;border-radius:20px;box-shadow:0 2px 16px rgba(0,0,0,0.06);overflow:hidden;margin-bottom:24px}
    .detail-body{display:flex;gap:32px;padding:32px}
    @media(max-width:768px){.detail-body{flex-direction:column;padding:20px;gap:20px}}

    .detail-image{flex:0 0 360px;height:360px;border-radius:16px;background:#f9fafb;display:flex;align-items:center;justify-content:center;overflow:hidden;position:relative}
    @media(max-width:768px){.detail-image{flex:none;width:100%;height:280px}}
    .detail-image .placeholder{font-size:64px;opacity:0.3}
    .detail-image .cat-tag{position:absolute;top:12px;left:12px;padding:4px 12px;border-radius:999px;font-size:12px;font-weight:600;background:rgba(99,102,241,0.15);color:#6366f1;backdrop-filter:blur(4px)}

    .detail-info{flex:1;min-width:0}
    .detail-info .brand{display:inline-block;padding:3px 10px;border-radius:6px;font-size:12px;font-weight:600;background:rgba(99,102,241,0.1);color:#6366f1;margin-bottom:10px}
    .detail-info h1{font-size:24px;font-weight:700;color:#111827;margin-bottom:10px;line-height:1.4}
    .detail-info .meta{display:flex;flex-wrap:wrap;gap:16px;margin-bottom:16px;padding-bottom:16px;border-bottom:1px solid #f3f4f6}
    .detail-info .meta-item{display:flex;align-items:center;gap:4px;font-size:13px;color:#6b7280}
    .detail-info .meta-item .val{color:#1f2937;font-weight:600}
    .detail-info .meta-item .stars{color:#f59e0b;letter-spacing:1px}
    .detail-info .price-box{background:linear-gradient(135deg,#fef2f2,#fff7ed);border-radius:14px;padding:16px 20px;margin-bottom:20px;display:flex;align-items:baseline;gap:12px;flex-wrap:wrap}
    .detail-info .price-box .now{font-size:36px;font-weight:700;color:#ef4444;letter-spacing:-1px}
    .detail-info .price-box .now::before{content:'¥';font-size:20px;font-weight:600;margin-right:2px}
    .detail-info .price-box .original{font-size:16px;color:#9ca3af;text-decoration:line-through}
    .detail-info .price-box .discount{background:#fef2f2;color:#dc2626;padding:4px 10px;border-radius:6px;font-size:12px;font-weight:700}
    .detail-info .price-box .promo-tag{background:linear-gradient(135deg,#ef4444,#dc2626);color:white;padding:4px 12px;border-radius:6px;font-size:12px;font-weight:700;animation:promoPulse 2s ease-in-out infinite}
    .detail-info .price-box .sales{font-size:13px;color:#6b7280;margin-left:auto}
    @keyframes promoPulse{0%,100%{opacity:1}50%{opacity:0.7}}
    .detail-info .desc{font-size:14px;color:#4b5563;line-height:1.7;margin-bottom:20px;padding:16px;background:#f9fafb;border-radius:12px}

    .action-bar{display:flex;gap:12px;flex-wrap:wrap;margin-bottom:16px}
    .action-bar .btn{display:inline-flex;align-items:center;justify-content:center;gap:6px;padding:14px 28px;border-radius:14px;font-size:15px;font-weight:600;cursor:pointer;transition:all 0.2s;border:none;font-family:inherit;text-decoration:none}
    .action-bar .btn-primary{background:linear-gradient(135deg,#6366f1,#a855f7);color:white;box-shadow:0 4px 16px rgba(99,102,241,0.3);flex:1}
    .action-bar .btn-primary:hover{transform:translateY(-2px);box-shadow:0 8px 24px rgba(99,102,241,0.4)}
    .action-bar .btn-secondary{background:#f3f4f6;color:#4b5563;border:1px solid #e5e7eb}
    .action-bar .btn-secondary:hover{background:#e5e7eb}
    .action-bar .btn-wish{background:#fef2f2;color:#dc2626;border:1px solid #fecaca;padding:14px 20px}
    .action-bar .btn-wish.wished{background:#dc2626;color:white;border-color:#dc2626}
    .action-bar .btn-wish:hover{transform:scale(1.05)}
    .action-bar .qty-selector{display:flex;align-items:center;gap:0;border:1px solid #e5e7eb;border-radius:12px;overflow:hidden}
    .action-bar .qty-selector button{width:40px;height:46px;border:none;background:#f9fafb;font-size:18px;font-weight:600;cursor:pointer;color:#4b5563;transition:all 0.15s}
    .action-bar .qty-selector button:hover{background:#e5e7eb}
    .action-bar .qty-selector input{width:50px;height:46px;border:none;border-left:1px solid #e5e7eb;border-right:1px solid #e5e7eb;text-align:center;font-size:15px;font-weight:600;outline:none}

    .section{margin-bottom:24px}
    .section h2{font-size:18px;font-weight:700;margin-bottom:14px;display:flex;align-items:center;gap:8px;color:#111827}

    .review-card{background:white;border-radius:14px;padding:16px 20px;box-shadow:0 1px 4px rgba(0,0,0,0.04);margin-bottom:10px}
    .review-card .review-header{display:flex;justify-content:space-between;align-items:center;margin-bottom:8px}
    .review-card .review-user{font-size:13px;font-weight:600;color:#374151}
    .review-card .review-stars{color:#f59e0b;font-size:14px;letter-spacing:1px}
    .review-card .review-time{font-size:11px;color:#9ca3af}
    .review-card .review-comment{font-size:14px;color:#4b5563;line-height:1.6}

    .related-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(165px,1fr));gap:12px}
    .related-item{background:white;border-radius:14px;padding:14px;box-shadow:0 1px 4px rgba(0,0,0,0.06);transition:all 0.2s;border:1px solid #f3f4f6;text-decoration:none;display:block;color:inherit}
    .related-item:hover{transform:translateY(-3px);box-shadow:0 8px 20px rgba(0,0,0,0.1);border-color:#e5e7eb}
    .related-item .rp{font-size:17px;font-weight:700;color:#6366f1;margin-bottom:4px}
    .related-item .rp::before{content:'¥';font-size:12px;font-weight:600}
    .related-item .rn{font-size:13px;font-weight:600;color:#111827;margin-bottom:4px;display:-webkit-box;-webkit-line-clamp:2;-webkit-box-orient:vertical;overflow:hidden;min-height:36px;line-height:1.3}
    .related-item .rs{font-size:11px;color:#9ca3af}
    .related-item .rcat{display:inline-block;padding:1px 6px;border-radius:4px;font-size:9px;font-weight:600;background:rgba(99,102,241,0.1);color:#6366f1;margin-bottom:6px}

    .empty-reviews{background:white;border-radius:14px;padding:40px 20px;text-align:center;box-shadow:0 1px 4px rgba(0,0,0,0.04)}
    .empty-reviews .ico{font-size:36px;margin-bottom:8px;opacity:0.4}
    .empty-reviews p{color:#6b7280;font-size:13px}

    @media(max-width:768px){.nav{padding:10px 16px}.container{padding:14px 12px}.detail-info h1{font-size:20px}.detail-info .price-box .now{font-size:28px}.action-bar .btn{padding:12px 20px;font-size:14px}.related-grid{grid-template-columns:repeat(auto-fill,minmax(140px,1fr))}}

    @keyframes slideIn{from{opacity:0;transform:translateX(40px)}to{opacity:1;transform:translateX(0)}}
  </style>
</head>
<body>
  <div class="nav">
    <div class="brand">
      <div class="brand-icon">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M6 2L3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4z"/><line x1="3" y1="6" x2="21" y2="6"/><path d="M16 10a4 4 0 0 1-8 0"/></svg>
      </div>
      <span>安全练习商城</span>
    </div>
    <div class="menu">
      <a href="/shop">🛒 商城</a>
      <a href="/cart" style="position:relative">🛍️ 购物车<span id="navCartBadge" style="display:none;position:absolute;top:-6px;right:-14px;background:#ef4444;color:#fff;font-size:10px;min-width:16px;height:16px;line-height:16px;text-align:center;border-radius:8px;padding:0 4px;font-weight:700">0</span></a>
      <a href="/orders">📋 订单</a>
      <a href="/billing">💰 账单</a>
      <a class="danger" href="/logout">退出</a>
    </div>
  </div>

  <div class="container">
    <div class="breadcrumb">
      <a href="/shop">商城</a>
      <span>/</span>
      <% if (product.category) { %><a href="/shop?category=<%= encodeURIComponent(product.category) %>"><%= product.category %></a><span>/</span><% } %>
      <span><%= product.name %></span>
    </div>

    <div class="detail-card">
      <div class="detail-body">
        <div class="detail-image">
          <% if (product.category) { %><span class="cat-tag"><%= product.category %></span><% } %>
          <span class="placeholder">📦</span>
        </div>
        <div class="detail-info">
          <% if (product.brand) { %><span class="brand"><%= product.brand %></span><% } %>
          <h1><%= product.name %></h1>
          <div class="meta">
            <span class="meta-item">⭐ 评分：<span class="val stars"><%= '★'.repeat(Math.round(Number(product.avg_rating) || 0)) %><%= '☆'.repeat(5 - Math.round(Number(product.avg_rating) || 0)) %></span> <span class="val"><%= product.avg_rating || 0 %></span></span>
            <span class="meta-item">📝 <span class="val"><%= product.review_count || 0 %></span> 条评价</span>
            <span class="meta-item">📦 已售 <span class="val"><%= product.sales_count || 0 %></span> 件</span>
            <span class="meta-item">📊 库存 <span class="val"><%= product.stock %></span> 件</span>
          </div>
          <div class="price-box">
            <% if (typeof promoInfo !== 'undefined' && promoInfo && promoInfo.discounted) { %>
              <span class="original" style="font-size:18px">¥<%= promoInfo.originalPrice %></span>
              <span class="now">¥<%= promoInfo.finalPrice %></span>
              <span class="promo-tag"><%= promoInfo.promoDiscountText %></span>
              <span style="font-size:11px;color:#6b7280;margin-left:4px;background:rgba(99,102,241,0.1);padding:2px 8px;border-radius:4px"><%= promoInfo.promoTitle %></span>
            <% } else { %>
              <span class="now"><%= product.price %></span>
            <% } %>
            <span class="sales">🔥 已售 <%= product.sales_count || 0 %> 件</span>
          </div>
          <% if (product.description) { %>
          <div class="desc"><%= product.description %></div>
          <% } else { %>
          <div class="desc" style="color:#9ca3af;font-style:italic">暂无商品描述</div>
          <% } %>
          <div class="action-bar">
            <div class="qty-selector">
              <button onclick="adj(-1)">−</button>
              <input type="text" id="buyQty" value="1" readonly>
              <button onclick="adj(1)">+</button>
            </div>
            <button class="btn btn-primary" onclick="addToCart()">🛒 加入购物车</button>
            <form action="/buy" method="POST" style="display:flex;gap:8px;flex:1">
              <input type="hidden" name="_csrf" value="<%= csrfToken %>">
              <input type="hidden" name="product_id" value="<%= product.id %>">
              <input type="hidden" name="quantity" id="buyQtyHidden" value="1">
              <input type="text" name="coupon" placeholder="优惠码" style="width:80px;padding:8px;border:1px solid #e5e7eb;border-radius:10px;font-size:12px;text-align:center">
              <button type="submit" class="btn btn-primary" style="flex:1">⚡ 立即购买</button>
            </form>
            <button class="btn btn-wish <%= isWished ? 'wished' : '' %>" id="wishBtn" onclick="toggleWish()"><%= isWished ? '❤️' : '🤍' %></button>
          </div>
          <div style="font-size:12px;color:#6b7280;display:flex;gap:20px;padding:10px 0;border-top:1px solid #f3f4f6">
            <span>✅ 正品保障</span>
            <span>🔄 七天退换</span>
            <span>🚚 满99包邮</span>
          </div>
        </div>
      </div>
    </div>

    <!-- 用户评价 -->
    <div class="section">
      <h2>📝 用户评价 (<%= reviews.length %>)</h2>
      <% if (reviews.length > 0) { %>
        <% reviews.forEach(function(r) { %>
        <div class="review-card">
          <div class="review-header">
            <span class="review-user"><%= r.username %></span>
            <span class="review-stars"><%= '★'.repeat(r.rating) %><%= '☆'.repeat(5 - r.rating) %></span>
            <span class="review-time"><%= r.created_at %></span>
          </div>
          <div class="review-comment"><%= r.comment || '用户未填写评价内容' %></div>
        </div>
        <% }); %>
      <% } else { %>
        <div class="empty-reviews">
          <div class="ico">💬</div>
          <p>暂无评价，快来购买并分享你的使用体验吧</p>
        </div>
      <% } %>
    </div>

    <!-- 猜你喜欢 -->
    <% if (related.length > 0) { %>
    <div class="section">
      <h2>🎯 猜你喜欢</h2>
      <div class="related-grid">
        <% related.forEach(function(r) { %>
        <a href="/product/<%= r.id %>" class="related-item">
          <span class="rcat"><%= r.category || '其他' %></span>
          <div class="rn"><%= r.name %></div>
          <div class="rp"><%= r.price %></div>
          <div class="rs">已售 <%= r.sales_count || 0 %> 件</div>
        </a>
        <% }); %>
      </div>
    </div>
    <% } %>
  </div>

  <script src="/socket.io/socket.io.js"></script>
  <script>
    var socket = io();
    socket.on('connect', function(){
      socket.emit('login', { id: <%= user.id %>, username: '<%= user.username %>' });
    });

    function updateCartBadge(count) {
      var badge = document.getElementById('navCartBadge');
      if (!badge) return;
      if (!count || count <= 0) { badge.style.display = 'none'; return; }
      badge.textContent = count > 99 ? '99+' : count;
      badge.style.display = 'inline-block';
    }
    fetch('/api/cart/count').then(r=>r.json()).then(function(data){ updateCartBadge(data.count); }).catch(function(){});

    var qty = 1;
    function adj(d) {
      qty = Math.max(1, Math.min(<%= product.stock %>, qty + d));
      document.getElementById('buyQty').value = qty;
      document.getElementById('buyQtyHidden').value = qty;
    }

    function addToCart() {
      var xhr = new XMLHttpRequest();
      xhr.open('POST', '/api/cart/add');
      xhr.setRequestHeader('Content-Type', 'application/x-www-form-urlencoded');
      xhr.onload = function() {
        try {
          var res = JSON.parse(xhr.responseText);
          if (res.ok) {
            updateCartBadge(res.count);
            showToast('🛒 已加入购物车 (x' + qty + ')', 'success');
          } else {
            showToast(res.msg || '加入失败', 'error');
          }
        } catch(e) { showToast('加入失败', 'error'); }
      };
      xhr.onerror = function() { showToast('网络错误', 'error'); };
      xhr.send('product_id=<%= product.id %>&quantity=' + qty);
    }

    function toggleWish() {
      var xhr = new XMLHttpRequest();
      xhr.open('POST', '/api/wishlist/toggle');
      xhr.setRequestHeader('Content-Type', 'application/x-www-form-urlencoded');
      xhr.onload = function() {
        try {
          var res = JSON.parse(xhr.responseText);
          if (res.ok) {
            var btn = document.getElementById('wishBtn');
            if (res.action === 'added') {
              btn.innerHTML = '❤️'; btn.classList.add('wished');
              showToast('⭐ 已收藏', 'success');
            } else {
              btn.innerHTML = '🤍'; btn.classList.remove('wished');
              showToast('💔 已取消收藏', 'success');
            }
          }
        } catch(e) { showToast('操作失败', 'error'); }
      };
      xhr.onerror = function() { showToast('网络错误', 'error'); };
      xhr.send('product_id=<%= product.id %>');
    }

    function showToast(msg, type) {
      var bg = type === 'success' ? 'linear-gradient(135deg,#10b981,#059669)' : 'linear-gradient(135deg,#ef4444,#dc2626)';
      var toast = document.createElement('div');
      toast.style.cssText = 'position:fixed;top:20px;right:20px;' + bg + ';color:white;padding:14px 20px;border-radius:12px;box-shadow:0 10px 30px rgba(0,0,0,0.2);z-index:9999;font-size:14px;font-weight:500;max-width:360px;animation:slideIn 0.3s ease;transition:all 0.3s';
      toast.textContent = msg;
      document.body.appendChild(toast);
      setTimeout(function() { toast.style.opacity = '0'; setTimeout(function() { toast.remove(); }, 300); }, 2500);
    }
  </script>
</body>
</html>