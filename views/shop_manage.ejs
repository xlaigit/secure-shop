<!DOCTYPE html>
<html><head><meta charset="UTF-8"><title>管理店铺 - <%= shop.name %></title>
<style>
  body{font-family:'Microsoft YaHei',sans-serif;background:#f5f5f5;margin:0;padding:20px}
  .nav{background:white;padding:12px 20px;border-radius:10px;box-shadow:0 2px 8px rgba(0,0,0,.06);margin-bottom:20px}
  .nav a{color:#4299e1;text-decoration:none;margin-right:15px;font-size:14px}
  .nav a:hover{text-decoration:underline}
  .warn-banner{background:linear-gradient(135deg,#f6ad55,#ed8936);color:white;padding:20px;border-radius:12px;margin-bottom:20px;box-shadow:0 6px 20px rgba(237,137,54,.25)}
  .warn-banner h3{margin-bottom:8px}
  .warn-banner p{margin:6px 0;font-size:13px}
  .warn-banner a{color:white;text-decoration:underline;font-weight:bold}
  .container{background:white;padding:25px;border-radius:12px;box-shadow:0 2px 10px rgba(0,0,0,.05)}
  h2{color:#2d3748;margin-top:0}
  h3{color:#4a5568;border-bottom:2px solid #e2e8f0;padding-bottom:6px;margin-top:25px}
  form{background:#f7fafc;padding:15px;border-radius:8px;margin-bottom:15px}
  label{display:block;margin:8px 0;font-size:13px;color:#4a5568}
  input[type=text],input[type=number]{padding:8px;border:1px solid #cbd5e0;border-radius:6px;font-size:13px;width:200px}
  button{padding:8px 16px;background:#4299e1;color:white;border:none;border-radius:6px;cursor:pointer;font-size:13px;margin-top:8px}
  button:hover{background:#3182ce}
  ul{list-style:none;padding:0}
  li{background:#f7fafc;padding:12px 15px;border-radius:8px;margin-bottom:8px;display:flex;align-items:center;justify-content:space-between}
  .shop-desc{color:#718096;font-size:14px;margin:10px 0 20px}
  .modal{display:none;position:fixed;top:0;left:0;width:100%;height:100%;background:rgba(0,0,0,0.5);z-index:999;align-items:center;justify-content:center}
  .modal-content{background:white;border-radius:16px;padding:24px;width:90%;max-width:420px;box-shadow:0 20px 60px rgba(0,0,0,0.3)}
  .modal-header{display:flex;justify-content:space-between;align-items:center;margin-bottom:20px}
  .modal-title{font-size:18px;font-weight:700;color:#2d3748}
  .modal-close{background:none;border:none;font-size:24px;cursor:pointer;color:#a0aec0;padding:0;margin:0}
  .modal-close:hover{color:#4a5568}
  .form-group{margin-bottom:16px}
  .form-group label{display:block;margin-bottom:6px;font-size:14px;font-weight:600;color:#4a5568}
  .form-group select,.form-group input{width:100%;padding:10px;border:2px solid #e2e8f0;border-radius:10px;font-size:14px;background:white}
  .form-group select:focus,.form-group input:focus{outline:none;border-color:#4299e1}
  .btn{display:inline-block;padding:10px 20px;border:none;border-radius:10px;cursor:pointer;font-size:14px;font-weight:600}
  .btn-primary{background:#4299e1;color:white;width:100%}
  .btn-primary:hover{background:#3182ce}
  .ship-info{background:#ebf8ff;border:1px solid #bee3f8;border-radius:10px;padding:12px;margin-top:8px;font-size:13px;color:#2b6cb0;line-height:1.8}
  .product-images{display:flex;gap:8px;flex-wrap:wrap;margin-top:8px}
  .product-images img{width:60px;height:60px;object-fit:cover;border-radius:8px;border:2px solid #e2e8f0}
  .product-images .img-wrap{position:relative;display:inline-block}
  .product-images .del-img{position:absolute;top:-6px;right:-6px;background:#fc8181;color:white;border:none;border-radius:50%;width:20px;height:20px;font-size:12px;cursor:pointer;line-height:1;padding:0}
  .upload-form{display:inline-block;margin-left:8px}
  .upload-form input[type=file]{font-size:12px;width:160px}
  .upload-form button{padding:4px 10px;font-size:12px;margin-top:0}
</style></head>
<body>
  <div class="nav">
    <a href="/shop">🛒 商城</a> | <a href="/friends">👥 好友</a> | <a href="/chat">💬 群聊</a> | <a href="/shop/create">🏪 开店</a> | <a href="/shop/manage">📦 我的店铺</a> | <a href="/shop/warehouses">🏭 仓库</a> | <a href="/notifications">📨 邮件</a> | <a href="/appeal">📝 申诉</a>| <a href="/shop/coupons">🎫 优惠券</a> |
  </div>

  <% if (typeof shopWarning !== 'undefined' && shopWarning) { %>
    <div class="warn-banner">
      <h3>⚠️ 您的店铺当前处于警告期</h3>
      <p>警告到期时间：<strong id="warnTime"><%= warningUntil %></strong></p>
      <p>在此期间，您的商品将不在商城首页展示，且无法发布新商品。</p>
      <p>如果您认为此警告有误，可以 <a href="/appeal">提交申诉 →</a></p>
    </div>
  <% } %>

  <div class="container">
    <h2>🏪 <%= shop.name %></h2>
    <p class="shop-desc"><%= shop.description %></p>
    <h3>📝 添加商品</h3>
    <% if (typeof shopWarning !== 'undefined' && shopWarning) { %>
      <p style="color:#dd6b20;background:#fffaf0;padding:10px;border-radius:8px">⚠️ 警告期内无法发布新商品，请等待警告结束或申诉。</p>
    <% } else { %>
    <form method="POST" action="/shop/product/add">
      <input type="hidden" name="_csrf" value="<%= csrfToken %>">
      <label>名称：<input name="name" required></label><br>
      <label>价格：<input type="number" step="0.01" name="price" required></label><br>
      <label>库存：<input type="number" name="stock" value="999"></label><br>
      <label>运费：<select name="shipping_policy" style="padding:8px;border:1px solid #cbd5e0;border-radius:6px;font-size:13px;width:200px">
        <option value="0">📦 包邮（商家承担）</option>
        <option value="1" selected>💰 不包邮（买家承担）</option>
        <option value="2">🔄 半包邮（各付一半）</option>
      </select></label><br>
      <button type="submit">✅ 添加</button>
    </form>
    <% } %>
    <h3>📦 商品列表</h3>
    <ul>
      <% products.forEach(p => { %>
        <li style="flex-direction:column;align-items:flex-start;gap:8px">
          <div style="display:flex;align-items:center;justify-content:space-between;width:100%">
          <span><strong><%= p.name %></strong> - ¥<%= p.price %> (库存:<%= p.stock %>)</span>
          <form method="POST" action="/shop/product/delete/<%= p.id %>" style="display:inline">
            <input type="hidden" name="_csrf" value="<%= csrfToken %>">
            <button type="submit" style="background:#fc8181">🗑️ 删除</button>
          </form>
          </div>
          <div class="product-images">
            <% if (typeof images !== 'undefined') { images.filter(function(img){ return img.product_id === p.id; }).forEach(function(img){ %>
              <div class="img-wrap">
                <img src="<%= img.url %>" alt="商品图">
                <form method="POST" action="/shop/product/<%= p.id %>/images/delete/<%= img.id %>" style="display:inline">
                  <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                  <button class="del-img" title="删除图片">✕</button>
                </form>
              </div>
            <% }) } %>
            <form method="POST" action="/shop/product/<%= p.id %>/images" enctype="multipart/form-data" class="upload-form">
              <input type="hidden" name="_csrf" value="<%= csrfToken %>">
              <input type="file" name="images" accept="image/*" multiple>
              <button type="submit">📷 上传</button>
            </form>
          </div>
        </li>
      <% }) %>
      <% if (products.length === 0) { %><li style="justify-content:center;color:#a0aec0">📭 暂无商品，快来添加吧！</li><% } %>
    </ul>
    <h3>📋 订单管理</h3>
    <% if (typeof orders !== 'undefined' && orders.length > 0) { %>
      <ul>
      <% orders.forEach(function(o) { %>
        <li>
          <span><strong><%= o.product_name %></strong> - ¥<%= o.price %> - <%= o.buyer_name %> 
            <% if (o.ship_status === 'shipped') { %>🚚 <%= o.carrier %> <%= o.tracking_number || '' %>
            <% } else if (o.ship_status === 'delivered') { %>📬 已送达
            <% } else if (o.ship_status === 'signed') { %>✅ 已签收
            <% } else { %>⏳ 待发货<% } %>
          </span>
          <% if (!o.ship_status || o.ship_status === 'pending') { %>
            <button type="button" class="btn ship-btn" data-order="<%= o.id %>" style="background:#e0e7ff;color:#4338ca">📦 发货</button>
          <% } %>
        </li>
      <% }) %>
      </ul>
    <% } else { %>
      <p style="color:#9ca3af">暂无订单</p>
    <% } %>
  </div>
  <% if (typeof warningUntil !== 'undefined' && warningUntil) { %>
  <script>
    var wt = document.getElementById('warnTime');
    if (wt) { var d = new Date('<%= warningUntil %>'); wt.textContent = d.getFullYear() + '-' + String(d.getMonth()+1).padStart(2,'0') + '-' + String(d.getDate()).padStart(2,'0') + ' ' + String(d.getHours()).padStart(2,'0') + ':' + String(d.getMinutes()).padStart(2,'0'); }
  </script>
  <% } %>

  <div class="modal" id="shipModal">
  <div class="modal-content">
    <div class="modal-header">
      <span class="modal-title">📦 发货</span>
      <button class="modal-close" onclick="closeShipModal()">&times;</button>
    </div>
    <form method="POST" id="shipForm" action="#">
      <input type="hidden" name="_csrf" value="<%= csrfToken %>">
      <div class="form-group">
        <label>仓库</label>
        <select name="warehouse_id">
          <option value="0">默认</option>
          <% if (typeof warehouses !== 'undefined') { warehouses.forEach(function(w) { %>
            <option value="<%= w.id %>"><%= w.name %></option>
          <% }) } %>
        </select>
      </div>
      <div class="form-group">
        <label>快递商</label>
        <select name="carrier" id="carrierSelect" onchange="updateShipInfo()">
          <option value="邮政">邮政（慢，3-7天）</option>
          <option value="中通">中通（中速，2-5天）</option>
          <option value="顺丰陆运">顺丰陆运（较快，2-3天）</option>
          <option value="顺丰空运">顺丰空运（快，1-2天）</option>
        </select>
        <div class="ship-info" id="shipInfo">
          📮 快递：<strong>邮政</strong> ｜ 速度：<strong>标准</strong> ｜ 时速：<strong>30km/h</strong> ｜ 运费：<strong>基础价</strong>
        </div>
      </div>
      <div class="form-group">
        <label>重量 (kg)</label>
        <input name="weight" type="number" step="0.1" placeholder="0.5" value="1">
      </div>
      <button class="btn btn-primary" type="submit">确认发货</button>
    </form>
  </div>
</div>
<script>
(function(){
var shipInfoData = {
  '邮政': { speed: '标准', kmh: '30km/h', fee: '最低' },
  '中通': { speed: '标准', kmh: '50km/h', fee: '中等' },
  '顺丰陆运': { speed: '快速', kmh: '70km/h', fee: '较高' },
  '顺丰空运': { speed: '特快', kmh: '500km/h', fee: '最高' }
};
function updateShipInfo() {
  var c = document.getElementById('carrierSelect');
  if (!c) return;
  var d = shipInfoData[c.value] || { speed: '标准', kmh: '?', fee: '?' };
  var el = document.getElementById('shipInfo');
  if (el) el.innerHTML = '📮 快递：<strong>' + c.value + '</strong> ｜ 速度：<strong>' + d.speed + '</strong> ｜ 时速：<strong>' + d.kmh + '</strong> ｜ 运费：<strong>' + d.fee + '</strong>';
}
function showShipForm(orderId) {
  var form = document.getElementById('shipForm');
  var modal = document.getElementById('shipModal');
  if (form) form.action = '/shop/ship/' + orderId;
  if (modal) modal.style.display = 'flex';
  updateShipInfo();
}
function closeShipModal() {
  var modal = document.getElementById('shipModal');
  if (modal) modal.style.display = 'none';
}
var btns = document.querySelectorAll('.ship-btn');
for (var i = 0; i < btns.length; i++) {
  btns[i].addEventListener('click', function(){
    showShipForm(this.getAttribute('data-order'));
  });
}
var cs = document.getElementById('carrierSelect');
if (cs) cs.addEventListener('change', updateShipInfo);
})();
</script>
</body></html>