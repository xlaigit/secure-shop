<!DOCTYPE html>
<html lang="zh-CN">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>老虎机 - 游戏中心</title>
  <link rel="icon" href="data:image/svg+xml,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 100 100'><text y='.9em' font-size='90'>🎰</text></svg>">
  <style>
    * { margin: 0; padding: 0; box-sizing: border-box; }
    body {
      font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
      background: linear-gradient(135deg, #1a0000, #4a0000, #1a0000);
      min-height: 100vh; color: #fff;
    }
    nav {
      background: rgba(0,0,0,0.3); backdrop-filter: blur(12px);
      padding: 12px 24px; display: flex; align-items: center; gap: 16px;
      border-bottom: 1px solid rgba(255,255,255,0.08);
    }
    nav a { color: rgba(255,255,255,0.7); text-decoration: none; font-size: 14px; padding: 6px 14px; border-radius: 8px; transition: all 0.2s; }
    nav a:hover { background: rgba(255,255,255,0.1); color: #fff; }
    nav .brand { font-size: 20px; font-weight: 700; color: #ffd700; margin-right: auto; }
    nav .balance { background: rgba(255,215,0,0.15); color: #ffd700; padding: 6px 16px; border-radius: 20px; font-size: 14px; font-weight: 600; }

    .container { max-width: 560px; margin: 0 auto; padding: 40px 20px; text-align: center; }
    .title { font-size: 32px; font-weight: 800; color: #ffd700; margin-bottom: 6px; }
    .subtitle { color: rgba(255,255,255,0.5); font-size: 14px; margin-bottom: 30px; }

    .slot-machine {
      background: linear-gradient(135deg, #2a0000, #3a0000);
      border: 3px solid #ffd700; border-radius: 24px;
      padding: 30px; position: relative;
      box-shadow: 0 0 40px rgba(255,215,0,0.1);
    }
    .slot-machine .top-decor {
      position: absolute; top: -20px; left: 50%; transform: translateX(-50%);
      background: #ffd700; color: #000; font-size: 14px; font-weight: 700;
      padding: 4px 20px; border-radius: 10px; text-transform: uppercase;
    }

    .reels {
      display: flex; gap: 10px; justify-content: center; margin-bottom: 20px;
    }
    .reel {
      width: 110px; height: 130px;
      background: linear-gradient(135deg, #1a1a2e, #0d0d1a);
      border: 2px solid rgba(255,215,0,0.3); border-radius: 16px;
      display: flex; align-items: center; justify-content: center;
      font-size: 64px; overflow: hidden;
      box-shadow: inset 0 0 20px rgba(0,0,0,0.5);
    }
    .reel .symbol {
      transition: all 0.1s;
    }
    .reel.spinning .symbol {
      animation: reelSpin 0.1s linear infinite;
    }
    @keyframes reelSpin {
      0% { transform: translateY(-100px); opacity: 0; }
      100% { transform: translateY(100px); opacity: 0; }
    }
    .reel .symbol.final { animation: none; transform: translateY(0); opacity: 1; }

    .reel:nth-child(1).stopping .symbol { animation: stopReel 0.3s ease-out; }
    .reel:nth-child(2).stopping .symbol { animation: stopReel 0.3s ease-out 0.15s; }
    .reel:nth-child(3).stopping .symbol { animation: stopReel 0.3s ease-out 0.3s; }
    @keyframes stopReel {
      0% { transform: scale(1.5) rotate(10deg); opacity: 0.5; }
      100% { transform: scale(1) rotate(0deg); opacity: 1; }
    }

    .combo-result {
      font-size: 28px; font-weight: 800; min-height: 50px; margin-bottom: 16px;
    }
    .combo-result.win { color: #ffd700; text-shadow: 0 0 20px rgba(255,215,0,0.3); }
    .combo-result.lose { color: rgba(255,255,255,0.3); }

    .bet-area { display: flex; gap: 10px; align-items: center; justify-content: center; margin-bottom: 16px; flex-wrap: wrap; }
    .bet-area input {
      background: rgba(0,0,0,0.4); border: 2px solid rgba(255,215,0,0.3);
      border-radius: 12px; padding: 10px 18px; color: #fff; font-size: 18px;
      width: 140px; text-align: center; outline: none;
    }
    .bet-area input:focus { border-color: #ffd700; }
    .bet-area .quick-bet button {
      background: rgba(255,255,255,0.1); border: 1px solid rgba(255,255,255,0.15);
      border-radius: 8px; color: #fff; padding: 8px 14px; cursor: pointer; font-size: 14px; transition: all 0.2s;
    }
    .bet-area .quick-bet button:hover { background: rgba(255,215,0,0.2); border-color: #ffd700; }

    .btn-spin {
      padding: 14px 50px; border: none; border-radius: 30px;
      background: linear-gradient(90deg, #e74c3c, #c0392b); color: #fff;
      font-size: 18px; font-weight: 700; cursor: pointer;
      transition: all 0.2s; margin-bottom: 20px;
    }
    .btn-spin:hover { transform: scale(1.05); box-shadow: 0 0 30px rgba(231,76,60,0.3); }
    .btn-spin:disabled { opacity: 0.4; cursor: not-allowed; transform: none; }

    .payout-table { background: rgba(0,0,0,0.3); border-radius: 16px; padding: 16px; }
    .payout-table h3 { font-size: 14px; color: rgba(255,255,255,0.5); margin-bottom: 8px; }
    .payout-table .row { display: flex; justify-content: space-between; padding: 3px 0; font-size: 13px; color: rgba(255,255,255,0.7); }
    .payout-table .row .sym { font-size: 18px; }

    .toast {
      position: fixed; top: 80px; left: 50%; transform: translateX(-50%);
      background: rgba(0,0,0,0.85); color: #fff; padding: 12px 28px;
      border-radius: 12px; font-size: 15px; z-index: 999;
      opacity: 0; transition: opacity 0.3s; pointer-events: none;
    }
    .toast.show { opacity: 1; }
  </style>
</head>
<body>
  <nav>
    <a href="/games" class="brand">🎰 老虎机</a>
    <a href="/games">🎮 游戏中心</a>
    <a href="/games/blackjack">🃏 21点</a>
    <a href="/games/dice">🎲 骰子</a>
    <a href="/games/guess">🔢 猜数字</a>
    <span class="balance">💰 <span id="balanceDisplay"><%= user.balance.toFixed(2) %></span> 金币</span>
  </nav>

  <div class="toast" id="toast"></div>

  <div class="container">
    <div class="title">🎰 老虎机</div>
    <div class="subtitle">试试你的运气！三个相同符号赢大奖</div>

    <div class="slot-machine">
      <div class="top-decor">★ JACKPOT ★</div>
      <div class="reels" id="reels">
        <div class="reel" id="reel0"><div class="symbol">🍒</div></div>
        <div class="reel" id="reel1"><div class="symbol">🍋</div></div>
        <div class="reel" id="reel2"><div class="symbol">🍊</div></div>
      </div>
    </div>

    <div class="combo-result" id="comboResult"></div>

    <div class="bet-area">
      <input type="number" id="betInput" value="50" min="10" step="10">
      <div class="quick-bet">
        <button onclick="setBet(10)">10</button>
        <button onclick="setBet(50)">50</button>
        <button onclick="setBet(100)">100</button>
        <button onclick="setBet(<%= Math.floor(user.balance) %>)">All-in</button>
      </div>
    </div>

    <button class="btn-spin" id="spinBtn" onclick="spin()">🎰 转一转</button>

    <div class="payout-table">
      <h3>📊 赔付表</h3>
      <div class="row"><span><span class="sym">7️⃣</span><span class="sym">7️⃣</span><span class="sym">7️⃣</span></span><span>50 倍</span></div>
      <div class="row"><span><span class="sym">💎</span><span class="sym">💎</span><span class="sym">💎</span></span><span>20 倍</span></div>
      <div class="row"><span><span class="sym">🔔</span><span class="sym">🔔</span><span class="sym">🔔</span></span><span>10 倍</span></div>
      <div class="row"><span><span class="sym">🍇</span><span class="sym">🍇</span><span class="sym">🍇</span></span><span>5 倍</span></div>
      <div class="row"><span><span class="sym">🍊</span><span class="sym">🍊</span><span class="sym">🍊</span></span><span>3 倍</span></div>
      <div class="row"><span><span class="sym">🍋</span><span class="sym">🍋</span><span class="sym">🍋</span></span><span>2 倍</span></div>
      <div class="row"><span><span class="sym">🍒</span><span class="sym">🍒</span><span class="sym">🍒</span></span><span>1.5 倍</span></div>
      <div class="row"><span>任意两个相同</span><span>0.5 倍</span></div>
    </div>
  </div>

  <script>
    let isSpinning = false;
    const csrf = '<%= csrfToken %>';

    function showToast(msg) {
      const t = document.getElementById('toast');
      t.textContent = msg; t.classList.add('show');
      setTimeout(() => t.classList.remove('show'), 2500);
    }
    function setBet(v) { document.getElementById('betInput').value = v; }

    function spin() {
      if (isSpinning) return;
      const bet = parseFloat(document.getElementById('betInput').value);
      if (!bet || bet < 10) { showToast('最低下注 10 金币'); return; }

      isSpinning = true;
      document.getElementById('spinBtn').disabled = true;
      document.getElementById('comboResult').textContent = '';

      // 转轮动画
      const symbols = ['🍒', '🍋', '🍊', '🍇', '🔔', '💎', '7️⃣'];
      document.querySelectorAll('.reel').forEach((reel, i) => {
        reel.classList.add('spinning');
        const symbolDiv = reel.querySelector('.symbol');
        symbolDiv.classList.remove('final');
        // 快速切换显示
        const interval = setInterval(() => {
          symbolDiv.textContent = symbols[Math.floor(Math.random() * symbols.length)];
        }, 80);
        reel._interval = interval;
      });

      fetch('/api/games/slot/spin', {
        method: 'POST',
        headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
        body: 'bet=' + bet + '&_csrf=' + encodeURIComponent(csrf)
      })
      .then(r => r.json())
      .then(data => {
        // 停止转轮（逐个停止）
        document.querySelectorAll('.reel').forEach((reel, i) => {
          clearInterval(reel._interval);
          reel.classList.remove('spinning');
          reel.classList.add('stopping');
          const symbolDiv = reel.querySelector('.symbol');
          setTimeout(() => {
            symbolDiv.textContent = data.reels[i];
            symbolDiv.classList.add('final');
          }, i * 200);
        });

        setTimeout(() => {
          document.querySelectorAll('.reel').forEach(r => r.classList.remove('stopping'));

          const result = document.getElementById('comboResult');
          if (data.win) {
            result.className = 'combo-result win';
            result.textContent = `🎉 ${data.reels.join(' ')} 赢得 ${data.payout} 金币！`;
            if (data.multiplier >= 10) showToast(`🔥 大奖！${data.multiplier}x 赔付！`);
            else showToast(`🎉 +${data.payout} 金币！`);
          } else {
            result.className = 'combo-result lose';
            result.textContent = `${data.reels.join(' ')} 未中奖`;
          }
          document.getElementById('balanceDisplay').textContent = data.balance.toFixed(2);
          isSpinning = false;
          document.getElementById('spinBtn').disabled = false;
        }, 1200);
      })
      .catch(() => { showToast('网络错误'); isSpinning = false; document.getElementById('spinBtn').disabled = false; });
    }
  </script>
</body>
</html>